  <Footer />

  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      
      // 1. Setup Role Filtering
      const filterBtns = document.querySelectorAll('button[data-dept]');
      filterBtns.forEach(btn => {
        if (btn.dataset.bound) return;
        btn.dataset.bound = 'true';
        
        btn.addEventListener('click', function() { 
          filterRoles(this.getAttribute('data-dept'), this); 
        });
      });

      // 2. Setup Role Card Clicking
      const roleCards = document.querySelectorAll('.role-card');
      roleCards.forEach(card => {
        if (card.dataset.bound) return;
        card.dataset.bound = 'true';
        
        card.addEventListener('click', function() { 
          openRole(this); 
        });
      });

      // 3. Setup File Input UI
      const fileInput = document.querySelector('.app-file-input');
      if (fileInput && !fileInput.dataset.bound) {
        fileInput.dataset.bound = 'true';
        fileInput.addEventListener('change', function(e) {
          const target = e.target;
          const labelText = target.parentElement?.querySelector('.file-label-text');
          if (labelText && target.files && target.files.length > 0) {
            labelText.textContent = 'File attached âœ“';
            target.parentElement?.classList.add('bg-white/20', 'border-white/50', 'text-white');
          }
        });
      }

      // 4. Setup Form Submission
      const appForm = document.getElementById('app-form');
      if (appForm && !appForm.dataset.bound) {
        appForm.dataset.bound = 'true';
        appForm.addEventListener('submit', function(e) { 
          e.preventDefault(); 
          const submitBtn = document.getElementById('app-submit-btn');
          if(submitBtn) {
            submitBtn.textContent = 'Application sent! We will reply within 5 days âœ“';
            submitBtn.classList.remove('bg-amber-500', 'hover:bg-amber-600');
            submitBtn.classList.add('bg-emerald-700', 'pointer-events-none');
          }
        });
      }

      // --- Helper Functions ---
      function filterRoles(dept, el) {
        if(!dept) return;
        
        // Reset all buttons
        document.querySelectorAll('.rf').forEach(btn => {
          btn.classList.remove('bg-emerald-700', 'text-white', 'border-emerald-700', 'shadow-md');
          btn.classList.add('bg-transparent', 'text-emerald-900/70', 'border-transparent');
          
          const countSpan = btn.querySelector('.rf-count');
          if(countSpan) {
            countSpan.classList.remove('bg-white/20', 'text-white', 'border-transparent');
            countSpan.classList.add('bg-white', 'border', 'border-emerald-100', 'text-emerald-900/50');
          }
        });

        // Activate clicked button
        el.classList.remove('bg-transparent', 'text-emerald-900/70', 'border-transparent');
        el.classList.add('bg-emerald-700', 'text-white', 'border-emerald-700', 'shadow-md');
        
        const elCountSpan = el.querySelector('.rf-count');
        if(elCountSpan) {
          elCountSpan.classList.remove('bg-white', 'border', 'border-emerald-100', 'text-emerald-900/50');
          elCountSpan.classList.add('bg-white/20', 'text-white', 'border-transparent');
        }

        // Filter Cards
        const cards = document.querySelectorAll('.role-card');

        cards.forEach(card => {
          const cardDept = card.getAttribute('data-dept');
          if (dept === 'all' || cardDept === dept) {
            card.style.display = 'block';
          } else {
            card.style.display = 'none';
          }
        });

        // Fallback UI
        const noRolesMsg = document.getElementById('no-roles');
        if (noRolesMsg) {
          if (visibleCount === 0) {
            noRolesMsg.classList.remove('hidden');
          } else {
            noRolesMsg.classList.add('hidden');
          }
        }
      }

      function openRole(card) {
        const titleElement = card.querySelector('.role-title');
        if (!titleElement || !titleElement.textContent) return;
        
        const fullTitle = titleElement.textContent.trim();
        const baseTitle = fullTitle.split('â€”')[0].trim();

        const select = document.getElementById('role-select');
        if (select) {
          let matched = false;
          for (let i = 0; i < select.options.length; i++) {
            if (select.options[i].text.includes(baseTitle)) {
              select.selectedIndex = i;
              matched = true;
              break;
            }
          }
          if (!matched) {
            select.selectedIndex = select.options.length - 1; 
          }
        }

        const formElement = document.getElementById('apply-form');
        if(formElement) {
          formElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        
        if (select) {
          setTimeout(() => {
            select.classList.add('ring-2', 'ring-emerald-500', 'border-emerald-500');
            setTimeout(() => {
              select.classList.remove('ring-2', 'ring-emerald-500', 'border-emerald-500');
            }, 1500);
          }, 500);
        }
      }
      
    });
  </script>
</Base>
