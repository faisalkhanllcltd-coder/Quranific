---
// src/pages/404.astro
import Base from '../layouts/Base.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import Button from '../components/ui/Button.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Page Not Found | Quranific",
  "description": "The page you are looking for could not be found.",
  "url": "https://quranific.com/404",
  "isPartOf": {
    "@type": "WebSite",
    "name": "Quranific",
    "url": "https://quranific.com"
  }
};

const Icons = {
  home: `<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>`,
  support: `<svg class="w-5 h-5 shrink-0 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" /></svg>`
};
---

<Base title="Page Not Found | Quranific" description="The page you are looking for could not be found.">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" is:inline />
  <meta name="robots" content="noindex, follow" slot="head" />
  
  <Header />

  <main class="min-h-[85vh] flex items-center justify-center py-10 md:py-20 px-4 sm:px-6 relative overflow-hidden bg-gradient-to-b from-cream-50 to-white selection:bg-emerald-200 selection:text-emerald-950">
    
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-emerald-500/10 rounded-full blur-[100px] pointer-events-none" aria-hidden="true"></div>

    <div class="max-w-2xl mx-auto text-center relative z-10 animate-in fade-in slide-in-from-bottom-4 duration-700">
      
      <h1 class="text-8xl md:text-9xl font-black text-transparent bg-clip-text bg-gradient-to-br from-emerald-900 via-emerald-600 to-emerald-400 tracking-tighter mb-4 drop-shadow-sm">
        404
      </h1>
      
      <div class="w-16 h-1 bg-emerald-500 mx-auto rounded-full mb-8" aria-hidden="true"></div>
      
      <h2 class="text-3xl md:text-4xl font-bold text-emerald-950 mb-4 tracking-tight">
        Oops! Page Not Found.
      </h2>
      
      <p class="text-lg text-emerald-800/80 mb-10 font-medium max-w-md mx-auto leading-relaxed">
        It seems you've ventured off the path. The page you are looking for might have been moved or no longer exists.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/" variant="primary" class="w-full sm:w-auto flex items-center justify-center gap-2 px-8">
          <span set:html={Icons.home}></span>
          Return Home
        </Button>
        <Button href="/contact" variant="white" class="w-full sm:w-auto flex items-center justify-center gap-2 px-8 border-2 border-emerald-100 hover:border-emerald-300">
          <span set:html={Icons.support}></span>
          Contact Support
        </Button>
      </div>
      
    </div>
  </main>

  <Footer />
</Base>