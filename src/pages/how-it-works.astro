  <script>
    document.addEventListener('astro:page-load', () => {
      document.querySelectorAll('.slot-btn').forEach(btn => {
        // Prevent double binding during client-side navigation
      const htmlBtn = btn as HTMLElement;
      if (htmlBtn.dataset.bound) return;
      htmlBtn.dataset.bound = 'true';

        btn.addEventListener('click', (e) => {
          document.querySelectorAll('.slot-btn').forEach(b => {
            b.classList.remove('bg-emerald-700', 'text-white', 'border-emerald-700');
            b.classList.add('bg-cream-50', 'text-emerald-900/80', 'border-emerald-100');
          });
          const target = e.target as HTMLElement;
          target.classList.remove('bg-cream-50', 'text-emerald-900/80', 'border-emerald-100');
          target.classList.add('bg-emerald-700', 'text-white', 'border-emerald-700');
        });
      });
    });
  </script>
