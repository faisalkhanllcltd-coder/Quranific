  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      
      // --- 1. MAIN FEE CALCULATOR ---
      const calcState = { who: null, freq: null, cycle: null };
      
      // CRITICAL: Pure JS object. No TS type annotations.
      const basePrices = {
        child: { '2': 39, '3': 59, '5': 89 },
        adult: { '2': 39, '3': 59, '5': 89 }
      };

      document.querySelectorAll('.calc-btn').forEach(btn => {
        if (btn.dataset.bound) return;
        btn.dataset.bound = 'true';

        btn.addEventListener('click', function() {
          const parent = this.parentElement;
          if (!parent) return;
          
          const type = parent.id.replace('calc-', '').replace('-btns', '');
          const val = this.getAttribute('data-val');
          const label = this.getAttribute('data-label');

          // Update active class
          parent.querySelectorAll('.calc-btn').forEach(b => {
            b.classList.remove('bg-emerald-700', 'text-white', 'border-emerald-700');
            b.classList.add('bg-cream-50', 'text-emerald-900/70', 'border-emerald-200');
          });
          this.classList.remove('bg-cream-50', 'text-emerald-900/70', 'border-emerald-200');
          this.classList.add('bg-emerald-700', 'text-white', 'border-emerald-700');

          // Update state & label using pure JS
          calcState[type] = val;
          const valElem = document.getElementById(`calc-${type}-val`);
          if (valElem) valElem.textContent = label;

          // Run calculation if all selected
          if (calcState.who && calcState.freq && calcState.cycle) {
            updateCalcResult();
          }
        });
      });

      function updateCalcResult() {
        if(!calcState.who || !calcState.freq) return;
        
        // Pure JS property access
        const whoPrices = basePrices[calcState.who];
        const base = whoPrices ? (whoPrices[calcState.freq] || 39) : 39;
        
        const monthly = base;
        const annual = Math.round(base * 0.85); // 15% discount
        const isAnnual = calcState.cycle === 'annual';
        const price = isAnnual ? annual : monthly;
        const saving = isAnnual ? Math.round((monthly - annual) * 12) : 0;
        const sessions = parseInt(calcState.freq) * 4;
        const perSesh = (price / sessions).toFixed(2);

        const html = `
          <div class="flex justify-between items-center mb-2"><span class="text-sm text-emerald-800/80 font-medium">Sessions per month</span><span class="text-sm font-bold text-emerald-950">${sessions} sessions</span></div>
          <div class="flex justify-between items-center mb-4"><span class="text-sm text-emerald-800/80 font-medium">Per session</span><span class="text-sm font-bold text-emerald-950">$${perSesh}</span></div>
          ${isAnnual ? `<div class="flex justify-between items-center mb-4"><span class="text-sm text-emerald-800/80 font-medium">Annual total</span><span class="text-sm font-bold text-emerald-950">$${annual * 12}</span></div>` : ''}
          <div class="pt-4 border-t border-emerald-100 flex justify-between items-center">
            <span class="text-[15px] font-bold text-emerald-950">Monthly fee</span>
            <div class="text-right">
              <div class="font-serif text-3xl font-bold text-emerald-700 leading-none mb-1">$${price}<span class="text-sm font-medium text-emerald-800/60">/mo</span></div>
              ${saving > 0 ? `<div class="text-[10px] font-bold text-green-600 bg-green-50 border border-green-200 px-2 py-0.5 rounded-full inline-block">You save $${saving}/yr</div>` : ''}
            </div>
          </div>
        `;
        
        const calcResultBox = document.getElementById('calc-result-box');
        if (calcResultBox) {
          calcResultBox.innerHTML = html;
          calcResultBox.classList.remove('bg-emerald-50', 'border-emerald-100');
          calcResultBox.classList.add('bg-white', 'border-emerald-200', 'shadow-sm');
        }
      }

      // --- 2. BILLING TOGGLE ---
      let isAnnualPricing = true;
      const planPrices = {
        light: { m: 39, a: 33 },
        standard: { m: 59, a: 50 },
        intensive: { m: 89, a: 76 }
      };

      const billingToggle = document.getElementById('billing-toggle');
      if (billingToggle && !billingToggle.dataset.bound) {
        billingToggle.dataset.bound = 'true';
        
        billingToggle.addEventListener('click', () => {
          isAnnualPricing = !isAnnualPricing;
          
          const thumb = document.getElementById('billing-thumb');
          const lblAnnual = document.getElementById('lbl-annual');
          const lblMonthly = document.getElementById('lbl-monthly');

          if (isAnnualPricing && thumb && lblAnnual && lblMonthly) {
            billingToggle.classList.replace('bg-emerald-100', 'bg-emerald-700');
            thumb.classList.replace('translate-x-1', 'translate-x-6');
            lblAnnual.classList.replace('text-emerald-900/60', 'text-emerald-950');
            lblMonthly.classList.replace('text-emerald-950', 'text-emerald-900/60');
          } else if (thumb && lblAnnual && lblMonthly) {
            billingToggle.classList.replace('bg-emerald-700', 'bg-emerald-100');
            thumb.classList.replace('translate-x-6', 'translate-x-1');
            lblMonthly.classList.replace('text-emerald-900/60', 'text-emerald-950');
            lblAnnual.classList.replace('text-emerald-950', 'text-emerald-900/60');
          }

          const p = isAnnualPricing ? 'a' : 'm';
          const suf = isAnnualPricing ? 'per month, billed annually' : 'per month, billed monthly';
          const orig = {
            light: isAnnualPricing ? '$39/mo when billed monthly' : '',
            standard: isAnnualPricing ? '$59/mo when billed monthly' : '',
            intensive: isAnnualPricing ? '$89/mo when billed monthly' : ''
          };

          ['light', 'standard', 'intensive'].forEach(id => {
            const priceEl = document.getElementById(`price-${id}`);
            if(priceEl) priceEl.textContent = planPrices[id][p].toString();
            
            const perEl = document.getElementById(`per-${id}`);
            if(perEl) perEl.textContent = suf;
            
            const origEl = document.getElementById(`orig-${id}`);
            if (origEl) {
              if (orig[id]) {
                origEl.textContent = orig[id];
                origEl.classList.remove('invisible');
              } else {
                origEl.classList.add('invisible');
              }
            }
          });
        });
      }

      // --- 3. SIBLING CALCULATOR ---
      const addBtn = document.getElementById('sib-add-btn');
      if (addBtn && !addBtn.dataset.bound) {
        addBtn.dataset.bound = 'true';
        
        addBtn.addEventListener('click', function addSibling() {
          const row2 = document.getElementById('child2-row');
          
          if (row2 && row2.classList.contains('hidden')) {
            row2.classList.remove('hidden');
            row2.classList.add('flex');
            
            const label = document.getElementById('sib-total-label');
            if(label) label.textContent = '2 children enrolled';
            
            const total = document.getElementById('sib-total-num');
            if(total) total.textContent = '$94';
            
            const savingBadge = document.getElementById('sib-saving');
            if (savingBadge) {
              savingBadge.classList.remove('hidden');
              savingBadge.classList.add('block');
            }
            
            addBtn.textContent = 'Contact us for 3+ children →';
            addBtn.onclick = (e) => {
              e.preventDefault();
              window.location.href = 'mailto:hello@quranific.com';
            };
          }
        });
      }
      
    });
  </script>
</Base>