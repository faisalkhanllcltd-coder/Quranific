---
// src/pages/contact.astro
import Base from '../layouts/Base.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';

// SECURITY FIX (C-07): Importing canonical SITE data instead of using fake placeholders
import { SITE } from '../constants/site';

// G-1 FIX: SITE.email, SITE.phone, SITE.address now defined on the SITE object.
// Fallbacks are kept defensively but will never activate once SITE is updated.
const CONTACT_INFO = {
  email:    SITE.emails.support,
  whatsapp: SITE.whatsappNumber || '923112112122',
  // G-2 FIX: Phone and address fields removed from the public contact card.
  // Do not display a placeholder number. Add SITE.phone when a real number exists.
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Us - Quranific | We Reply to Every Message",
  "description": "Get in touch with the Quranific team. Contact us via email or WhatsApp for support, inquiries, or feedback.",
  "mainEntity": {
    "@type": "Organization",
    "name": "Quranific",
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer support",
      "email": CONTACT_INFO.email,
      "availableLanguage": ["English", "Arabic"]
    }
  }
};

// Reusable SVGs
const Icons = {
  wa:   `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>`,
  mail: `<svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
  form: `<svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
};
---

<Base
  title="Contact Us - Quranific | We Reply to Every Message"
  description="Get in touch with the Quranific team. Contact us via email or WhatsApp for support, inquiries, or feedback."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" is:inline />
  <!-- Cloudflare Turnstile — loaded async so it never blocks rendering -->
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline slot="head"></script>

  <Header />

  <main class="bg-cream-50 selection:bg-emerald-100 selection:text-emerald-900 font-sans">

    <Section height={700} class="pt-16 md:pt-32 pb-10 md:pb-20 lg:pt-48 lg:pb-32 px-4 sm:px-6 relative overflow-hidden">
      <div class="absolute top-[-10%] right-[-10%] w-[600px] h-[600px] bg-amber-500/5 rounded-full blur-[100px] pointer-events-none" aria-hidden="true"></div>
      <div class="absolute bottom-[-10%] left-[-10%] w-[500px] h-[500px] bg-emerald-700/5 rounded-full blur-[100px] pointer-events-none" aria-hidden="true"></div>

      <div class="max-w-7xl mx-auto grid lg:grid-cols-[1.1fr_0.9fr] gap-16 items-start relative z-10">

        <div>
          <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-emerald-50 border border-emerald-200 text-emerald-700 text-xs font-bold uppercase tracking-widest rounded-full mb-6 shadow-sm">
            WhatsApp replies typically within 3–10 minutes; form/email submissions get a response within 1 hour.
          </div>

          <h1 class="text-4xl lg:text-[3.5rem] font-bold text-emerald-950 leading-[1.1] tracking-tight mb-6">
            We reply to <em class="font-serif italic text-emerald-700 font-medium">every message</em> within 24 hours.
          </h1>

          <p class="text-lg text-emerald-900/80 font-medium leading-relaxed mb-10 max-w-xl">
            No chatbots. No ticket queues. A real person from our team reads every message and responds with the answer you actually need — not a link to an FAQ.
          </p>

          <div class="flex flex-col gap-4">
            <a href={`https://wa.me/${CONTACT_INFO.whatsapp.replace(/\D/g, '')}`} target="_blank" class="flex items-center gap-5 bg-white border border-emerald-100 rounded-2xl p-5 hover:shadow-md transition-all duration-300 group relative overflow-hidden">
              <div class="absolute left-0 top-0 bottom-0 w-1 bg-[#25D366] scale-y-0 group-hover:scale-y-100 origin-bottom transition-transform duration-300" aria-hidden="true"></div>
              <div class="w-12 h-12 rounded-xl bg-green-50 border border-green-200 text-green-600 flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform" aria-hidden="true"><Fragment set:html={Icons.wa} /></div>
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-0.5">
                  <h3 class="font-bold text-emerald-950 text-[15px]">WhatsApp</h3>
                  <span class="px-2 py-0.5 bg-green-50 border border-green-200 text-green-600 text-[10px] font-bold rounded-full">Fastest · ~12 mins</span>
                </div>
                <p class="text-sm font-medium text-emerald-800/70">For quick questions and urgent matters.</p>
              </div>
            </a>

            <a href="#contact-form" class="flex items-center gap-5 bg-white border border-emerald-100 rounded-2xl p-5 hover:shadow-md transition-all duration-300 group relative overflow-hidden">
              <div class="absolute left-0 top-0 bottom-0 w-1 bg-emerald-700 scale-y-0 group-hover:scale-y-100 origin-bottom transition-transform duration-300" aria-hidden="true"></div>
              <div class="w-12 h-12 rounded-xl bg-emerald-50 border border-emerald-100 text-emerald-700 flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform" aria-hidden="true"><Fragment set:html={Icons.form} /></div>
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-0.5">
                  <h3 class="font-bold text-emerald-950 text-[15px]">Contact Form</h3>
                  <span class="px-2 py-0.5 bg-emerald-50 border border-emerald-100 text-emerald-700 text-[10px] font-bold rounded-full">Within 24 hrs</span>
                </div>
                <p class="text-sm font-medium text-emerald-800/70">For detailed questions and enrolment routing.</p>
              </div>
            </a>

            <a href={`mailto:${CONTACT_INFO.email}`} class="flex items-center gap-5 bg-white border border-emerald-100 rounded-2xl p-5 hover:shadow-md transition-all duration-300 group relative overflow-hidden">
              <div class="absolute left-0 top-0 bottom-0 w-1 bg-amber-500 scale-y-0 group-hover:scale-y-100 origin-bottom transition-transform duration-300" aria-hidden="true"></div>
              <div class="w-12 h-12 rounded-xl bg-amber-50 border border-amber-200 text-amber-600 flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform" aria-hidden="true"><Fragment set:html={Icons.mail} /></div>
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-0.5">
                  <h3 class="font-bold text-emerald-950 text-[15px]">Direct Email</h3>
                  <span class="px-2 py-0.5 bg-emerald-50 border border-emerald-100 text-emerald-700 text-[10px] font-bold rounded-full">Within 24 hrs</span>
                </div>
                <p class="text-sm font-medium text-emerald-800/70">{CONTACT_INFO.email}</p>
              </div>
            </a>
          </div>
        </div>

        <div class="hidden lg:block relative z-20">
          <div class="bg-white rounded-3xl shadow-2xl shadow-emerald-900/10 border border-emerald-100 overflow-hidden transform rotate-2 hover:rotate-0 transition-transform duration-500">
            <div class="bg-[#075E54] px-4 py-3 flex items-center gap-3">
              <span class="text-white/80 text-2xl font-light cursor-pointer select-none" aria-hidden="true">‹</span>
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-emerald-500 to-emerald-700 flex items-center justify-center font-serif text-white text-lg font-bold shadow-inner" aria-hidden="true">Q</div>
              <div class="flex-1">
                <div class="text-white font-bold text-sm leading-tight">Quranific Support</div>
                <div class="text-white/70 text-[11px]">Online · Usually replies in 12 mins</div>
              </div>
              <div class="text-white/70 flex gap-3" aria-hidden="true"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg></div>
            </div>

            <div class="bg-[#ECE5DD] p-5 h-[340px] flex flex-col gap-3 overflow-y-auto">
              <div class="text-center"><span class="bg-white/50 text-black/40 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest">Today</span></div>

              <div class="bg-white text-[#1a1a1c] text-[13px] font-medium p-3 rounded-tr-xl rounded-b-xl rounded-tl-sm max-w-[85%] self-start shadow-sm relative">
                Assalamu Alaikum! 👋 Welcome to Quranific. How can I help you today?
                <div class="text-[9px] text-black/30 text-right mt-1">10:02 ✓✓</div>
              </div>

              <div class="bg-[#DCF8C6] text-[#1a1a1c] text-[13px] font-medium p-3 rounded-tl-xl rounded-b-xl rounded-tr-sm max-w-[85%] self-end shadow-sm relative">
                Wa Alaikum Salam! My daughter is 7 and hasn't started Quran yet. Is it too late?
                <div class="text-[9px] text-black/30 text-right mt-1 flex justify-end items-center gap-1">10:04 <span class="text-[#53bdeb] font-bold">✓✓</span></div>
              </div>

              <div class="bg-white text-[#1a1a1c] text-[13px] font-medium p-3 rounded-tr-xl rounded-b-xl rounded-tl-sm max-w-[85%] self-start shadow-sm relative">
                Not at all — age 7 is actually a perfect time to start 🌙<br/><br/>Your daughter would start with Arabic letters and Noorani Qaida — and progress is usually very fast at her age.
                <div class="text-[9px] text-black/30 text-right mt-1">10:05 ✓✓</div>
              </div>

              <div class="bg-[#DCF8C6] text-[#1a1a1c] text-[13px] font-medium p-3 rounded-tl-xl rounded-b-xl rounded-tr-sm max-w-[85%] self-end shadow-sm relative">
                That's reassuring! Can we try a class first before committing?
                <div class="text-[9px] text-black/30 text-right mt-1 flex justify-end items-center gap-1">10:06 <span class="text-[#53bdeb] font-bold">✓✓</span></div>
              </div>

              <div class="bg-white text-[#1a1a1c] p-3 rounded-tr-xl rounded-b-xl rounded-tl-sm self-start shadow-sm flex items-center gap-1.5" id="wa-typing" style="display:none;" aria-hidden="true">
                <span class="w-1.5 h-1.5 bg-black/30 rounded-full animate-bounce"></span>
                <span class="w-1.5 h-1.5 bg-black/30 rounded-full animate-bounce" style="animation-delay: 0.2s"></span>
                <span class="w-1.5 h-1.5 bg-black/30 rounded-full animate-bounce" style="animation-delay: 0.4s"></span>
              </div>

              <div class="bg-white text-[#1a1a1c] text-[13px] font-medium p-3 rounded-tr-xl rounded-b-xl rounded-tl-sm max-w-[85%] self-start shadow-sm relative" id="wa-reply" style="display:none;">
                Absolutely — your first class is <strong>completely free</strong>, no credit card needed. We'll match your daughter to a teacher within a few hours of signing up 😊<br/><br/>Want me to send you the link to book?
                <div class="text-[9px] text-black/30 text-right mt-1">10:07 ✓✓</div>
              </div>
            </div>

            <div class="bg-[#f0f0f0] p-2.5 flex items-center gap-2 border-t border-black/5" aria-hidden="true">
              <div class="bg-white rounded-full py-2 px-4 text-[13px] text-black/40 flex-1">Type a message...</div>
              <div class="w-10 h-10 rounded-full bg-[#25D366] flex items-center justify-center text-white"><svg class="w-5 h-5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg></div>
            </div>
          </div>
        </div>

      </div>
    </Section>

    <!-- ─── SMART CONTACT FORM ─────────────────────────────────────────────── -->
    <Section height={900} class="py-12 md:py-24 bg-white border-y border-emerald-50" id="contact-form">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-[1fr_1.4fr] gap-12 lg:gap-20 items-start">

          <div class="lg:sticky lg:top-32">
            <span class="text-xs font-black tracking-widest uppercase text-emerald-700 block mb-3">Send a Message</span>
            <h2 class="text-3xl lg:text-4xl font-bold text-emerald-950 mb-4 tracking-tight leading-tight">
              Tell us what you need.<br/><em class="font-serif italic text-emerald-700 font-medium">We will sort it.</em>
            </h2>
            <p class="text-[15px] text-emerald-800/80 font-medium mb-10 leading-relaxed">
              Select the topic that best describes your question and the form will adapt to collect exactly what we need to give you a useful answer.
            </p>

            <div class="text-[11px] font-bold tracking-widest uppercase text-emerald-900/50 mb-3">What's your question about?</div>
            <div class="space-y-2.5 mb-10">
              <!-- E-3 FIX: Added aria-pressed to all topic buttons. JS updates them on click. -->
              <button
                class="w-full flex items-center gap-4 bg-emerald-50 border-2 border-emerald-700 rounded-xl p-3 text-left transition-all duration-300 topic-btn"
                data-topic="enrol"
                aria-pressed="true"
              >
                <div class="w-10 h-10 rounded-lg bg-white border border-emerald-100 flex items-center justify-center text-lg shrink-0 topic-icon" aria-hidden="true">🎓</div>
                <div><div class="font-bold text-emerald-950 text-sm">Enrolling a child</div><div class="text-[12px] font-medium text-emerald-800/70">Free trial, first steps, course selection</div></div>
              </button>
              <button
                class="w-full flex items-center gap-4 bg-cream-50 border border-emerald-100 rounded-xl p-3 text-left hover:border-emerald-700 hover:bg-emerald-50 transition-all duration-300 topic-btn"
                data-topic="existing"
                aria-pressed="false"
              >
                <div class="w-10 h-10 rounded-lg bg-white border border-emerald-50 flex items-center justify-center text-lg shrink-0 topic-icon" aria-hidden="true">📊</div>
                <div><div class="font-bold text-emerald-950 text-sm">I'm an existing parent</div><div class="text-[12px] font-medium text-emerald-800/70">Progress, teacher, schedule, billing</div></div>
              </button>
              <button
                class="w-full flex items-center gap-4 bg-cream-50 border border-emerald-100 rounded-xl p-3 text-left hover:border-emerald-700 hover:bg-emerald-50 transition-all duration-300 topic-btn"
                data-topic="adult"
                aria-pressed="false"
              >
                <div class="w-10 h-10 rounded-lg bg-white border border-emerald-50 flex items-center justify-center text-lg shrink-0 topic-icon" aria-hidden="true">🧑</div>
                <div><div class="font-bold text-emerald-950 text-sm">Adult learning</div><div class="text-[12px] font-medium text-emerald-800/70">Tajweed fix, private lessons</div></div>
              </button>
              <button
                class="w-full flex items-center gap-4 bg-cream-50 border border-emerald-100 rounded-xl p-3 text-left hover:border-emerald-700 hover:bg-emerald-50 transition-all duration-300 topic-btn"
                data-topic="teacher"
                aria-pressed="false"
              >
                <div class="w-10 h-10 rounded-lg bg-white border border-emerald-50 flex items-center justify-center text-lg shrink-0 topic-icon" aria-hidden="true">📜</div>
                <div><div class="font-bold text-emerald-950 text-sm">Teaching at Quranific</div><div class="text-[12px] font-medium text-emerald-800/70">Applications, vetting, joining</div></div>
              </button>
              <button
                class="w-full flex items-center gap-4 bg-cream-50 border border-emerald-100 rounded-xl p-3 text-left hover:border-emerald-700 hover:bg-emerald-50 transition-all duration-300 topic-btn"
                data-topic="other"
                aria-pressed="false"
              >
                <div class="w-10 h-10 rounded-lg bg-white border border-emerald-50 flex items-center justify-center text-lg shrink-0 topic-icon" aria-hidden="true">💬</div>
                <div><div class="font-bold text-emerald-950 text-sm">Something else</div><div class="text-[12px] font-medium text-emerald-800/70">Press, partnerships, general enquiry</div></div>
              </button>
            </div>

            <div class="bg-emerald-50 border border-emerald-100 rounded-2xl p-6">
              <div class="font-bold text-emerald-700 text-sm mb-3 flex items-center gap-2" aria-hidden="true">⏱ Our response promise</div>
              <div class="space-y-2">
                <div class="flex items-center gap-2 text-[13px] font-medium text-emerald-800/80"><span class="w-1.5 h-1.5 bg-emerald-700 rounded-full" aria-hidden="true"></span>WhatsApp: average 12 minutes</div>
                <div class="flex items-center gap-2 text-[13px] font-medium text-emerald-800/80"><span class="w-1.5 h-1.5 bg-emerald-700 rounded-full" aria-hidden="true"></span>Contact form: within 24 hours</div>
                <div class="flex items-center gap-2 text-[13px] font-medium text-emerald-800/80"><span class="w-1.5 h-1.5 bg-emerald-700 rounded-full" aria-hidden="true"></span>We reply to <strong class="text-emerald-950">every</strong> message — no exceptions</div>
              </div>
            </div>
          </div>

          <div class="bg-cream-50 border border-emerald-100 rounded-3xl p-8 lg:p-10 shadow-xl shadow-emerald-900/5">
            <div id="form-content">
              <h3 class="font-bold text-xl text-emerald-950 mb-1" id="form-dynamic-title">Enrol a child or book a free trial</h3>
              <p class="text-[13px] font-medium text-emerald-800/70 mb-8" id="form-dynamic-sub">Fill in the details below and we will get back to you within 24 hours with everything you need to get started.</p>

              <!--
                E-1 FIX: form now has action="/api/contact" and method="POST".
                The JS submit handler intercepts, appends the Turnstile token, and
                sends as JSON — same contract the API expects.
              -->
              <form class="space-y-5" id="smart-form" action="/api/contact" method="POST" novalidate>
                <div class="grid sm:grid-cols-2 gap-5">
                  <div>
                    <label for="fc-name" class="block text-xs font-bold uppercase tracking-wider text-emerald-900/60 mb-2">Your Name <span class="text-amber-500">*</span></label>
                    <input type="text" id="fc-name" name="fc-name" autocomplete="name" class="w-full px-4 py-3 text-sm bg-white border border-emerald-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-700 focus:border-transparent placeholder:text-emerald-900/20 font-medium" placeholder="Your full name" required>
                  </div>
                  <div>
                    <label for="fc-email" class="block text-xs font-bold uppercase tracking-wider text-emerald-900/60 mb-2">Email Address <span class="text-amber-500">*</span></label>
                    <input type="email" id="fc-email" name="fc-email" autocomplete="email" class="w-full px-4 py-3 text-sm bg-white border border-emerald-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-700 focus:border-transparent placeholder:text-emerald-900/20 font-medium" placeholder="you@example.com" required>
                  </div>
                </div>

                <div>
                  <label for="fc-whatsapp" class="block text-xs font-bold uppercase tracking-wider text-emerald-900/60 mb-2">WhatsApp Number (Preferred)</label>
                  <input type="tel" id="fc-whatsapp" name="fc-whatsapp" autocomplete="tel" class="w-full px-4 py-3 text-sm bg-white border border-emerald-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-700 focus:border-transparent placeholder:text-emerald-900/20 font-medium" placeholder="+44 7700 000000">
                </div>

                <div id="dynamic-child-field">
                  <label for="fc-level" class="block text-xs font-bold uppercase tracking-wider text-emerald-900/60 mb-2">Child's age and current level</label>
                  <select id="fc-level" name="fc-level" class="w-full px-4 py-3 text-sm bg-white border border-emerald-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-700 focus:border-transparent font-medium appearance-none cursor-pointer text-emerald-950">
                    <option value="">Select age and level</option>
                    <option>Age 4–6 · Complete beginner</option>
                    <option>Age 7–9 · Complete beginner</option>
                    <option>Age 7–9 · Can read some Arabic</option>
                    <option>Age 10–12 · Complete beginner</option>
                    <option>Age 10–12 · Can read Arabic</option>
                    <option>Age 13–14 · Any level</option>
                  </select>
                </div>

                <div>
                  <label for="fc-message" class="block text-xs font-bold uppercase tracking-wider text-emerald-900/60 mb-2">Your question or message <span class="text-amber-500">*</span></label>
                  <textarea id="fc-message" name="fc-message" class="w-full px-4 py-3 text-sm bg-white border border-emerald-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-700 focus:border-transparent placeholder:text-emerald-900/20 font-medium min-h-[120px] resize-y" placeholder="What would you like to know about enrolling or booking a free trial?" required></textarea>
                </div>

                <!--
                  E-2 FIX: Changed from <div> to <button type="button"> with role="checkbox"
                  and aria-checked so keyboard and screen-reader users can activate it.
                -->
                <button
                  type="button"
                  id="urgency-toggle"
                  role="checkbox"
                  aria-checked="false"
                  class="w-full flex items-center gap-4 bg-white border border-emerald-200 rounded-xl p-4 cursor-pointer hover:bg-amber-50 hover:border-amber-200 transition-all duration-300 text-left"
                >
                  <div class="text-xl shrink-0" aria-hidden="true">🚨</div>
                  <div class="flex-1">
                    <div class="font-bold text-emerald-950 text-sm">This is urgent</div>
                    <div class="text-[12px] font-medium text-emerald-800/70">Tick this and we will prioritise your message for a 2-hour reply</div>
