---
// src/pages/features.astro
import Base from '../layouts/Base.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';

// High-Level SEO Schema (WebPage)
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Features & Curriculum - Quranific | The Ultimate Online Quran Experience",
  "description": "Discover the premium features of Quranific. Interactive 1-on-1 classes, flexible scheduling, child-friendly tutors, and a guaranteed path to mastering Tajweed."
};

const Icons = {
  smile: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  star: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>`,
  clock: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  video: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>`,
  check: `<svg class="w-4 h-4 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>`,
  shield: `<svg class="w-8 h-8 text-emerald-950" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
  globe: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>`,
  users: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>`,
  support: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" /></svg>`,
  arrowRight: `<svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>`
};
---

<Base title="Features | Why Choose Quranific" description="Empowering students to become independent learners and confident reciters through 1-on-1 personalized Quran classes.">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" is:inline />
  
  <Header />

  <main class="min-h-screen bg-cream-50 selection:bg-emerald-200 selection:text-emerald-950 overflow-hidden">
    
    <Section height={500} class="pt-16 md:pt-32 pb-16 lg:pt-40 lg:pb-24 px-4 sm:px-6 relative">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-emerald-500/5 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>
      
      <div class="max-w-4xl mx-auto text-center relative z-10 animate-in fade-in slide-in-from-bottom-8 duration-1000">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-50 text-emerald-800 text-xs font-bold tracking-widest uppercase rounded-full mb-8 border border-emerald-100 shadow-sm">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500" aria-hidden="true"></span>
          The Quranific Experience
        </span>
        
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-emerald-950 mb-6 tracking-tighter leading-[1.1] text-balance">
          Where Faith Finds <br/> a Friendly Face.
        </h1>
        
        <p class="text-lg lg:text-xl text-emerald-700/80 font-medium max-w-2xl mx-auto leading-relaxed text-balance">
          We empower our students to become independent learners and confident reciters through personalized, one-on-one guidance.
        </p>
      </div>
    </Section>

    <Section height={400} class="py-12 px-4 sm:px-6 relative z-10">
      <div class="max-w-7xl mx-auto grid md:grid-cols-3 gap-6">
        
        <div class="bg-white rounded-3xl p-8 lg:p-10 shadow-sm border border-emerald-100 hover:shadow-md transition-shadow group">
          <div class="w-14 h-14 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-emerald-100 transition-all" aria-hidden="true">
            <span set:html={Icons.smile}></span>
          </div>
          <h3 class="text-2xl font-bold text-emerald-950 mb-3">Child-Friendly Tutors</h3>
          <p class="text-emerald-800/80 leading-relaxed font-medium">
            Our highly qualified instructors offer incredible patience and gentle guidance, creating a safe and engaging environment specifically for young beginners.
          </p>
        </div>

        <div class="bg-emerald-950 rounded-3xl p-8 lg:p-10 shadow-lg border border-emerald-800 hover:shadow-xl transition-shadow group transform md:-translate-y-4">
          <div class="w-14 h-14 bg-emerald-800 text-amber-400 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-all border border-emerald-700" aria-hidden="true">
            <span set:html={Icons.star}></span>
          </div>
          <h3 class="text-2xl font-bold text-white mb-3">Absolute Tajweed Focus</h3>
          <p class="text-emerald-100/80 leading-relaxed font-medium">
            We ensure proper pronunciation and beautiful recitation of the Quran. We guarantee your success, setting you on a path to excellence with confidence.
          </p>
        </div>

        <div class="bg-white rounded-3xl p-8 lg:p-10 shadow-sm border border-emerald-100 hover:shadow-md transition-shadow group">
          <div class="w-14 h-14 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-emerald-100 transition-all" aria-hidden="true">
            <span set:html={Icons.clock}></span>
          </div>
          <h3 class="text-2xl font-bold text-emerald-950 mb-3">Ultimate Flexibility</h3>
          <p class="text-emerald-800/80 leading-relaxed font-medium">
            Learn Quran online exactly on your schedule. Our systems are tailored completely to your family's needs, available across all global time zones.
          </p>
        </div>

      </div>
    </Section>

    <Section height={600} class="py-10 md:py-20 lg:py-32 px-4 sm:px-6">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
        <div class="relative order-2 lg:order-1">
          <div class="aspect-square max-w-md mx-auto relative">
            <div class="absolute inset-0 bg-emerald-100 rounded-full blur-3xl opacity-50" aria-hidden="true"></div>
            <div class="relative w-full h-full bg-white rounded-[2.5rem] shadow-xl border border-emerald-100 p-8 flex flex-col justify-between">
              <div class="flex justify-between items-start">
                <div class="w-16 h-16 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600" aria-hidden="true">
                  <span set:html={Icons.video}></span>
                </div>
                <span class="bg-emerald-100 text-emerald-800 text-xs font-bold px-3 py-1 rounded-full">Live Session</span>
              </div>
              <div class="space-y-4" aria-hidden="true">
                <div class="h-4 bg-emerald-50 rounded-full w-3/4"></div>
                <div class="h-4 bg-emerald-50 rounded-full w-1/2"></div>
                <div class="h-4 bg-emerald-50 rounded-full w-5/6"></div>
              </div>
              <div class="flex items-center gap-4 mt-8 pt-8 border-t border-emerald-50" aria-hidden="true">
                <div class="w-10 h-10 rounded-full bg-emerald-200"></div>
                <div>
                  <div class="w-24 h-3 bg-emerald-100 rounded-full mb-2"></div>
                  <div class="w-16 h-2 bg-emerald-50 rounded-full"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <div class="order-1 lg:order-2">
          <h2 class="text-3xl lg:text-5xl font-black text-emerald-950 mb-6 tracking-tight text-balance">
            Undivided Attention.<br/>Unmatched Results.
          </h2>
          <p class="text-lg text-emerald-800/80 leading-relaxed font-medium mb-8">
            We provide true one-on-one online Quran classes. This means your teacher is focused entirely on you, catching every nuance of your pronunciation and adapting the pace to your exact learning style.
          </p>
          <ul class="space-y-5">
            {[
              'Personalized lesson plans for every student',
              'Available for all ages: Kids, Adults, and Seniors',
              'Choose between Male and Female Hafiz/Qari tutors'
            ].map(item => (
              <li class="flex items-start gap-4 text-emerald-950 font-medium">
                <div class="w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center shrink-0 mt-0.5" aria-hidden="true">
                  <span set:html={Icons.check}></span>
                </div>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </Section>

    <Section height={700} class="py-10 md:py-20 lg:py-32 bg-emerald-50 border-y border-emerald-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-16 max-w-3xl mx-auto">
          <h2 class="text-3xl lg:text-5xl font-black text-emerald-950 mb-6 tracking-tight">A Clear Path to Mastery</h2>
          <p class="text-lg text-emerald-800/80 font-medium">
            Whether you are starting from the very beginning or looking to perfect your memorization, we have a structured path for you.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 relative">
          <div class="hidden md:block absolute top-12 left-20 right-20 h-0.5 bg-emerald-200 z-0" aria-hidden="true"></div>
          
          {[
            { step: '01', title: 'Basic Qaida', desc: 'Master the Arabic alphabet, joined letters, and basic pronunciation rules (Makharij). Perfect for beginners and young children.' },
            { step: '02', title: 'Quran Reading & Tajweed', desc: 'Transition to reading the Quran fluently. Learn advanced Tajweed rules to recite beautifully exactly as it was revealed.' },
            { step: '03', title: 'Hifz (Memorization)', desc: 'A structured, rigorous program for memorizing the Quran with dedicated review cycles to ensure it stays in your heart forever.' }
          ].map(item => (
            <div class="relative z-10 flex flex-col items-center text-center">
              <div class="w-24 h-24 bg-white rounded-full border-4 border-emerald-100 shadow-sm flex items-center justify-center text-2xl font-black text-emerald-700 mb-6" aria-hidden="true">
                {item.step}
              </div>
              <h3 class="text-xl font-bold text-emerald-950 mb-3">{item.title}</h3>
              <p class="text-emerald-800/80 font-medium leading-relaxed max-w-sm">
                {item.desc}
              </p>
            </div>
          ))}
        </div>
      </div>
    </Section>

    <Section height={300} class="py-12 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto bg-gradient-to-r from-emerald-900 to-emerald-950 rounded-3xl p-8 lg:p-12 shadow-xl flex flex-col md:flex-row items-center justify-between gap-8 border border-emerald-800">
        <div class="flex items-center gap-6">
          <div class="w-16 h-16 bg-amber-400 rounded-full flex items-center justify-center shrink-0 shadow-inner" aria-hidden="true">
            <span set:html={Icons.shield}></span>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-white mb-1">Fee-Back Guarantee</h3>
            <p class="text-emerald-100/80 font-medium">Confidently, we offer a no-questions-asked 1-month money-back guarantee.</p>
          </div>
        </div>
        <div class="shrink-0 w-full md:w-auto">
          <Button href="/funnel/signup" variant="white" class="w-full">
            Start Risk-Free
          </Button>
        </div>
      </div>
    </Section>

    <Section height={500} class="py-10 md:py-20 lg:py-32 px-4 sm:px-6">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16 max-w-2xl mx-auto">
          <h2 class="text-3xl lg:text-4xl font-black text-emerald-950 mb-6 tracking-tight">More Reasons to Choose Us</h2>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          
          <div class="bg-white p-8 rounded-3xl border border-emerald-100 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center mb-6" aria-hidden="true">
              <span set:html={Icons.globe}></span>
            </div>
            <h4 class="text-xl font-bold text-emerald-950 mb-3">Global Academy</h4>
            <p class="text-emerald-800/80 text-sm font-medium leading-relaxed">We proudly serve students from the USA, UK, Canada, Australia, UAE, and across Europe.</p>
          </div>

          <div class="bg-white p-8 rounded-3xl border border-emerald-100 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center mb-6" aria-hidden="true">
              <span set:html={Icons.users}></span>
            </div>
            <h4 class="text-xl font-bold text-emerald-950 mb-3">Dedicated Tutors</h4>
            <p class="text-emerald-800/80 text-sm font-medium leading-relaxed">Choose from expert male or female teachers, completely tailored to your family's comfort.</p>
          </div>

          <div class="bg-white p-8 rounded-3xl border border-emerald-100 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center mb-6" aria-hidden="true">
              <span set:html={Icons.support}></span>
            </div>
            <h4 class="text-xl font-bold text-emerald-950 mb-3">Support Beyond Class</h4>
            <p class="text-emerald-800/80 text-sm font-medium leading-relaxed">Access learning resources, ask questions, and stay connected with our support team 24/7.</p>
          </div>

        </div>
      </div>
    </Section>

    <Section height={400} class="pb-12 md:pb-24 px-4 sm:px-6">
      <div class="max-w-4xl mx-auto bg-gradient-to-br from-emerald-50 to-emerald-100/50 rounded-3xl p-10 lg:p-16 text-center shadow-sm border border-emerald-200/50">
        <h2 class="text-3xl lg:text-4xl font-black text-emerald-950 mb-4 tracking-tight">Start Your Journey Today</h2>
        <p class="text-emerald-900/80 mb-10 text-lg max-w-xl mx-auto font-medium">
          Connect with expert Quran teachers. Book a free consultation or trial class and we’ll walk you through everything step-by-step.
        </p>
        <div class="flex justify-center">
          <Button href="/funnel/signup" variant="primary" class="text-lg px-10 group">
            Book Your Free Class
            <span set:html={Icons.arrowRight}></span>
          </Button>
        </div>
      </div>
    </Section>

  </main>

  <Footer />
</Base>