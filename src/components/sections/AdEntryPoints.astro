---
// src/components/sections/AdEntryPoints.astro

const personas = [
  {
    id: "kids",
    title: "Quran for Kids",
    desc: "Fun, engaging, and structured 1-on-1 lessons designed to build a lifelong love for the Quran in a child-friendly environment.",
    link: "/ads/kids",
    badge: "Most Popular",
    badgeStyles: "bg-amber-50 text-amber-700 border-amber-200", 
    icon: "🧒",
  },
  {
    id: "adults",
    title: "Quran for Adults",
    desc: "Flexible scheduling for busy professionals. Master Tajweed, start Hifz, or dive deep into Translation at your own pace.",
    link: "/ads/adults",
    badge: "Flexible Times",
    badgeStyles: "bg-emerald-50 text-emerald-700 border-emerald-200", 
    icon: "👨‍💻",
  },
  {
    id: "ladies",
    title: "Quran for Ladies",
    desc: "Learn in a 100% secure, comfortable, and private environment exclusively with our highly qualified female Arab tutors.",
    link: "/ads/ladies",
    badge: "100% Private",
    badgeStyles: "bg-purple-50 text-purple-700 border-purple-200", 
    icon: "🧕",
  }
];
---

<section id="learning-paths" class="py-16 md:py-24 bg-[#fefdf9] relative overflow-hidden border-b border-emerald-900/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black font-serif text-emerald-950 mb-5 tracking-tight text-balance">
        Tailored Learning for <span class="text-emerald-700">Everyone</span>
      </h2>
      <p class="text-base sm:text-lg text-emerald-900/70 text-balance max-w-2xl mx-auto">
        Choose your specialized learning path. We match you with the perfect tutor based on your age, goals, and schedule.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 sm:gap-8">
      {personas.map(persona => (
        /* EDGE UI FIX: Replaced jumpy translation with smooth premium scaling and unified shadows */
        <a 
          href={persona.link} 
          class="group block bg-white rounded-3xl p-6 sm:p-8 border border-emerald-100 transition-all duration-500 hover:scale-[1.02] hover:border-emerald-200 hover:shadow-2xl hover:shadow-emerald-900/10"
        >
          <div class="flex justify-between items-start mb-8">
            <div class={`inline-flex items-center px-3 py-1 rounded-full text-[11px] font-bold tracking-wide border ${persona.badgeStyles}`}>
              {persona.badge}
            </div>
            <div class="text-4xl group-hover:scale-110 transition-transform duration-500 origin-top-right drop-shadow-sm">
              {persona.icon}
            </div>
          </div>

          <h3 class="text-2xl font-black font-serif text-emerald-950 mb-3 group-hover:text-emerald-700 transition-colors">
            {persona.title}
          </h3>
          <p class="text-emerald-900/70 text-sm leading-relaxed mb-8 min-h-[80px]">
            {persona.desc}
          </p>

          <div class="inline-flex items-center text-sm font-bold text-emerald-700 bg-emerald-50 px-4 py-2 rounded-full group-hover:bg-emerald-100 group-hover:text-emerald-800 transition-colors">
            Explore Program 
            <svg class="w-4 h-4 ml-1.5 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>