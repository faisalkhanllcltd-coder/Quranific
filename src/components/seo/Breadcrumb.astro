---
// src/components/seo/Breadcrumb.astro
import { SITE } from '../../constants/site';

interface Props {
  items?: { name: string; url: string }[];
}

const { items } = Astro.props;

// A-0 FIX: Explicitly type schemaItemList so TypeScript does not infer
// "item" as a string literal from SITE.url. Using `string` as the item type
// resolves ts(2322): 'string' is not assignable to '"https://quranific.com"'.
interface BreadcrumbItem {
  '@type': 'ListItem';
  position: number;
  name: string;
  item: string;
}

let schemaItemList: BreadcrumbItem[];

if (items && items.length > 0) {
  // Explicit items provided (e.g., from [slug].astro)
  schemaItemList = items.map((item, index) => ({
    '@type': 'ListItem' as const,
    position: index + 1,
    name: item.name,
    item: item.url.startsWith('http') ? item.url : `${SITE.url}${item.url}`,
  }));
} else {
  // Auto-generate from current URL path
  const { pathname } = Astro.url;
  const segments = pathname.split('/').filter(Boolean);

  schemaItemList = [
    {
      '@type': 'ListItem' as const,
      position: 1,
      name: 'Home',
      item: SITE.url as string,
    },
  ];

  segments.forEach((segment, index) => {
    const href = `${SITE.url}/${segments.slice(0, index + 1).join('/')}`;
    const label = segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' ');
    schemaItemList.push({
      '@type': 'ListItem' as const,
      position: index + 2,
      name: label,
      item: href,
    });
  });
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: schemaItemList,
};

// For visual rendering: derive segment list from items prop or from URL
const segments = items
  ? items.map((it, i) => ({
      href: it.url,
      label: it.name,
      isLast: i === items.length - 1,
    }))
  : (() => {
      const segs = Astro.url.pathname.split('/').filter(Boolean);
      return segs.map((segment, index) => ({
        href: `/${segs.slice(0, index + 1).join('/')}`,
        label: segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' '),
        isLast: index === segs.length - 1,
      }));
    })();
---

<nav aria-label="Breadcrumb" class="flex mb-8">
  <!--
    A-0 FIX: Added is:inline to suppress Astro warning 4000 for this
    application/ld+json script tag (which intentionally uses set:html).
  -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

  <ol class="flex items-center space-x-2 text-sm font-medium text-emerald-800/60">
    <li>
      <a href="/" class="hover:text-emerald-950 transition-colors">Home</a>
    </li>

    {segments.map(({ href, label, isLast }) => (
      <li class="flex items-center space-x-2">
        <svg class="w-4 h-4 text-emerald-200" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"/>
        </svg>
        {isLast ? (
          <span class="text-emerald-950 font-bold" aria-current="page">{label}</span>
        ) : (
          <a href={href} class="hover:text-emerald-950 transition-colors">{label}</a>
        )}
      </li>
    ))}
  </ol>
</nav>