---
// src/components/sections/HomeHero.astro
// Pure HTML/CSS. Zero JavaScript overhead.
import { Image } from 'astro:assets';
---
<section class="relative min-h-[90vh] flex flex-col justify-center bg-[#fefdf9] overflow-hidden selection:bg-emerald-200 selection:text-emerald-950 pt-32 pb-16 md:pt-40 md:pb-24 lg:pt-48 lg:pb-32">
  
  <div class="absolute inset-0 bg-[radial-gradient(#d1fae5_1px,transparent_1px)] [background-size:24px_24px] opacity-40"></div>
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-gradient-to-r from-emerald-200/40 to-amber-200/40 blur-[100px] rounded-full pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full animate-in fade-in slide-in-from-bottom-6 duration-1000">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      
      <div class="lg:col-span-7">
        
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-emerald-100 shadow-sm mb-8 transition-transform hover:scale-105 duration-300">
          <svg class="w-4 h-4 text-amber-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <span class="text-sm font-bold text-emerald-950">Trusted by 50,000+ students worldwide</span>
        </div>
        
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black tracking-tight mb-6 leading-tight text-emerald-950">
          Learn the Quran with <br />
          <span class="bg-gradient-to-r from-emerald-700 via-emerald-600 to-amber-500 bg-clip-text text-transparent">Expert Teachers</span>
        </h1>
        
        <p class="text-lg md:text-xl text-emerald-900/80 mb-10 leading-relaxed max-w-2xl font-medium text-balance">
          Join our global community of learners and deepen your understanding of Islam through personalized, 1-on-1 online classes.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="/funnel/signup" class="inline-flex justify-center items-center px-8 py-4 text-lg font-bold text-white bg-emerald-700 hover:bg-emerald-800 rounded-xl shadow-lg shadow-emerald-900/10 hover:shadow-emerald-900/20 hover:-translate-y-0.5 transition-all duration-300 active:scale-95 min-h-[44px]">
            Start Free Trial
          </a>
          <a href="#how-it-works" class="inline-flex justify-center items-center px-8 py-4 text-lg font-bold text-emerald-950 bg-white border-2 border-emerald-100 hover:border-emerald-200 hover:bg-emerald-50/50 rounded-xl transition-all duration-300 min-h-[44px]">
            How It Works
          </a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4 mt-8">
          <div class="bg-white/60 backdrop-blur-sm border border-emerald-100/60 p-4 rounded-2xl shadow-sm hover:shadow-md hover:bg-white transition-all duration-300 group">
            <div class="text-2xl md:text-3xl font-black text-emerald-950 mb-1 group-hover:text-emerald-700 transition-colors">24/7</div>
            <div class="text-[10px] md:text-xs font-bold text-emerald-800/60 uppercase tracking-widest">Flexible Timing</div>
          </div>
          <div class="bg-white/60 backdrop-blur-sm border border-emerald-100/60 p-4 rounded-2xl shadow-sm hover:shadow-md hover:bg-white transition-all duration-300 group">
            <div class="text-2xl md:text-3xl font-black text-emerald-950 mb-1 group-hover:text-emerald-700 transition-colors">1-on-1</div>
            <div class="text-[10px] md:text-xs font-bold text-emerald-800/60 uppercase tracking-widest">Private Classes</div>
          </div>
          <div class="bg-white/60 backdrop-blur-sm border border-emerald-100/60 p-4 rounded-2xl shadow-sm hover:shadow-md hover:bg-white transition-all duration-300 group">
            <div class="text-2xl md:text-3xl font-black text-emerald-950 mb-1 group-hover:text-emerald-700 transition-colors">100%</div>
            <div class="text-[10px] md:text-xs font-bold text-emerald-800/60 uppercase tracking-widest">Certified Tutors</div>
          </div>
          <div class="bg-white/60 backdrop-blur-sm border border-emerald-100/60 p-4 rounded-2xl shadow-sm hover:shadow-md hover:bg-white transition-all duration-300 group">
            <div class="text-2xl md:text-3xl font-black text-emerald-950 mb-1 group-hover:text-emerald-700 transition-colors">All</div>
            <div class="text-[10px] md:text-xs font-bold text-emerald-800/60 uppercase tracking-widest">Ages Welcome</div>
          </div>
        </div>

      </div>

      <div class="hidden lg:flex lg:col-span-5 relative h-[600px] items-center justify-center">
        
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-[#047857]/15 blur-[120px] rounded-full pointer-events-none"></div>
        <div class="absolute top-[30%] right-[10%] w-3/4 h-3/4 bg-[#fbbf24]/10 blur-[100px] rounded-full pointer-events-none"></div>

        <div class="relative z-10 w-full aspect-square">
          <Image 
            src="/images/quranific-hero.webp" 
            alt="Quranific Live Interactive Platform" 
            width={800}
            height={800}
            loading="eager"
            fetchpriority="high"
            decoding="sync"
            class="w-full h-auto object-contain animate-hero-float"
          />
        </div>

        <div class="absolute top-12 -right-6 bg-white/80 backdrop-blur-md border border-white/60 p-5 rounded-3xl shadow-2xl shadow-emerald-900/10 w-72 z-20 animate-card-1 hover:scale-105 transition-transform duration-300">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-emerald-50 rounded-full flex items-center justify-center shadow-inner border border-emerald-100">
              <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div>
              <div class="font-bold text-emerald-950">Active Class</div>
              <div class="text-xs text-emerald-700 font-bold">Tajweed Fundamentals</div>
            </div>
          </div>
          <div class="w-full bg-slate-100 rounded-full h-2 overflow-hidden">
            <div class="bg-gradient-to-r from-emerald-400 to-emerald-600 h-full rounded-full w-3/4 animate-pulse"></div>
          </div>
        </div>

        <div class="absolute bottom-16 -left-10 bg-white/80 backdrop-blur-md border border-white/60 p-6 rounded-3xl shadow-2xl shadow-emerald-900/10 w-64 z-20 animate-card-2 hover:scale-105 transition-transform duration-300">
          <div class="text-4xl font-black text-amber-500 mb-2 tracking-tight">4.9<span class="text-2xl text-amber-500/50">/5</span></div>
          <div class="flex gap-1 mb-3">
            {[1, 2, 3, 4, 5].map(() => (
              <svg class="w-5 h-5 text-amber-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <div class="text-sm text-emerald-950 font-bold">Based on 10,000+ reviews</div>
        </div>

      </div>
      
    </div>
  </div>
</section>

<style>
  @keyframes hero-float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-16px); }
  }
  
  @keyframes card-float-1 {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  @keyframes card-float-2 {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(12px); }
  }
  
  .animate-hero-float {
    animation: hero-float 7s ease-in-out infinite;
    will-change: transform;
  }
  
  .animate-card-1 {
    animation: card-float-1 6s ease-in-out 1s infinite;
    will-change: transform;
  }

  .animate-card-2 {
    animation: card-float-2 8.5s ease-in-out 2.5s infinite;
    will-change: transform;
  }

  /* Accessibility: Disable floating animations if user prefers reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .animate-hero-float, .animate-card-1, .animate-card-2 {
      animation: none !important;
      transform: translateY(0) !important;
    }
  }
</style>