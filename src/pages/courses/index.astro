---
// src/pages/courses/index.astro
import Base from '../../layouts/Base.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Quranific Courses",
  "description": "Explore our comprehensive online Quran courses for children and adults. From Foundation to Tajweed Mastery and Hifz.",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Quran Foundation", "url": "https://quranific.com/courses#foundation" },
    { "@type": "ListItem", "position": 2, "name": "Tajweed Mastery", "url": "https://quranific.com/courses#tajweed" },
    { "@type": "ListItem", "position": 3, "name": "Hifz Programme", "url": "https://quranific.com/courses#hifz" },
    { "@type": "ListItem", "position": 4, "name": "Adult Tajweed Fix", "url": "https://quranific.com/courses#adult-tajweed" },
    { "@type": "ListItem", "position": 5, "name": "Adult Hifz Journey", "url": "https://quranific.com/courses#adult-hifz" },
    { "@type": "ListItem", "position": 6, "name": "Learning Differences Programme", "url": "https://quranific.com/courses#special-needs" }
  ]
};

// Reusable SVGs
const Check = `<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`;
const XIcon = `<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>`;
---

<Base 
  title="Courses — Quranific | Find the Perfect Quran Programme for Your Child" 
  description="Not every child starts in the same place. Find the perfect 1-on-1 online Quran course for your child or yourself. Foundation, Tajweed, Hifz, and Special Needs."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <Header />

  <main class="bg-[#fefdf9] selection:bg-[#d1fae5] selection:text-[#064e3b] font-sans">
    
    <section class="pt-16 md:pt-32 pb-10 md:pb-20 lg:pt-48 lg:pb-32 px-4 sm:px-6 bg-[#022c22] relative overflow-hidden content-visibility-auto">
      <div class="absolute top-[-10%] right-[-10%] w-[600px] h-[600px] bg-[#f59e0b]/10 rounded-full blur-[100px] pointer-events-none"></div>
      <div class="absolute bottom-[-10%] left-[-10%] w-[500px] h-[500px] bg-white/5 rounded-full blur-[100px] pointer-events-none"></div>

      <div class="max-w-7xl mx-auto grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center relative z-10">
        
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/10 border border-white/20 text-white/90 text-xs font-bold uppercase tracking-widest rounded-full mb-8 backdrop-blur-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-[#f59e0b] animate-pulse"></span>
            6 programmes · Ages 4 to adult
          </div>
          
          <h1 class="text-5xl lg:text-[4rem] font-bold text-white leading-[1.05] tracking-tight mb-6">
            Find the programme<br/>
            that fits <em class="font-serif italic text-[#fbbf24] font-medium">your child exactly.</em>
          </h1>
          
          <p class="text-lg text-emerald-100/70 font-medium leading-relaxed mb-10 max-w-xl">
            Not every child starts in the same place. Not every family has the same goal. Every Quranific programme is built around one learner — yours — with a dedicated teacher and a path that moves at their pace.
          </p>

          <div class="flex flex-col sm:flex-row items-center gap-4 mb-10">
            <a href="#courses-grid" class="w-full sm:w-auto inline-flex justify-center items-center px-8 py-4 bg-[#f59e0b] text-white font-bold rounded-xl hover:bg-[#d97706] transition-[color,background-color,border-color,box-shadow,opacity,transform] shadow-lg shadow-amber-500/20">Browse All Courses ↓</a>
            <a href="/funnel/signup" class="w-full sm:w-auto inline-flex justify-center items-center px-8 py-4 bg-transparent border-2 border-white/30 text-white hover:bg-white/10 font-bold rounded-xl transition-[color,background-color,border-color,box-shadow,opacity,transform]">Book Free Trial Class</a>
          </div>

          <div class="flex items-center gap-8 pt-6 border-t border-white/10">
            <div>
              <div class="font-serif text-3xl font-bold text-white mb-0.5">3,200<span class="text-xl text-[#fbbf24]">+</span></div>
              <div class="text-[11px] font-bold text-emerald-100/50 uppercase tracking-widest">Families enrolled</div>
            </div>
            <div>
              <div class="font-serif text-3xl font-bold text-white mb-0.5">48</div>
              <div class="text-[11px] font-bold text-emerald-100/50 uppercase tracking-widest">Verified teachers</div>
            </div>
            <div>
              <div class="font-serif text-3xl font-bold text-white mb-0.5">4.9<span class="text-xl text-[#fbbf24]">★</span></div>
              <div class="text-[11px] font-bold text-emerald-100/50 uppercase tracking-widest">Average rating</div>
            </div>
          </div>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-3xl p-8 backdrop-blur-md shadow-2xl relative z-20">
          <div class="text-[11px] font-bold uppercase tracking-widest text-emerald-100/50 mb-6">Not sure which course? Find it in 30 seconds.</div>
          
          <div class="space-y-6 mb-6">
            <div>
              <div class="text-sm font-bold text-white mb-3">Who is learning?</div>
              <div class="flex flex-wrap gap-2" id="who-btns">
                <button class="fb px-4 py-2 bg-white/10 border border-white/20 rounded-full text-sm font-bold text-white/80 hover:bg-white/20 transition-[color,background-color,border-color,box-shadow,opacity,transform]">Child (4–8)</button>
                <button class="fb px-4 py-2 bg-white/10 border border-white/20 rounded-full text-sm font-bold text-white/80 hover:bg-white/20 transition-[color,background-color,border-color,box-shadow,opacity,transform]">Child (9–14)</button>
                <button class="fb px-4 py-2 bg-white/10 border border-white/20 rounded-full text-sm font-bold text-white/80 hover:bg-white/20 transition-[color,background-color,border-color,box-shadow,opacity,transform]">Adult</button>
                <button class="fb px-4 py-2 bg-white/10 border border-white/20 rounded-full text-sm font-bold text-white/80 hover:bg-white/20 transition-[color,background-color,border-color,box-shadow,opacity,transform]">Special needs</button>
              </div>
            </div>
            
            <div>
              <div class="text-sm font-bold text-white mb-3">What is their current level?</div>
              <div class="flex flex-wrap gap-2" id="level-btns">
                <button class="fb px-4 py-2 bg-white/10 border border-white/20 rounded-full text-sm font-bold text-white/80 hover:bg-white/20 transition-[color,background-color,border-color,box-shadow,opacity,transform]">Complete beginner</button>
                <button class="fb px-4 py-2 bg-white/10 border border-white/20 rounded-full text-sm font-bold text-white/80 hover:bg-white/20 transition-[color,background-color,border-color,box-shadow,opacity,transform]">Can read Arabic</button>
                <button class="fb px-4 py-2 bg-white/10 border border-white/20 rounded-full text-sm font-bold text-white/80 hover:bg-white/20 transition-[color,background-color,border-color,box-shadow,opacity,transform]">Ready for Hifz</button>
              </div>
            </div>
          </div>

          <div id="finder-result" class="hidden bg-white/10 border border-white/20 rounded-2xl p-5 animate-in fade-in slide-in-from-bottom-4 duration-500">
            <div class="text-[10px] font-bold uppercase tracking-widest text-[#fbbf24] mb-2">Recommended for you</div>
            <h3 class="text-lg font-bold text-white mb-1" id="fr-course">Foundation Programme</h3>
            <p class="text-sm text-emerald-100/70 font-medium mb-4" id="fr-desc">Perfect for ages 4–8 starting from zero. Noorani Qaida, short Surahs, and gentle Tajweed foundations.</p>
            <button class="w-full bg-[#f59e0b] text-white font-bold py-3 rounded-xl hover:bg-[#d97706] transition-colors" onclick="document.getElementById('courses-grid').scrollIntoView({behavior:'smooth'})">See this course →</button>
          </div>
        </div>

      </div>
      
      <div class="absolute bottom-0 left-0 right-0 w-full overflow-hidden leading-none">
        <svg class="relative block w-full h-[60px]" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
          <path d="M0,0V73.8C28.7,35.4,196.5-35.4,396.5,22.6C596.5,80.6,712.5,138.6,900.5,100.6C1088.5,62.6,1200,0,1200,0Z" fill="#fefdf9"></path>
        </svg>
      </div>
    </section>

    <div class="bg-[#fefdf9] border-b border-emerald-100 relative z-20 content-visibility-auto">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-5 divide-y md:divide-y-0 md:divide-x divide-emerald-100">
          <div class="p-6 text-center hover:bg-[#ecfdf5] transition-colors duration-300">
            <div class="font-serif text-3xl font-bold text-[#047857] mb-1">6</div>
            <div class="text-[12px] font-semibold text-[#065f46]/70 uppercase tracking-wide">Distinct programmes</div>
          </div>
          <div class="p-6 text-center hover:bg-[#ecfdf5] transition-colors duration-300">
            <div class="font-serif text-3xl font-bold text-[#047857] mb-1">1-on-1</div>
            <div class="text-[12px] font-semibold text-[#065f46]/70 uppercase tracking-wide">Every session, always</div>
          </div>
          <div class="p-6 text-center hover:bg-[#ecfdf5] transition-colors duration-300">
            <div class="font-serif text-3xl font-bold text-[#047857] mb-1">30 min</div>
            <div class="text-[12px] font-semibold text-[#065f46]/70 uppercase tracking-wide">Session length</div>
          </div>
          <div class="p-6 text-center hover:bg-[#ecfdf5] transition-colors duration-300">
            <div class="font-serif text-3xl font-bold text-[#047857] mb-1">100%</div>
            <div class="text-[12px] font-semibold text-[#065f46]/70 uppercase tracking-wide">Ijazah-certified teachers</div>
          </div>
          <div class="p-6 text-center hover:bg-[#ecfdf5] transition-colors duration-300">
            <div class="font-serif text-3xl font-bold text-[#047857] mb-1">Free</div>
            <div class="text-[12px] font-semibold text-[#065f46]/70 uppercase tracking-wide">First trial class</div>
          </div>
        </div>
      </div>
    </div>

    <section class="py-10 md:py-20 lg:py-28 bg-[#fefdf9] content-visibility-auto" id="courses-grid">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-12">
          <span class="text-xs font-black tracking-widest uppercase text-[#047857] block mb-3">All Programmes</span>
          <h2 class="text-4xl lg:text-5xl font-bold text-[#022c22] mb-4 tracking-tight">Six paths. <em class="font-serif italic text-[#047857] font-medium">One destination.</em></h2>
          <p class="text-lg text-[#064e3b]/80 font-medium max-w-2xl mx-auto">Every programme is 1-on-1, taught by a verified teacher, with weekly progress reports and a guaranteed make-up for every missed session.</p>
        </div>

        <div class="flex overflow-x-auto gap-2 p-1.5 bg-white border border-emerald-100 rounded-full max-w-fit mx-auto mb-12 no-scrollbar shadow-sm">
          <button class="px-5 py-2.5 rounded-full text-sm font-bold transition-[color,background-color,border-color,box-shadow,opacity,transform] course-tab bg-[#047857] text-white shadow-md" data-filter="all">All Courses</button>
          <button class="px-5 py-2.5 rounded-full text-sm font-bold text-[#064e3b]/60 hover:text-[#022c22] transition-[color,background-color,border-color,box-shadow,opacity,transform] course-tab whitespace-nowrap" data-filter="children">For Children</button>
          <button class="px-5 py-2.5 rounded-full text-sm font-bold text-[#064e3b]/60 hover:text-[#022c22] transition-[color,background-color,border-color,box-shadow,opacity,transform] course-tab whitespace-nowrap" data-filter="adult">For Adults</button>
          <button class="px-5 py-2.5 rounded-full text-sm font-bold text-[#064e3b]/60 hover:text-[#022c22] transition-[color,background-color,border-color,box-shadow,opacity,transform] course-tab whitespace-nowrap" data-filter="hifz">Hifz (Memorisation)</button>
          <button class="px-5 py-2.5 rounded-full text-sm font-bold text-[#064e3b]/60 hover:text-[#022c22] transition-[color,background-color,border-color,box-shadow,opacity,transform] course-tab whitespace-nowrap" data-filter="special">Special Needs</button>
        </div>

        <div class="grid lg:grid-cols-3 gap-6 lg:gap-8" id="course-cards-container">

          <div class="course-card bg-white border border-emerald-100 rounded-3xl overflow-hidden flex flex-col hover:shadow-xl hover:-translate-y-1 hover:border-[#a7f3d0] transition-[color,background-color,border-color,box-shadow,opacity,transform] duration-300" data-cat="children">
            <div class="bg-gradient-to-br from-[#047857] to-[#10b981] p-8 text-white relative">
              <div class="flex justify-between items-start mb-6 relative z-10">
                <span class="bg-white/20 border border-white/30 text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full">Foundation</span>
                <span class="bg-[#f59e0b] text-white text-[10px] font-bold px-3 py-1 rounded-full">Most enrolled</span>
              </div>
              <h3 class="font-serif text-3xl font-bold mb-1 relative z-10">Quran Foundation</h3>
              <p class="text-[13px] text-emerald-50/80 font-medium relative z-10">From zero to fluent reading — the complete first step</p>
              <div class="text-3xl text-emerald-900/10 font-bold absolute bottom-4 right-6" dir="rtl">بِسْمِ اللَّهِ</div>
            </div>
            <div class="p-8 flex-1 flex flex-col">
              <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#ecfdf5] border border-[#d1fae5] text-[#047857] text-xs font-bold rounded-full mb-6">📍 Ages 4–8 · Complete beginners</div>
              <div class="space-y-3 flex-1 mb-8">
                <div class="flex items-start gap-3 text-[13px] font-medium text-[#065f46]/80"><div class="w-5 h-5 rounded-full bg-[#ecfdf5] flex items-center justify-center text-[#047857] shrink-0 mt-0.5"><Fragment set:html={Check} /></div><strong class="text-[#022c22]">Arabic alphabet</strong> — all 29 letters</div>
                <div class="flex items-start gap-3 text-[13px] font-medium text-[#065f46]/80"><div class="w-5 h-5 rounded-full bg-[#ecfdf5] flex items-center justify-center text-[#047857] shrink-0 mt-0.5"><Fragment set:html={Check} /></div><strong class="text-[#022c22]">Noorani Qaida</strong> — reading system</div>
                <div class="flex items-start gap-3 text-[13px] font-medium text-[#065f46]/80"><div class="w-5 h-5 rounded-full bg-[#ecfdf5] flex items-center justify-center text-[#047857] shrink-0 mt-0.5"><Fragment set:html={Check} /></div><strong class="text-[#022c22]">Short Surahs</strong> — memorisation</div>
                <div class="flex items-start gap-3 text-[13px] font-medium text-[#065f46]/80"><div class="w-5 h-5 rounded-full bg-[#ecfdf5] flex items-center justify-center text-[#047857] shrink-0 mt-0.5"><Fragment set:html={Check} /></div><strong class="text-[#022c22]">Basic Tajweed</strong> — pronunciation</div>
              </div>
              <div class="flex items-center justify-between py-4 border-y border-emerald-50 mb-6">
                <div class="flex items-center gap-1.5 text-xs text-[#064e3b]/60 font-medium"><span>⏱</span> 30m</div>
                <div class="flex items-center gap-1.5 text-xs text-[#064e3b]/60 font-medium"><span>📅</span> 2-3x/wk</div>
                <div class="flex items-center gap-1.5 text-xs text-[#064e3b]/60 font-medium"><span>📆</span> 6-12 mo</div>
              </div>
              <div class="flex items-center justify-between">
                <div><span class="text-[11px] text-[#064e3b]/50 font-bold block mb-0.5">From</span><span class="font-serif text-2xl font-bold text-[#022c22]">$39</span><span class="text-[11px] text-[#064e3b]/50">/mo</span></div>
                <a href="/funnel/signup?course=Quran+Foundation" class="px-6 py-3 bg-[#047857] hover:bg-[#064e3b] text-white text-sm font-bold rounded-full transition-colors shadow-md">Enrol now →</a>
              </div>
            </div>
          </div>

          <div class="course-card bg-white border-2 border-[#f59e0b] shadow-xl rounded-3xl overflow-hidden flex flex-col hover:-translate-y-1 transition-[color,background-color,border-color,box-shadow,opacity,transform] duration-300 relative" data-cat="children">
            <div class="absolute top-4 -right-8 bg-[#f59e0b] text-white text-[10px] font-bold py-1 px-10 rotate-45 z-20 shadow-sm tracking-wider uppercase">Popular</div>
            <div class="bg-gradient-to-br from-[#4C1D95] to-[#7C3AED] p-8 text-white relative">
              <div class="flex justify-between items-start mb-6 relative z-10">
                <span class="bg-white/20 border border-white/30 text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full">Intermediate</span>
              </div>
              <h3 class="font-serif text-3xl font-bold mb-1 relative z-10">Tajweed Mastery</h3>
              <p class="text-[13px] text-purple-100/80 font-medium relative z-10">Full rules, fluency, and the sound of a living tradition</p>
              <div class="text-3xl text-purple-900/20 font-bold absolute bottom-4 right-6" dir="rtl">وَرَتِّلِ الْقُرْآنَ</div>
            </div>
            <div class="p-8 flex-1 flex flex-col">
              <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#ecfdf5] border border-[#d1fae5] text-[#047857] text-xs font-bold rounded-full mb-6">📍 Ages 8–14 · Can read Arabic</div>
              <div class="space-y-3 flex-1 mb-8">
                <div class="flex items-start gap-3 text-[13px] font-medium text-[#065f46]/80"><div class="w-5 h-5 rounded-full bg-[#ecfdf5] flex items-center justify-center text-[#047857] shrink-0 mt-0.5"><Fragment set:html={Check} /></div><strong class="text-[#022c22]">Full Tajweed rules</strong> — Makhaarij, Sifaat</div>
                <div class="flex items-start gap-3 text-[13px] font-medium text-[#065f46]/80"><div class="w-5 h-5 rounded-full bg-[#ecfdf5] flex items-center justify-center text-[#047857] shrink-0 mt-0.5"><Fragment set:html={Check} /></div><strong class="text-[#022c22]">Juz Amma</strong> — full 30th Juz recitation</div>
                <div class="flex items-start gap-3 text-[13px] font-medium text-[#065f46]/80"><div class="w-5 h-5 rounded-full bg-[#ecfdf5] flex items-center justify-center text-[#047857] shrink-0 mt-0.5"><Fragment set:html={Check} /></div><strong class="text-[#022c22]">Fluency building</strong> — longer passages</div>
                <div class="flex items-start gap-3 text-[13px] font-medium text-[#065f46]/80"><div class="w-5 h-5 rounded-full bg-[#ecfdf5] flex items-center justify-center text-[#047857] shrink-0 mt-0.5"><Fragment set:html={Check} /></div><strong class="text-[#022c22]">Intro to Hifz</strong> — selected Surahs</div>
              </div>
              <div class="flex items-center justify-between py-4 border-y border-emerald-50 mb-6">
                <div class="flex items-center gap-1.5 text-xs text-[#064e3b]/60 font-medium"><span>⏱</span> 30m</div>
                <div class="flex items-center gap-1.5 text-xs text-[#064e3b]/60 font-medium"><span>📅</span> 2-3x/wk</div>
                <div class="flex items-center gap-1.5 text-xs text-[#064e3b]/60 font-medium"><span>📆</span> 12-24 mo</div>
              </div>
              <div class="flex items-center justify-between">
                <div><span class="text-[11px] text-[#064e3b]/50 font-bold block mb-0.5">From</span><span class="font-serif text-2xl font-bold text-[#022c22]">$39</span><span class="text-[11px] text-[#064e3b]/50">/mo</span></div>
                <a href="/funnel/signup?course=Tajweed+Mastery" class="px-6 py-3 bg-[#f59e0b] hover:bg-[#d97706] text-white text-sm font-bold rounded-full transition-colors shadow-md">Enrol now →</a>
              </div>
            </div>
          </div>

          <div class="course-card bg-white border border-emerald-100 rounded-3xl overflow-hidden flex flex-col hover:shadow-xl hover:-translate-y-1 hover:border-[#a7f3d0] transition-[color,background-color,border-color,box-shadow,opacity,transform] duration-300" data-cat="hifz children">
            <div class="bg-gradient-to-br from-[#92400E] to-[#f59e0b] p-8 text-white relative">
              <div class="flex justify-between items-start mb-6 relative z-10">
                <span class="bg-white/20 border border-white/30 text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full">Advanced</span>
              </div>
              <h3 class="font-serif text-3xl font-bold mb-1 relative z-10">Hifz Programme</h3>
              <p class="text-[13px] text-amber-50/80 font-medium relative z-10">Full Quran memorisation with structured revision cycles</p>
              <div class="text-3xl text-amber-900/20 font-bold absolute bottom-4 right-6" dir="rtl">إِنَّا نَحْنُ نَزَّلْنَا</div>
            </div>
            <div class="p-8 flex-1 flex flex-col">
              <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#ecfdf5] border border-[#d1fae5] text-[#047857] text-xs font-bold rounded-full mb-6">📍 Any age · Strong Tajweed req.</div>
              <div class="space-y-3 flex-1 mb-8">
                <div class="flex items-start gap-3 text-[13px] font-medium text-[#065f46]/80"><div class="w-5 h-5 rounded-full bg-[#ecfdf5] flex items-center justify-center text-[#047857] shrink-0 mt-0.5"><Fragment set:html={Check} /></div><strong class="text-[#022c22]">Full memorisation</strong> — systematic path</div>
                <div class="flex items-start gap-3 text-[13px] font-medium text-[#065f46]/80"><div class="w-5 h-5 rounded-full bg-[#ecfdf5] flex items-center justify-center text-[#047857] shrink-0 mt-0.5"><Fragment set:html={Check} /></div><strong class="text-[#022c22]">Waqf & Ibtida</strong> — stopping/starting rules</div>
                <div class="flex items-start gap-3 text-[13px] font-medium text-[#065f46]/80"><div class="w-5 h-5 rounded-full bg-[#ecfdf5] flex items-center justify-center text-[#047857] shrink-0 mt-0.5"><Fragment set:html={Check} /></div><strong class="text-[#022c22]">Spaced repetition</strong> — retention focus</div>
                <div class="flex items-start gap-3 text-[13px] font-medium text-[#065f46]/80"><div class="w-5 h-5 rounded-full bg-[#ecfdf5] flex items-center justify-center text-[#047857] shrink-0 mt-0.5"><Fragment set:html={Check} /></div><strong class="text-[#022c22]">Ijazah specialist</strong> — matched specifically</div>
              </div>
              <div class="flex items-center justify-between py-4 border-y border-emerald-50 mb-6">
                <div class="flex items-center gap-1.5 text-xs text-[#064e3b]/60 font-medium"><span>⏱</span> 45m</div>
                <div class="flex items-center gap-1.5 text-xs text-[#064e3b]/60 font-medium"><span>📅</span> 3-5x/wk</div>
                <div class="flex items-center gap-1.5 text-xs text-[#064e3b]/60 font-medium"><span>📆</span> Long-term</div>
