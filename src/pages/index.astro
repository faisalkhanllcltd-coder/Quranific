---
// src/pages/index.astro
import Base from '../layouts/Base.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import HomeHero from '../components/sections/HomeHero.astro';
import TrustStrip from '../components/sections/TrustStrip.astro';
import TestimonialGrid from '../components/sections/TestimonialGrid.astro';
import FAQAccordion from '../components/sections/FAQAccordion.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';

// Core UI Components
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';

import { SITE } from '../constants/site';

const PAGE_CONTENT = {
  hero: {
    badgeText: "Now enrolling · Limited spots",
    title: "The Quran class your child",
    highlightWord: "actually looks forward to.",
    subtitle: "No crowded mosque classes. No harsh methods. No guilt. Just a gentle, qualified teacher, one child, and 30 minutes that might change everything.",
    primaryCtaText: "Book Your Free Class",
    primaryCtaLink: "/funnel/signup"
  },
  howTo: [
    {
      name: "Book your free class",
      text: "Fill in a short form — your child's age, level, and your preferred time slots. No credit card. Takes 2 minutes."
    },
    {
      name: "We match the perfect teacher",
      text: "Our team hand-selects a teacher based on your child's age, personality notes, and level. Within 24 hours, you'll receive their profile and a confirmed session time."
    },
    {
      name: "Watch them fall in love",
      text: "Your child joins their private session on a secure link. You'll receive a progress report after every class. Most parents notice a difference within the first two weeks."
    }
  ],
  faq: [
    {
      question: "What if my child misses a class?",
      answer: "Every single missed class has a guaranteed make-up session — no exceptions, no expiry."
    },
    {
      question: "Is my child's session safe and private?",
      answer: "Every session is strictly 1-on-1, conducted on a private, secure video link. Sessions are never recorded without explicit parental consent."
    },
    {
      question: "What if it doesn't work for us?",
      answer: "The first class is completely free — no credit card needed. If you join and are not satisfied within your first paid month, we refund every penny."
    }
  ],
  adultCta: {
    badge: "For Adults",
    title: "Fix your Tajweed. No embarrassment. No class.",
    description: "Private 1-on-1 sessions designed for working adults who want to improve their recitation without the awkwardness of a group setting. Your teacher only knows your name.",
    btnText: "Book Adult Trial Class →"
  }
};

// Elite Edge SEO: Deep Semantic JSON-LD
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": ["WebSite", "EducationalOrganization"],
    "name": SITE.name,
    "url": SITE.url,
    "description": SITE.description,
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": `${SITE.url}/courses?q={search_term_string}`
      },
      "query-input": "required name=search_term_string"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer support",
      "url": SITE.whatsappLink
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": PAGE_CONTENT.faq.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to start learning Quran with Quranific",
    "description": "Start your personalized 1-on-1 online Quran classes in three simple steps.",
    "step": PAGE_CONTENT.howTo.map((step, index) => ({
      "@type": "HowToStep",
      "position": index + 1,
      "name": step.name,
      "text": step.text
    }))
  }
];

const CheckIcon = `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`;
const XIcon = `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>`;
---

<Base 
  title={SITE.title} 
  description={SITE.description}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <Header />

  <main id="main-content" class="bg-cream-50 selection:bg-emerald-200 selection:text-emerald-950 font-sans">
    
    <HomeHero 
      badgeText={PAGE_CONTENT.hero.badgeText}
      title={PAGE_CONTENT.hero.title}
      highlightWord={PAGE_CONTENT.hero.highlightWord}
      subtitle={PAGE_CONTENT.hero.subtitle}
      primaryCtaText={PAGE_CONTENT.hero.primaryCtaText}
      primaryCtaLink={PAGE_CONTENT.hero.primaryCtaLink}
    />

    <TrustStrip />

    <Section height={700} class="py-10 md:py-20 lg:py-32 bg-emerald-950 relative" aria-labelledby="pain-heading">
      <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
        <div class="absolute top-0 right-0 w-[600px] h-[600px] border border-white/5 rounded-full -translate-y-1/4 translate-x-1/4"></div>
        <div class="absolute bottom-0 left-0 w-[800px] h-[800px] border border-white/5 rounded-full translate-y-1/4 -translate-x-1/4"></div>
      </div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid lg:grid-cols-[1fr_1.4fr] gap-12 lg:gap-20 items-start relative">
          
          <div class="self-start lg:sticky lg:top-32">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-white/5 border border-white/10 text-emerald-300 text-[11px] font-bold uppercase tracking-widest rounded-full mb-6 backdrop-blur-sm">
              You are not alone
            </div>
            <h2 id="pain-heading" class="text-4xl lg:text-5xl lg:leading-tight font-medium text-white mb-6 tracking-tight">
              We know <em class="text-amber-500 not-italic">exactly</em> how you feel.
            </h2>
            <p class="text-lg text-emerald-100/70 font-medium leading-relaxed">
              These are the real thoughts of parents who found Quranific — before they found us.
            </p>
          </div>

          <div class="flex flex-col gap-6">
            <blockquote class="bg-white/5 border border-white/10 rounded-2xl p-6 md:p-8 relative overflow-hidden group hover:bg-white/10 transition-colors duration-300 ease-in-out">
              <div class="absolute left-0 top-0 bottom-0 w-1 bg-amber-500 scale-y-0 group-hover:scale-y-100 origin-bottom transition-transform duration-300 ease-in-out" aria-hidden="true"></div>
              <p class="text-xl md:text-2xl font-serif italic text-white/95 mb-4 leading-relaxed">"The local mosque is 40 minutes away, the class has 30 kids in it, and my son comes home more scared of Quran than connected to it."</p>
              <footer class="text-sm font-bold text-emerald-400/60 uppercase tracking-widest">— A father in Manchester, 2 children</footer>
            </blockquote>
            
            <blockquote class="bg-white/5 border border-white/10 rounded-2xl p-6 md:p-8 relative overflow-hidden group hover:bg-white/10 transition-colors duration-300 ease-in-out">
              <div class="absolute left-0 top-0 bottom-0 w-1 bg-amber-500 scale-y-0 group-hover:scale-y-100 origin-bottom transition-transform duration-300 ease-in-out" aria-hidden="true"></div>
              <p class="text-xl md:text-2xl font-serif italic text-white/95 mb-4 leading-relaxed">"We tried two other online academies. The teachers kept changing, the quality was inconsistent, and my daughter just stopped caring."</p>
              <footer class="text-sm font-bold text-emerald-400/60 uppercase tracking-widest">— A mother in Houston, daughter aged 9</footer>
            </blockquote>

            <blockquote class="bg-white/5 border border-white/10 rounded-2xl p-6 md:p-8 relative overflow-hidden group hover:bg-white/10 transition-colors duration-300 ease-in-out">
              <div class="absolute left-0 top-0 bottom-0 w-1 bg-amber-500 scale-y-0 group-hover:scale-y-100 origin-bottom transition-transform duration-300 ease-in-out" aria-hidden="true"></div>
              <p class="text-xl md:text-2xl font-serif italic text-white/95 mb-4 leading-relaxed">"I keep telling myself we'll start properly next month. My son is 12 now. I can't let another year pass."</p>
              <footer class="text-sm font-bold text-emerald-400/60 uppercase tracking-widest">— A father in Dubai, son aged 12</footer>
            </blockquote>
          </div>

        </div>
      </div>
    </Section>

    <Section height={900} class="py-10 md:py-20 lg:py-32 bg-cream-50" aria-labelledby="difference-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-16 max-w-3xl mx-auto">
          <div class="inline-flex items-center justify-center gap-2 px-4 py-1.5 bg-emerald-50 border border-emerald-100 text-emerald-700 text-[11px] font-bold uppercase tracking-widest rounded-full mb-6">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-700"></span>
            </span>
            The Quranific Difference
          </div>
          <h2 id="difference-heading" class="text-4xl lg:text-5xl font-semibold text-emerald-950 mb-6 tracking-tight">
            This isn't how it <em class="text-emerald-700 not-italic">used to be taught.</em>
          </h2>
          <p class="text-lg text-emerald-900/80 font-medium">
            We built everything from scratch around one question: what does a child actually need to fall in love with the Quran — not just recite it out of fear?
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 lg:gap-10 mb-20 max-w-5xl mx-auto">
          
          <div class="bg-white border border-red-100 rounded-3xl overflow-hidden shadow-sm">
            <div class="bg-red-50/80 px-6 py-5 border-b border-red-100 flex items-center gap-3">
              <div class="w-7 h-7 rounded-full bg-red-200 text-red-700 flex items-center justify-center shrink-0" aria-hidden="true" set:html={XIcon}></div>
              <h3 class="font-bold text-red-950 uppercase tracking-wide text-sm">Traditional Academy</h3>
            </div>
            <ul class="p-6 space-y-4" role="list">
              <li class="flex gap-4 items-start"><svg class="w-5 h-5 shrink-0 text-red-900/40 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg><p class="text-[15px] font-medium text-red-950/70">Crowded group classes — your child is one of many.</p></li>
              <li class="flex gap-4 items-start"><svg class="w-5 h-5 shrink-0 text-red-900/40 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg><p class="text-[15px] font-medium text-red-950/70">Harsh correction methods that create fear, not love.</p></li>
              <li class="flex gap-4 items-start"><svg class="w-5 h-5 shrink-0 text-red-900/40 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg><p class="text-[15px] font-medium text-red-950/70">Teacher rotations — your child never builds a bond.</p></li>
              <li class="flex gap-4 items-start"><svg class="w-5 h-5 shrink-0 text-red-900/40 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><p class="text-[15px] font-medium text-red-950/70">No progress reports — you have no idea how they're doing.</p></li>
              <li class="flex gap-4 items-start"><svg class="w-5 h-5 shrink-0 text-red-900/40 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg><p class="text-[15px] font-medium text-red-950/70">Missed class? It's gone. No make-ups.</p></li>
              <li class="flex gap-4 items-start"><svg class="w-5 h-5 shrink-0 text-red-900/40 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg><p class="text-[15px] font-medium text-red-950/70">Rigid fixed schedules — works for them, not for you.</p></li>
            </ul>
          </div>

          <div class="bg-white border border-emerald-700 rounded-3xl overflow-hidden shadow-2xl shadow-emerald-900/10 relative">
            <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-emerald-700 to-amber-500" aria-hidden="true"></div>
            <div class="bg-emerald-50 px-6 py-5 border-b border-emerald-100 flex items-center gap-3">
              <div class="w-7 h-7 rounded-full bg-emerald-700 text-white flex items-center justify-center shrink-0" aria-hidden="true" set:html={CheckIcon}></div>
              <h3 class="font-bold text-emerald-950 uppercase tracking-wide text-sm">{SITE.name}</h3>
            </div>
            <ul class="p-6 space-y-4" role="list">
              <li class="flex gap-4 items-start"><svg class="w-5 h-5 shrink-0 text-emerald-700 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg><p class="text-[15px] font-bold text-emerald-950">1-on-1 private sessions — 100% of the teacher's attention.</p></li>
              <li class="flex gap-4 items-start"><svg class="w-5 h-5 shrink-0 text-emerald-700 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg><p class="text-[15px] font-bold text-emerald-950">Positive reinforcement only — patience is our non-negotiable.</p></li>
              <li class="flex gap-4 items-start"><svg class="w-5 h-5 shrink-0 text-emerald-700 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg><p class="text-[15px] font-bold text-emerald-950">Same dedicated teacher — every session, every month.</p></li>
              <li class="flex gap-4 items-start"><svg class="w-5 h-5 shrink-0 text-emerald-700 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg><p class="text-[15px] font-bold text-emerald-950">Weekly progress report sent directly to you.</p></li>
              <li class="flex gap-4 items-start"><svg class="w-5 h-5 shrink-0 text-emerald-700 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg><p class="text-[15px] font-bold text-emerald-950">Guaranteed make-up for every missed class.</p></li>
              <li class="flex gap-4 items-start"><svg class="w-5 h-5 shrink-0 text-emerald-700 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><p class="text-[15px] font-bold text-emerald-950">You pick the time — mornings, evenings, weekends.</p></li>
            </ul>

            <div class="bg-emerald-950 rounded-2xl p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
              <div>
                <div class="text-white font-bold text-[15px] mb-1">Ready to build this?</div>
                <div class="text-emerald-100/70 text-[13px] font-medium">First class is free.</div>
              </div>
              <Button href="/funnel/signup" variant="secondary" class="w-full sm:w-auto">
                Start Trial →
              </Button>
            </div>
          </div>

        </div>
      </div>
    </Section>

    <TestimonialGrid />

    <Section height={800} class="py-10 md:py-20 lg:py-32 bg-white border-b border-emerald-50" id="how-it-works" aria-labelledby="how-it-works-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-[1.1fr_1fr] gap-16 lg:gap-20 items-center">
          
          <div>
            <div class="inline-flex items-center justify-center gap-2 px-4 py-1.5 bg-emerald-50 border border-emerald-100 text-emerald-700 text-[11px] font-bold uppercase tracking-widest rounded-full mb-6">
              Three Simple Steps
            </div>
            <h2 id="how-it-works-heading" class="text-4xl lg:text-5xl font-semibold text-emerald-950 mb-6 tracking-tight leading-tight">
              Starting is <br/><em class="text-emerald-700 not-italic">simpler than you think.</em>
            </h2>
            <p class="text-lg text-emerald-900/80 font-medium mb-12 max-w-lg">
              From booking to first lesson in under 24 hours. No paperwork. No long commitments. No anxiety.
            </p>

            <ol class="space-y-10 relative" role="list">
              <div class="absolute left-[1.375rem] top-[3rem] bottom-[3rem] w-0.5 bg-gradient-to-b from-emerald-200 to-transparent hidden sm:block" aria-hidden="true"></div>
              
              {PAGE_CONTENT.howTo.map((step, idx) => (
                <li class="flex gap-6 relative z-10 group">
                  <div class="w-12 h-12 rounded-full border-2 border-emerald-200 bg-white text-emerald-700 font-bold flex items-center justify-center shrink-0 transition-colors duration-300 ease-in-out group-hover:bg-emerald-700 group-hover:text-white group-hover:border-emerald-700" aria-hidden="true">{idx + 1}</div>
                  <div>
                    <h3 class="font-bold text-xl text-emerald-950 mb-2">{step.name}</h3>
                    <p class="text-[15px] font-medium text-emerald-800/80 leading-relaxed mb-3">{step.text}</p>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-emerald-50 text-emerald-700 text-[11px] font-bold uppercase tracking-wider rounded-full">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      {idx === 0 ? "2 minutes" : idx === 1 ? "Within 24 hours" : "From week 1"}
                    </span>
                  </div>
                </li>
              ))}
            </ol>
          </div>

          <div class="bg-cream-50 border border-emerald-100 rounded-[2rem] p-6 sm:p-8 shadow-xl shadow-emerald-900/5" aria-label="Sample weekly schedule for Yusuf, age 9">
            <div class="text-[11px] font-bold uppercase tracking-widest text-emerald-900/60 mb-6">This week's schedule — Yusuf, age 9</div>
            <ul class="space-y-3 mb-8" role="list">
              <li class="bg-white border border-emerald-100 rounded-2xl p-4 flex items-center gap-4 transition-colors hover:border-emerald-200">
                <div class="w-12 text-center text-xs font-bold text-emerald-900/40 shrink-0" aria-hidden="true">MON</div>
                <div class="w-10 h-10 rounded-xl bg-emerald-50 text-emerald-700 flex items-center justify-center font-bold shrink-0" aria-hidden="true" set:html={CheckIcon}></div>
                <div class="flex-1 min-w-0">
                  <div class="font-bold text-emerald-950 text-sm truncate">Taj Session</div>
                  <div class="text-[13px] font-medium text-emerald-800/70 truncate">Ustadha Fatima · 4:30 PM</div>
                </div>
                <div class="hidden sm:block px-2.5 py-1 bg-emerald-50 text-emerald-700 text-[10px] font-bold rounded-full border border-emerald-200">Done</div>
              </li>
              
              <li class="bg-white border border-emerald-100 rounded-2xl p-4 flex items-center gap-4 transition-colors hover:border-emerald-200">
                <div class="w-12 text-center text-xs font-bold text-emerald-900/40 shrink-0" aria-hidden="true">WED</div>
                <div class="w-10 h-10 rounded-xl bg-emerald-50 text-emerald-700 flex items-center justify-center font-bold shrink-0" aria-hidden="true" set:html={CheckIcon}></div>
                <div class="flex-1 min-w-0">
                  <div class="font-bold text-emerald-950 text-sm truncate">Memorisation</div>
                  <div class="text-[13px] font-medium text-emerald-800/70 truncate">Ustadha Fatima · 4:30 PM</div>
                </div>
                <div class="hidden sm:block px-2.5 py-1 bg-emerald-50 text-emerald-700 text-[10px] font-bold rounded-full border border-emerald-200">Done</div>
              </li>

              <li class="bg-emerald-700/5 border-2 border-emerald-700 rounded-2xl p-4 flex items-center gap-4 relative shadow-sm">
                <div class="w-12 text-center text-xs font-bold text-emerald-700 shrink-0" aria-hidden="true">FRI</div>
                <div class="w-10 h-10 rounded-xl bg-emerald-700 text-white flex items-center justify-center shrink-0 relative" aria-hidden="true">
