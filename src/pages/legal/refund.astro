---
// src/pages/legal/refund-policy.astro
import Base from '../../layouts/Base.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';

const lastUpdated = "March 25, 2026";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Refund & Tuition Policy - Quranific",
  "description": "Comprehensive details on Quranific's tuition billing, full-month satisfaction guarantee, make-up class rules, and holiday schedules.",
  "dateModified": "2026-03-25"
};
---

<Base title="Refund & Tuition Policy | Quranific" description="Transparent, fair, and comprehensive billing policies. Learn about our satisfaction guarantee, make-up class rules, and subscription model.">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  
  <Header />

  <main class="bg-[#fefdf9] min-h-screen selection:bg-[#d1fae5] selection:text-[#064e3b] font-sans pb-32">
    
    <div class="pt-16 md:pt-32 pb-12 lg:pt-40 lg:pb-16 px-4 sm:px-6 border-b border-emerald-100 bg-white">
      <div class="max-w-5xl mx-auto">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-emerald-50 border border-[#d1fae5] text-[#047857] text-xs font-bold uppercase tracking-widest rounded-full mb-6">
          Billing & Enrollment
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-[#022c22] tracking-tight mb-6">
          Refund & Tuition Policy
        </h1>
        <p class="text-lg text-emerald-700/80 font-medium max-w-3xl">
          At Quranific, we aim to be completely fair and transparent in all our financial and educational dealings. By enrolling in our classes, you agree to the terms outlined below. <br/>
          <span class="text-sm mt-2 block opacity-70">Last Updated: {lastUpdated}</span>
        </p>
      </div>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-16 space-y-20">
      
      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Payment Structure
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Monthly Subscription Model</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">To ensure consistency for our students and stability for our teachers, we operate on a monthly subscription model, not a “pay-per-class” model.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Advance Billing</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">Fees are charged monthly in advance. Your billing cycle begins on the date of your first paid class and automatically renews on that same date each month.</p>
            <div class="mt-3 text-sm text-emerald-800 bg-emerald-50/50 p-4 rounded-r-lg border-l-2 border-[#047857]">
              <strong class="text-[#022c22]">Example:</strong> If your first paid class is on October 5th, your automatic monthly payment will be scheduled for the 5th of every following month.
            </div>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Slot Reservation</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">The monthly fee reserves your specific time slot with your assigned tutor globally, regardless of whether you attend every session.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Flat Fee System</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">Because we charge a monthly flat fee, the tuition remains the same regardless of the number of weeks in a specific month.</p>
            <div class="mt-3 text-sm text-emerald-800 bg-emerald-50/50 p-4 rounded-r-lg border-l-2 border-[#047857]">
              <strong class="text-[#022c22]">Example:</strong> If you pay $59/month for 3 classes a week, you will pay exactly $59 whether the calendar month has 12 class days or 14 class days.
            </div>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Free Trial Classes & Guarantee
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Free Trial</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">New students are welcome to try up to 3 days of free trial classes, with absolutely no obligation to continue and no credit card required.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">The 7-Day Refund Guarantee</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">If you decide to enroll, your first month’s fee is due. If you are not completely satisfied during the first week (7 days) of paid enrollment, we offer a full, 100% refund. No questions asked.</p>
            <div class="mt-3 text-sm text-emerald-800 bg-emerald-50/50 p-4 rounded-r-lg border-l-2 border-[#047857]">
              <strong class="text-[#022c22]">Example:</strong> You pay your first tuition fee on Monday. If you email us by the following Sunday to cancel, you receive every penny back immediately.
            </div>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Standard Refund & Cancellation Policy
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Mid-Month Cancellations</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">If you choose to cancel mid-month after the first week guarantee has passed, your enrollment will remain active until the end of that billing cycle. No refund will be issued for the unused portion of the month.</p>
            <div class="mt-3 text-sm text-emerald-800 bg-emerald-50/50 p-4 rounded-r-lg border-l-2 border-[#047857]">
              <strong class="text-[#022c22]">Example:</strong> Your billing date is the 1st of the month. You cancel on the 15th. You can still attend classes until the 30th, but you will not receive a 50% refund for the remainder of the month.
            </div>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">The "Forgot to Cancel" Rule</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">Subscriptions renew automatically. It is your strict responsibility to cancel before the renewal date. We do not issue refunds if you "forget" to cancel your subscription.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Academy Cancellation</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">If Quranific cannot provide a tutor or class for an extended period due to our own administrative issues, a pro-rated refund will be automatically calculated and issued for the missed period.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Late Payments & Suspension
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">5-Day Grace Period</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">If an automatic payment fails (e.g., due to an expired card or insufficient funds), our system will attempt to process it over a 5-day grace period.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Account Suspension</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">If payment is not secured by the end of the 5-day grace period, classes are immediately suspended and your reserved time slot may be released to another family.</p>
            <div class="mt-3 text-sm text-emerald-800 bg-emerald-50/50 p-4 rounded-r-lg border-l-2 border-[#047857]">
              <strong class="text-[#022c22]">Example:</strong> If your payment fails on the 1st, you have until the 5th to update your card. On the 6th, your classes are paused and your teacher may be reassigned.
            </div>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Holidays & Fee Coverage
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Eid Holidays</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">There are no classes on the primary days of Eid-ul-Fitr and Eid-ul-Adha. These are legally recognized paid holidays for our teachers. No refunds or make-up classes are provided for sessions that fall on Eid holidays.</p>
            <div class="mt-3 text-sm text-emerald-800 bg-emerald-50/50 p-4 rounded-r-lg border-l-2 border-[#047857]">
              <strong class="text-[#022c22]">Example:</strong> If you usually have class on a Wednesday, and Eid falls on that Wednesday, the academy is closed. This class is not rescheduled or refunded.
            </div>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Public Holidays</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">Classes continue as usual on all other national and public holidays (e.g., Christmas, Independence Day) unless explicitly notified.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Make-up Class Eligibility
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">The 5-Hour Notice Rule</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">If you cancel a session 5 hours or less before the session start time, you will <strong>not</strong> be eligible for a make-up class. You must notify us earlier than 5 hours to qualify.</p>
            <div class="mt-3 text-sm text-emerald-800 bg-emerald-50/50 p-4 rounded-r-lg border-l-2 border-[#047857]">
              <strong class="text-[#022c22]">Example:</strong> If your class is at 5:00 PM, you must notify the administration before 12:00 PM (Noon) to be eligible for a make-up session.
            </div>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">No-Show Rule</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">If you miss a class without prior notice, the teacher will wait 15 minutes. The class is considered “taken” and no make-up or refund will be provided.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Make-up Class Limit</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">Students are strictly limited to 5 make-up classes per month to ensure schedule stability.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Teacher Absences</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">If a teacher cancels a session for any reason (illness, emergency), you are always eligible for a make-up class, regardless of your monthly limit.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Make-up Class Validity & Rollovers
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Timeframe & Rollover Policy</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">We encourage students to take their make-up classes within the same month. If that is not feasible, the class will roll over to the next month, but it <strong>must be completed by the end of that following month</strong>. If not used by then, the make-up class permanently expires.</p>
            <div class="mt-3 text-sm text-emerald-800 bg-emerald-50/50 p-4 rounded-r-lg border-l-2 border-[#047857]">
              <strong class="text-[#022c22]">Example:</strong> If you miss a class in September (and gave 5 hours' notice), you have until October 31st to complete the make-up class. After October 31st, it is gone.
            </div>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Rescheduling & Substitute Teachers
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Substitute Assignment</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">Quranific reserves the right to assign a highly vetted substitute teacher if the original teacher is temporarily unavailable.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Refusal Policy</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">If a student actively refuses a suitable substitute teacher provided by the academy, the lesson will be forfeited, and no refund or additional reschedule will be granted.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Technical Issues
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Academy Issues</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">If a class is cancelled due to technical issues on our end (e.g., teacher’s internet failure or server disruption), a free make-up class will be arranged automatically.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Student Issues</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">If you are unable to connect due to your own internet outage or power issues, this counts as a student absence and is subject to the standard 5-Hour Rule and make-up limits.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Pausing or Freezing Enrollment
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Freeze Request</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">Students may pause their paid enrollment for 2 to 4 weeks per calendar year (e.g., for travel or exams) by giving 7 days written notice. Billing is suspended during this period.</p>
            <div class="mt-3 text-sm text-emerald-800 bg-emerald-50/50 p-4 rounded-r-lg border-l-2 border-[#047857]">
              <strong class="text-[#022c22]">Important Note:</strong> While your billing is paused, we cannot guarantee your original teacher or specific time slot will be available upon your return.
            </div>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Chargebacks & Payment Disputes
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Fraudulent Chargebacks</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">Please contact our support team to resolve billing errors before approaching your bank. Initiating a credit card chargeback for a legitimate, non-refundable charge is a breach of contract. Quranific will immediately suspend the account and submit this agreement and attendance logs to contest the dispute.</p>
          </li>
        </ul>
      </section>

      <section class="mt-16 pt-16 border-t border-emerald-100">
        <h2 class="text-3xl font-black text-[#022c22] mb-6 tracking-tight">How to Request a Refund, Pause, or Make-up Class</h2>
        <p class="text-lg text-[#064e3b]/80 font-medium mb-6">To reschedule a class or initiate a billing request, please follow these steps:</p>
        <ul class="list-disc pl-6 space-y-2 text-[#064e3b]/80 font-medium mb-8">
          <li>Contact our support team via WhatsApp or Email.</li>
          <li>Include your <strong>Student Name</strong>, <strong>Teacher Name</strong>, and the <strong>Date/Time</strong> of the issue.</li>
        </ul>

        <div class="bg-emerald-50 border border-emerald-100 p-8 rounded-2xl">
          <div class="flex flex-col gap-4">
            <div class="flex items-center gap-4">
              <span class="w-10 h-10 rounded-full bg-[#047857] text-white flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </span>
              <a href="mailto:privacy@quranific.com" class="font-bold text-xl text-[#022c22] hover:text-[#047857] transition-colors">privacy@quranific.com</a>
            </div>
            <div class="flex items-center gap-4">
              <span class="w-10 h-10 rounded-full bg-[#047857] text-white flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"></path></svg>
              </span>
              <a href="https://wa.me/923112112122" target="_blank" rel="noopener" class="font-bold text-xl text-[#022c22] hover:text-[#047857] transition-colors">+92 311 2112122</a>
            </div>
          </div>
        </div>
      </section>

    </div>
  </main>

  <Footer />
</Base>