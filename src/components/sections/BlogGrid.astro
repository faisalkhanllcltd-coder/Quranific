---
// src/components/sections/BlogGrid.astro
// SEO Article Grid. Blog articles are coming soon — CTA deprecated for launch.
---

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
  {[1, 2, 3].map(() => (
    <article class="bg-white border border-emerald-100 rounded-3xl overflow-hidden hover:shadow-2xl hover:shadow-emerald-900/10 hover:border-emerald-200 hover:-translate-y-1 transition-all duration-500 group flex flex-col">

      <div class="w-full h-48 relative overflow-hidden bg-gradient-to-br from-emerald-50 to-emerald-100/50">
        <div class="absolute inset-0 opacity-20 bg-[radial-gradient(#047857_1px,transparent_1px)] [background-size:16px_16px]"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent"></div>
      </div>

      <div class="p-6 lg:p-8 flex flex-col flex-1">
        <div class="flex items-center gap-3 mb-4">
          <span class="px-2.5 py-1 bg-amber-50 text-amber-700 text-[10px] font-black tracking-widest uppercase rounded-full">Guide</span>
          <span class="text-xs font-bold text-emerald-950/40">Mar 15, 2026</span>
        </div>
        <h3 class="text-xl font-bold text-emerald-950 mb-3 leading-snug group-hover:text-emerald-700 transition-colors text-balance">
          How to help your child memorize the Quran effectively
        </h3>
        <p class="text-sm text-emerald-900/70 font-medium leading-relaxed mb-6 flex-1 line-clamp-3">
          Discover proven pedagogical techniques to make Hifz an enjoyable and rewarding journey for younger students without causing burnout.
        </p>
        <!-- Blog articles not yet published. Non-clickable pill signals intent without a dead link. -->
        <span
          aria-label="Article coming soon"
          class="inline-flex items-center gap-1.5 text-sm font-bold text-emerald-400/70 mt-auto cursor-default select-none"
        >
          Coming Soon
        </span>
      </div>
    </article>
  ))}
</div>