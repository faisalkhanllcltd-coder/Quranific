---
// src/pages/tuition-fee.astro
import Base from '../layouts/Base.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';

// Elite Edge SEO: Attached AggregateOffer to a specific Service entity
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Tuition Fees - Quranific",
  "description": "Simple, honest pricing for private 1-on-1 Quran classes. No hidden fees. Full-month guarantee.",
  "mainEntity": {
    "@type": "Service",
    "name": "1-on-1 Online Quran Classes",
    "provider": {
      "@type": "Organization",
      "name": "Quranific"
    },
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": "USD",
      "lowPrice": "33.00",
      "highPrice": "89.00",
      "offerCount": "3"
    }
  }
};

// Reusable SVGs mapped for zero DOM bloat
const Icons = {
  check: `<svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`,
  xIcon: `<svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>`,
  shield: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
  chevronDown: `<svg fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" viewBox="0 0 24 24" width="20" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>`,
  sparkle: `<svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>`
};
---

<Base 
  title="Tuition Fees — Quranific | Simple, Honest Pricing" 
  description="Honest pricing. Nothing hidden. Everything included. Calculate your monthly fee for private 1-on-1 Quran classes with certified scholars."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" is:inline />

  <Header />

  <main class="bg-cream-50 selection:bg-emerald-200 selection:text-emerald-950 font-sans">
    
    <section class="pt-16 md:pt-32 pb-10 md:pb-20 lg:pt-40 lg:pb-32 px-4 sm:px-6 relative overflow-hidden border-b border-emerald-100">
      <div class="absolute top-[-10%] right-[-10%] w-[600px] h-[600px] bg-amber-500/15 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>
      <div class="absolute bottom-[-10%] left-[-10%] w-[500px] h-[500px] bg-emerald-700/10 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>

      <div class="max-w-7xl mx-auto grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center relative z-10">
        
        <div class="animate-in fade-in slide-in-from-bottom-6 duration-700">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white border border-emerald-200/60 text-emerald-800 text-xs font-bold uppercase tracking-widest rounded-full mb-8 shadow-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse" aria-hidden="true"></span>
            Transparent · No hidden fees
          </div>
          
          <h1 class="text-5xl lg:text-[4rem] font-black text-emerald-950 leading-[1.05] tracking-tight mb-6">
            Honest pricing.<br/>
            <em class="font-serif italic text-emerald-700 font-medium">Nothing hidden.</em><br/>
            Everything included.
          </h1>
          
          <p class="text-lg text-emerald-900/80 font-medium leading-relaxed mb-10 max-w-xl">
            We are not going to make you read the small print. Every price you see here is the price you pay — full stop. No setup fees, no resource fees. One simple monthly amount that covers everything.
          </p>

          <div class="flex flex-col gap-4 mb-10">
            <div class="flex items-center gap-3 text-sm font-medium text-emerald-800">
              <div class="w-5 h-5 rounded-full bg-emerald-700 text-white flex items-center justify-center shrink-0" set:html={Icons.check}></div>
              <span><strong class="text-emerald-950">First class always free</strong> — no credit card required</span>
            </div>
            <div class="flex items-center gap-3 text-sm font-medium text-emerald-800">
              <div class="w-5 h-5 rounded-full bg-emerald-700 text-white flex items-center justify-center shrink-0" set:html={Icons.check}></div>
              <span><strong class="text-emerald-950">Full refund</strong> if unsatisfied after your first paid month</span>
            </div>
            <div class="flex items-center gap-3 text-sm font-medium text-emerald-800">
              <div class="w-5 h-5 rounded-full bg-emerald-700 text-white flex items-center justify-center shrink-0" set:html={Icons.check}></div>
              <span><strong class="text-emerald-950">Cancel any time</strong> — no lock-in, no cancellation fee</span>
            </div>
            <div class="flex items-center gap-3 text-sm font-medium text-emerald-800">
              <div class="w-5 h-5 rounded-full bg-emerald-700 text-white flex items-center justify-center shrink-0" set:html={Icons.check}></div>
              <span><strong class="text-emerald-950">Sibling discounts</strong> — 10% off your second child, 20% off your third</span>
            </div>
          </div>

          <div class="flex flex-wrap items-center gap-4">
            <Button href="#plans" variant="primary">See All Plans ↓</Button>
            <Button href="https://wa.me/923112112122" target="_blank" variant="ghost">Ask about pricing</Button>
          </div>
        </div>

        <div class="bg-white rounded-3xl shadow-xl shadow-emerald-900/5 border border-emerald-100 p-6 sm:p-8 transform lg:rotate-1 hover:rotate-0 transition-transform duration-500 animate-in fade-in slide-in-from-bottom-8 duration-700 delay-150">
          <h3 class="text-xl font-bold text-emerald-950 mb-1">Calculate your monthly fee</h3>
          <p class="text-sm text-emerald-800/70 font-medium mb-8">See your exact cost in 30 seconds — no surprises.</p>

          <div class="space-y-6">
            <div>
              <div class="flex justify-between items-center mb-3">
                <span class="text-sm font-bold text-emerald-900/60 uppercase tracking-wider">Who is enrolling?</span>
                <span class="text-sm font-bold text-emerald-700" id="calc-who-val">–</span>
              </div>
              <div class="flex flex-wrap gap-2" id="calc-who-btns">
                <button class="calc-btn px-4 py-2 bg-cream-50 border border-emerald-200 rounded-lg text-sm font-bold text-emerald-900/70 hover:border-emerald-700 hover:text-emerald-700 transition-colors" data-val="child" data-label="Child">Child</button>
                <button class="calc-btn px-4 py-2 bg-cream-50 border border-emerald-200 rounded-lg text-sm font-bold text-emerald-900/70 hover:border-emerald-700 hover:text-emerald-700 transition-colors" data-val="adult" data-label="Adult">Adult</button>
              </div>
            </div>

            <div>
              <div class="flex justify-between items-center mb-3">
                <span class="text-sm font-bold text-emerald-900/60 uppercase tracking-wider">Sessions per week</span>
                <span class="text-sm font-bold text-emerald-700" id="calc-freq-val">–</span>
              </div>
              <div class="flex flex-wrap gap-2" id="calc-freq-btns">
                <button class="calc-btn px-4 py-2 bg-cream-50 border border-emerald-200 rounded-lg text-sm font-bold text-emerald-900/70 hover:border-emerald-700 hover:text-emerald-700 transition-colors" data-val="2" data-label="2× / week">2× / week</button>
                <button class="calc-btn px-4 py-2 bg-cream-50 border border-emerald-200 rounded-lg text-sm font-bold text-emerald-900/70 hover:border-emerald-700 hover:text-emerald-700 transition-colors" data-val="3" data-label="3× / week">3× / week</button>
                <button class="calc-btn px-4 py-2 bg-cream-50 border border-emerald-200 rounded-lg text-sm font-bold text-emerald-900/70 hover:border-emerald-700 hover:text-emerald-700 transition-colors" data-val="5" data-label="5× / week">5× / week</button>
              </div>
            </div>

            <div>
              <div class="flex justify-between items-center mb-3">
                <span class="text-sm font-bold text-emerald-900/60 uppercase tracking-wider">Billing cycle</span>
                <span class="text-sm font-bold text-emerald-700" id="calc-cycle-val">–</span>
              </div>
              <div class="flex flex-wrap gap-2" id="calc-cycle-btns">
                <button class="calc-btn px-4 py-2 bg-cream-50 border border-emerald-200 rounded-lg text-sm font-bold text-emerald-900/70 hover:border-emerald-700 hover:text-emerald-700 transition-colors" data-val="monthly" data-label="Monthly">Monthly</button>
                <button class="calc-btn px-4 py-2 bg-cream-50 border border-emerald-200 rounded-lg text-sm font-bold text-emerald-900/70 hover:border-emerald-700 hover:text-emerald-700 transition-colors flex items-center gap-2" data-val="annual" data-label="Annual">
                  Annual <span class="bg-amber-50 text-amber-600 text-[10px] px-1.5 py-0.5 rounded border border-amber-200">-15%</span>
                </button>
              </div>
            </div>

            <div class="h-px bg-emerald-100 my-6" aria-hidden="true"></div>

            <div class="bg-emerald-50 border border-emerald-100 rounded-2xl p-5 transition-colors duration-300" id="calc-result-box">
              <div class="text-center text-sm font-medium text-emerald-800/70 py-2">Select options above to see your price</div>
            </div>

            <Button href="/funnel/signup" variant="primary" class="w-full mt-6">Book Your Free Class →</Button>
          </div>
        </div>

      </div>
    </section>

    <Section height={200} class="bg-white border-y border-emerald-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 divide-y sm:divide-y-0 sm:divide-x divide-emerald-100">
          <div class="py-6 sm:px-6 flex items-center gap-4 hover:bg-cream-50 transition-colors">
            <div class="w-10 h-10 rounded-lg bg-emerald-50 text-emerald-700 flex items-center justify-center shrink-0" set:html={Icons.shield}></div>
            <div>
              <div class="text-sm font-bold text-emerald-950">Full-month guarantee</div>
              <div class="text-xs font-medium text-emerald-800/70">Refund if unsatisfied</div>
            </div>
          </div>
          <div class="py-6 sm:px-6 flex items-center gap-4 hover:bg-cream-50 transition-colors">
            <div class="w-10 h-10 rounded-lg bg-emerald-50 text-emerald-700 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            </div>
            <div>
              <div class="text-sm font-bold text-emerald-950">Make-up guarantee</div>
              <div class="text-xs font-medium text-emerald-800/70">Every absence replaced</div>
            </div>
          </div>
          <div class="py-6 sm:px-6 flex items-center gap-4 hover:bg-cream-50 transition-colors">
            <div class="w-10 h-10 rounded-lg bg-emerald-50 text-emerald-700 flex items-center justify-center shrink-0" set:html={Icons.xIcon}></div>
            <div>
              <div class="text-sm font-bold text-emerald-950">No hidden fees</div>
              <div class="text-xs font-medium text-emerald-800/70">You pay what you see</div>
            </div>
          </div>
          <div class="py-6 sm:px-6 flex items-center gap-4 hover:bg-cream-50 transition-colors">
            <div class="w-10 h-10 rounded-lg bg-emerald-50 text-emerald-700 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <div>
              <div class="text-sm font-bold text-emerald-950">Weekly reports</div>
              <div class="text-xs font-medium text-emerald-800/70">Included in every plan</div>
            </div>
          </div>
        </div>
      </div>
    </Section>

    <Section height={900} class="py-12 md:py-24 lg:py-32" id="plans">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-12">
          <span class="text-xs font-black tracking-widest uppercase text-emerald-700 block mb-3">Tuition Plans</span>
          <h2 class="text-4xl lg:text-5xl font-bold text-emerald-950 mb-4 tracking-tight">
            Choose your plan.<br/>
            <em class="font-serif italic text-emerald-700 font-medium">Change it any time.</em>
          </h2>
          <p class="text-lg text-emerald-900/80 font-medium max-w-2xl mx-auto">
            All plans include the same quality — same ijazah-certified teachers, same weekly reports, same guarantee. The only difference is session frequency.
          </p>
        </div>

        <div class="flex items-center justify-center gap-4 mb-16">
          <span class="text-sm font-bold text-emerald-900/60 transition-colors" id="lbl-monthly">Monthly</span>
          <button class="relative w-14 h-8 rounded-full bg-emerald-700 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-700" id="billing-toggle" aria-pressed="true">
            <span class="absolute top-1 left-1 bg-white w-6 h-6 rounded-full transition-transform transform translate-x-6 shadow-sm" id="billing-thumb"></span>
          </button>
          <span class="text-sm font-bold text-emerald-950 transition-colors" id="lbl-annual">Annual</span>
          <span class="bg-amber-50 text-amber-600 text-[11px] font-bold px-2.5 py-0.5 rounded-full border border-amber-200 shadow-sm">Save 15%</span>
        </div>

        <div class="grid lg:grid-cols-3 gap-6 lg:gap-8 mb-8 max-w-6xl mx-auto">
          
          <div class="bg-white rounded-3xl border border-emerald-100 flex flex-col hover:shadow-xl transition-all duration-300">
            <div class="p-8 border-b border-emerald-50">
              <div class="text-[11px] font-bold tracking-widest uppercase text-emerald-900/50 mb-4">Starter</div>
              <h3 class="font-serif text-3xl font-bold text-emerald-950 mb-2">Light</h3>
              <p class="text-sm text-emerald-800/70 font-medium leading-relaxed mb-6 h-14">Perfect for children just beginning or families testing the experience.</p>
              <div class="flex items-baseline gap-1 mb-1">
                <span class="text-2xl font-bold text-emerald-950">$</span>
                <span class="font-serif text-6xl font-bold text-emerald-950" id="price-light">33</span>
              </div>
              <div class="text-sm font-medium text-emerald-800/70 mb-1" id="per-light">per month, billed annually</div>
              <div class="text-xs font-medium text-emerald-900/40 line-through h-4" id="orig-light">$39/mo when billed monthly</div>
              <div class="mt-6 inline-flex items-center px-3 py-1 bg-emerald-50 border border-emerald-100 text-emerald-700 text-xs font-bold rounded-full">8 sessions / month</div>
            </div>
            <div class="p-8 flex-1 flex flex-col">
              <div class="text-[11px] font-bold tracking-widest uppercase text-emerald-900/50 mb-6">What's included</div>
              <div class="space-y-4 flex-1">
                <div class="flex items-start gap-3"><span set:html={Icons.check}></span><span class="text-sm font-medium text-emerald-950">8 private 1-on-1 sessions/mo</span></div>
                <div class="flex items-start gap-3"><span set:html={Icons.check}></span><span class="text-sm font-medium text-emerald-950">Same dedicated teacher</span></div>
                <div class="flex items-start gap-3"><span set:html={Icons.check}></span><span class="text-sm font-medium text-emerald-950">Weekly progress report</span></div>
                <div class="flex items-start gap-3"><span set:html={Icons.check}></span><span class="text-sm font-medium text-emerald-950">Make-up class guarantee</span></div>
                <div class="flex items-start gap-3"><span set:html={Icons.check}></span><span class="text-sm font-medium text-emerald-950">Sit-in access anytime</span></div>
                <div class="flex items-start gap-3 opacity-40"><div class="w-5 h-5 shrink-0 bg-gray-100 rounded-full flex items-center justify-center text-[10px] font-bold" aria-hidden="true">-</div><span class="text-sm font-medium text-emerald-950">Monthly progress summary</span></div>
                <div class="flex items-start gap-3 opacity-40"><div class="w-5 h-5 shrink-0 bg-gray-100 rounded-full flex items-center justify-center text-[10px] font-bold" aria-hidden="true">-</div><span class="text-sm font-medium text-emerald-950">Priority teacher matching</span></div>
              </div>
              <Button href="/funnel/signup" variant="ghost" class="w-full mt-8">Start free trial →</Button>
            </div>
          </div>

          <div class="bg-white rounded-3xl border border-emerald-200 shadow-2xl flex flex-col relative transform lg:-translate-y-4 ring-2 ring-emerald-700/20 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-b from-emerald-50/50 to-white pointer-events-none" aria-hidden="true"></div>
            <div class="absolute top-0 left-0 right-0 bg-gradient-to-r from-emerald-700 to-emerald-500 text-center text-[11px] font-bold tracking-widest uppercase text-white py-1.5 rounded-t-[22px] shadow-sm flex items-center justify-center gap-1">
              <span set:html={Icons.sparkle}></span> Most Popular
            </div>
            
            <div class="p-8 border-b border-emerald-100 mt-4 relative z-10">
              <div class="text-[11px] font-bold tracking-widest uppercase text-emerald-900/50 mb-4">Growth</div>
              <h3 class="font-serif text-3xl font-bold text-emerald-950 mb-2">Standard</h3>
              <p class="text-sm text-emerald-800/70 font-medium leading-relaxed mb-6 h-14">Three sessions per week is the sweet spot for consistent, meaningful progress.</p>
              <div class="flex items-baseline gap-1 mb-1">
                <span class="text-2xl font-bold text-emerald-950">$</span>
                <span class="font-serif text-6xl font-bold text-emerald-950" id="price-standard">50</span>
              </div>
              <div class="text-sm font-medium text-emerald-800/70 mb-1" id="per-standard">per month, billed annually</div>
              <div class="text-xs font-medium text-emerald-900/40 line-through h-4" id="orig-standard">$59/mo when billed monthly</div>
              <div class="mt-6 inline-flex items-center px-3 py-1 bg-emerald-50 border border-emerald-200 text-emerald-700 text-xs font-bold rounded-full shadow-sm">12 sessions / month</div>
            </div>
            <div class="p-8 flex-1 flex flex-col bg-emerald-50/30 rounded-b-[22px] relative z-10">
              <div class="text-[11px] font-bold tracking-widest uppercase text-emerald-900/50 mb-6">What's included</div>
              <div class="space-y-4 flex-1">
                <div class="flex items-start gap-3 text-emerald-700"><span set:html={Icons.check}></span><span class="text-sm font-bold text-emerald-950">12 private 1-on-1 sessions/mo</span></div>
                <div class="flex items-start gap-3 text-emerald-700"><span set:html={Icons.check}></span><span class="text-sm font-medium text-emerald-950">Same dedicated teacher</span></div>
                <div class="flex items-start gap-3 text-emerald-700"><span set:html={Icons.check}></span><span class="text-sm font-medium text-emerald-950">Weekly progress report</span></div>
                <div class="flex items-start gap-3 text-emerald-700"><span set:html={Icons.check}></span><span class="text-sm font-medium text-emerald-950">Make-up class guarantee</span></div>
                <div class="flex items-start gap-3 text-emerald-700"><span set:html={Icons.check}></span><span class="text-sm font-medium text-emerald-950">Sit-in access anytime</span></div>
                <div class="flex items-start gap-3 text-emerald-700"><span set:html={Icons.check}></span><span class="text-sm font-bold text-emerald-950">Monthly progress summary</span></div>
                <div class="flex items-start gap-3 text-emerald-700"><span set:html={Icons.check}></span><span class="text-sm font-bold text-emerald-950">Priority teacher matching</span></div>
              </div>
              <Button href="/funnel/signup" variant="primary" class="w-full mt-8 shadow-xl shadow-emerald-700/20">Start free trial →</Button>
            </div>
          </div>

          <div class="bg-white rounded-3xl border border-emerald-100 flex flex-col hover:shadow-xl transition-all duration-300">
            <div class="p-8 border-b border-emerald-50">
              <div class="text-[11px] font-bold tracking-widest uppercase text-emerald-900/50 mb-4">Intensive</div>
              <h3 class="font-serif text-3xl font-bold text-emerald-950 mb-2">Hifz-Ready</h3>
              <p class="text-sm text-emerald-800/70 font-medium leading-relaxed mb-6 h-14">For children pursuing Hifz or accelerating through Tajweed. Five sessions weekly.</p>
              <div class="flex items-baseline gap-1 mb-1">
                <span class="text-2xl font-bold text-emerald-950">$</span>
                <span class="font-serif text-6xl font-bold text-emerald-950" id="price-intensive">76</span>
              </div>
              <div class="text-sm font-medium text-emerald-800/70 mb-1" id="per-intensive">per month, billed annually</div>
              <div class="text-xs font-medium text-emerald-900/40 line-through h-4" id="orig-intensive">$89/mo when billed monthly</div>
              <div class="mt-6 inline-flex items-center px-3 py-1 bg-emerald-50 border border-emerald-100 text-emerald-700 text-xs font-bold rounded-full">20 sessions / month</div>
            </div>
            <div class="p-8 flex-1 flex flex-col">
              <div class="text-[11px] font-bold tracking-widest uppercase text-emerald-900/50 mb-6">What's included</div>
              <div class="space-y-4 flex-1">
                <div class="flex items-start gap-3"><span set:html={Icons.check}></span><span class="text-sm font-medium text-emerald-950">20 private 1-on-1 sessions/mo</span></div>
