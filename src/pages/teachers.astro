---
// src/pages/teachers.astro
import Base from '../layouts/Base.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';

// Reusable SVGs mapped for DOM injection
const Icons = {
  heroBadge: `<svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
  ijazah: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477-4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>`,
  checkCircle: `<svg class="w-5 h-5 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>`,
  privacy: `<svg class="w-10 h-10" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" /></svg>`,
  star: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>`,
  arrowRight: `<svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>`,
  
  // Vetting Icons
  vet1: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
  vet2: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" /></svg>`,
  vet3: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>`,
  vet4: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>`
};

// --- RIGOROUS VETTING DATA ---
const VETTING_PROCESS = [
  {
    step: '01',
    title: 'Credential Verification',
    desc: 'Every applicant must provide proof of Hafiz status and Ijazah certification. We verify their educational background and identity.',
    icon: Icons.vet1
  },
  {
    step: '02',
    title: 'Live Tajweed Audit',
    desc: 'Candidates undergo a rigorous live recitation test with our senior academic panel to ensure flawless Makharij (pronunciation) and Tajweed rules.',
    icon: Icons.vet2
  },
  {
    step: '03',
    title: 'Pedagogy Evaluation',
    desc: 'Knowing the Quran is not enough. Teachers are tested on their ability to explain complex concepts simply, especially to children and non-Arabic speakers.',
    icon: Icons.vet3
  },
  {
    step: '04',
    title: 'Continuous Quality Assurance',
    desc: 'Once hired, tutors are subject to random class audits, monthly training workshops, and strict parent-feedback reviews to maintain their status.',
    icon: Icons.vet4
  }
];

// --- FEATURED TEACHERS (Data-Rich Profiles) ---
const TEACHERS = [
  {
    name: 'Ustadha Fatima M.',
    gender: 'Female',
    title: "Ijazah in Hafs 'an 'Asim",
    experience: '8+ Years',
    rating: '5.0',
    students: '120+',
    specialties: ['Child Psychology', 'Beginner Tajweed', "Women's Hifz"],
    languages: ['English', 'Arabic'],
    bio: 'Specializing in early childhood Islamic education, Ustadha Fatima uses interactive, gentle methods to make young learners fall in love with the Quran.'
  },
  {
    name: 'Ustad Bilal A.',
    gender: 'Male',
    title: 'Hafiz & Qari (Al-Azhar Alumnus)',
    experience: '12+ Years',
    rating: '4.9',
    students: '300+',
    specialties: ['Advanced Tajweed', "Qira'at", 'Adult Hifz'],
    languages: ['English', 'Arabic', 'Urdu'],
    bio: 'With over a decade of experience and deep academic roots, Ustad Bilal helps adult learners perfect their recitation and memorize with unbreakable retention.'
  },
  {
    name: 'Ustadha Aisha R.',
    gender: 'Female',
    title: 'Certified Hafiza & Tajweed Expert',
    experience: '5+ Years',
    rating: '5.0',
    students: '85+',
    specialties: ['Female Only', 'Makharij Correction', 'Islamic Studies'],
    languages: ['English', 'Urdu'],
    bio: 'Known for her incredible patience and attention to detail, Ustadha Aisha provides a safe, comfortable, and highly effective learning environment for sisters.'
  },
  {
    name: 'Ustad Omar T.',
    gender: 'Male',
    title: "Ijazah Holder in 3 Qira'at",
    experience: '10+ Years',
    rating: '4.9',
    students: '250+',
    specialties: ['Youth Mentorship', 'Intensive Hifz', 'Tafsir Basics'],
    languages: ['English', 'Arabic'],
    bio: 'Ustad Omar combines traditional rigor with modern relatable mentorship, making him a favorite among teenage students navigating their Quranic journey.'
  }
];

// Elite Edge SEO: Upgraded AboutPage schema linking directly to instructors
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "Our Teachers - Quranific | Elite Quran Tutors",
  "description": "Meet our highly vetted, Ijazah-certified Quran tutors. We offer dedicated male and female instructors specializing in Tajweed, Hifz, and child education.",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": TEACHERS.map((t, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "Person",
        "name": t.name,
        "jobTitle": t.title,
        "description": t.bio
      }
    }))
  }
};
---

<Base 
  title="Our Teachers | Elite Certified Quran Tutors" 
  description="Learn from the top 1% of certified Quran scholars. Discover our rigorous vetting process and meet our dedicated male and female tutors."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  
  <Header />

  <main class="min-h-screen bg-cream-50 selection:bg-emerald-200 selection:text-emerald-950">
    
    <section class="pt-16 md:pt-32 pb-16 lg:pt-40 lg:pb-24 px-4 sm:px-6 relative overflow-hidden border-b border-emerald-100">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-emerald-500/5 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>
      
      <div class="max-w-4xl mx-auto text-center relative z-10 animate-in fade-in slide-in-from-bottom-8 duration-1000">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-50 text-emerald-800 text-xs font-bold tracking-widest uppercase rounded-full mb-8 border border-emerald-100 shadow-sm">
          <span set:html={Icons.heroBadge} aria-hidden="true"></span>
          The Top 1% of Instructors
        </span>
        
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-emerald-950 mb-6 tracking-tighter leading-[1.1] text-balance">
          Masters of the Word. <br/> Mentors for Life.
        </h1>
        
        <p class="text-lg lg:text-xl text-emerald-800/80 font-medium max-w-2xl mx-auto leading-relaxed text-balance mb-10">
          We don't just hire tutors; we curate a global faculty of certified scholars, Hafiz, and Ijazah holders dedicated to passing down the authentic recitation of the Quran.
        </p>

        <div class="flex flex-wrap justify-center gap-4 sm:gap-8">
          <div class="flex flex-col items-center">
            <span class="text-3xl font-black text-emerald-800">100%</span>
            <span class="text-xs font-bold text-emerald-600 uppercase tracking-wider">Background Checked</span>
          </div>
          <div class="w-px h-12 bg-emerald-200 hidden sm:block" aria-hidden="true"></div>
          <div class="flex flex-col items-center">
            <span class="text-3xl font-black text-emerald-800">24/7</span>
            <span class="text-xs font-bold text-emerald-600 uppercase tracking-wider">Quality Assurance</span>
          </div>
          <div class="w-px h-12 bg-emerald-200 hidden sm:block" aria-hidden="true"></div>
          <div class="flex flex-col items-center">
            <span class="text-3xl font-black text-emerald-800">4-Step</span>
            <span class="text-xs font-bold text-emerald-600 uppercase tracking-wider">Vetting Process</span>
          </div>
        </div>
      </div>
    </section>

    <Section height={400} class="py-16 bg-white border-b border-emerald-50 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto bg-emerald-50 rounded-3xl p-8 lg:p-12 border border-emerald-100 flex flex-col md:flex-row items-center gap-8 lg:gap-12">
        <div class="w-24 h-24 shrink-0 bg-amber-50 text-amber-600 rounded-full flex items-center justify-center border-4 border-white shadow-sm" aria-hidden="true">
          <span set:html={Icons.ijazah}></span>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-emerald-950 mb-2">The Gold Standard: What is an Ijazah?</h2>
          <p class="text-emerald-900/80 font-medium leading-relaxed">
            Many of our teachers hold an <strong>Ijazah</strong>. This is the highest traditional certification in Quranic recitation, verifying that the teacher's recitation is flawless and connected through an unbroken chain of transmission directly back to the Prophet Muhammad (ﷺ). When you learn with Quranific, you learn the authentic, preserved word of Allah.
          </p>
        </div>
      </div>
    </Section>

    <Section height={800} class="py-10 md:py-20 lg:py-32 px-4 sm:px-6 bg-emerald-950 relative overflow-hidden">
      <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#10b981_1px,transparent_1px)] [background-size:16px_16px]" aria-hidden="true"></div>
      
      <div class="max-w-7xl mx-auto relative z-10">
        <div class="text-center mb-16 max-w-3xl mx-auto">
          <h2 class="text-3xl lg:text-5xl font-black text-white mb-6 tracking-tight">How We Select Our Teachers</h2>
          <p class="text-lg text-emerald-100/80 font-medium">
            We reject over 90% of applicants. Only those who pass our exhaustive, multi-layered evaluation are allowed to teach our students.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {VETTING_PROCESS.map(process => (
            <div class="bg-emerald-900/50 backdrop-blur-sm border border-emerald-800 rounded-3xl p-8 hover:bg-emerald-800/80 transition-all duration-300">
              <div class="flex items-center justify-between mb-6">
                <div class="w-12 h-12 bg-emerald-800 text-amber-400 rounded-xl flex items-center justify-center shadow-inner" aria-hidden="true">
                  <span set:html={process.icon}></span>
                </div>
                <span class="text-4xl font-black text-emerald-950/40" aria-hidden="true">{process.step}</span>
              </div>
              <h3 class="text-xl font-bold text-white mb-3">{process.title}</h3>
              <p class="text-emerald-100/70 font-medium leading-relaxed text-sm">
                {process.desc}
              </p>
            </div>
          ))}
        </div>
      </div>
    </Section>

    <Section height={600} class="py-10 md:py-20 px-4 sm:px-6 border-b border-emerald-100">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <span class="text-emerald-700 font-bold tracking-widest uppercase text-sm mb-2 block">Safe & Comfortable</span>
          <h2 class="text-3xl lg:text-4xl font-black text-emerald-950 mb-6 tracking-tight">Dedicated Male & Female Instructors</h2>
          <p class="text-lg text-emerald-900/80 leading-relaxed font-medium mb-8">
            We understand the importance of modesty and comfort in Islamic education. You have the absolute freedom to request specifically male or female tutors.
          </p>
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-emerald-100 flex items-center justify-center shrink-0 mt-1" aria-hidden="true">
                <span set:html={Icons.checkCircle}></span>
              </div>
              <div>
                <h4 class="font-bold text-emerald-950">Female Tutors for Sisters & Kids</h4>
                <p class="text-emerald-800/80 text-sm font-medium mt-1">Nurturing, patient environments ensuring absolute privacy for women and a gentle approach for young children.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-emerald-100 flex items-center justify-center shrink-0 mt-1" aria-hidden="true">
                <span set:html={Icons.checkCircle}></span>
              </div>
              <div>
                <h4 class="font-bold text-emerald-950">Male Tutors for Brothers</h4>
                <p class="text-emerald-800/80 text-sm font-medium mt-1">Expert scholars and Hafiz-e-Quran providing rigorous, focused academic mentorship for boys and men.</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="bg-gradient-to-br from-emerald-50 to-white rounded-[3rem] p-8 border border-emerald-100 shadow-xl relative aspect-square max-w-md mx-auto flex flex-col justify-center items-center text-center">
          <div class="absolute inset-0 bg-emerald-200/20 rounded-[3rem] blur-2xl" aria-hidden="true"></div>
          <div class="relative z-10">
            <div class="w-20 h-20 bg-white rounded-2xl shadow-sm border border-emerald-50 flex items-center justify-center mx-auto mb-6 text-emerald-700" aria-hidden="true">
              <span set:html={Icons.privacy}></span>
            </div>
            <h3 class="text-2xl font-black text-emerald-950 mb-2">100% Privacy</h3>
            <p class="text-emerald-800/80 font-medium">1-on-1 private video links, end-to-end encryption, and strictly vetted staff.</p>
          </div>
        </div>
      </div>
    </Section>

    <Section height={900} class="py-10 md:py-20 lg:py-32 px-4 sm:px-6">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16 max-w-3xl mx-auto">
          <h2 class="text-3xl lg:text-5xl font-black text-emerald-950 mb-6 tracking-tight">Meet Our Featured Faculty</h2>
          <p class="text-lg text-emerald-800/80 font-medium">
            A small glimpse into the elite scholars, pedagogues, and mentors waiting to guide you.
          </p>
        </div>

        <div class="grid lg:grid-cols-2 gap-8">
          {TEACHERS.map(teacher => (
            <div class="bg-white rounded-3xl border border-emerald-100 shadow-sm hover:shadow-lg transition-all duration-300 p-6 sm:p-8 flex flex-col sm:flex-row gap-6 sm:gap-8 group">
              
              <div class="flex flex-col items-center shrink-0">
                <div class="w-24 h-24 rounded-full bg-gradient-to-br from-emerald-100 to-emerald-200 border-4 border-white shadow-md flex items-center justify-center text-emerald-800 text-3xl font-black tracking-tighter mb-4 group-hover:scale-105 transition-transform" aria-hidden="true">
                  {teacher.name.split(' ')[1][0]}
                </div>
                <div class="flex items-center gap-1 text-amber-500 mb-1">
                  <span set:html={Icons.star} aria-hidden="true"></span>
                  <span class="text-sm font-bold text-emerald-950">{teacher.rating}</span>
                </div>
                <span class="text-xs text-emerald-700/70 font-bold uppercase tracking-wider">{teacher.students} Students</span>
              </div>

              <div class="flex-1">
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  <h3 class="text-2xl font-bold text-emerald-950">{teacher.name}</h3>
                  <span class="px-2.5 py-1 bg-emerald-50 text-emerald-700 text-[10px] font-bold uppercase tracking-wider rounded-md border border-emerald-100">
                    {teacher.gender} Tutor
                  </span>
                </div>
                
                <p class="text-emerald-700 font-bold text-sm mb-4">{teacher.title} &nbsp;·&nbsp; {teacher.experience}</p>
                <p class="text-emerald-900/80 text-sm font-medium leading-relaxed mb-6">
                  "{teacher.bio}"
                </p>

                <div class="space-y-3">
                  <div class="flex items-start gap-2">
                    <span class="text-xs font-bold text-emerald-950 uppercase tracking-wider w-20 shrink-0 pt-0.5">Focus:</span>
                    <div class="flex flex-wrap gap-2">
                      {teacher.specialties.map(spec => (
                        <span class="bg-cream-50 border border-emerald-100 text-emerald-800 text-xs px-2.5 py-1 rounded-full font-medium shadow-sm">{spec}</span>
                      ))}
                    </div>
                  </div>
                  <div class="flex items-start gap-2">
                    <span class="text-xs font-bold text-emerald-950 uppercase tracking-wider w-20 shrink-0 pt-0.5">Speaks:</span>
                    <div class="flex flex-wrap gap-2">
                      {teacher.languages.map(lang => (
                        <span class="text-emerald-800/80 text-xs font-medium bg-white border border-emerald-50 px-2 py-0.5 rounded-md shadow-sm">{lang}</span>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
              
            </div>
          ))}
        </div>
      </div>
    </Section>

    <Section height={400} class="pb-12 md:pb-24 px-4 sm:px-6 relative z-10">
      <div class="max-w-4xl mx-auto bg-gradient-to-br from-emerald-800 to-emerald-950 rounded-3xl p-10 lg:p-16 text-center shadow-xl border border-emerald-800 relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-64 h-64 bg-emerald-500/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none transition-transform duration-700 group-hover:scale-110" aria-hidden="true"></div>
        
        <div class="relative z-10">
          <h2 class="text-3xl lg:text-4xl font-black text-white mb-4 tracking-tight">Find Your Perfect Match</h2>
          <p class="text-emerald-100/90 mb-10 text-lg max-w-xl mx-auto font-medium">
            Tell us about your goals, schedule, and preferences. We will pair you with the ideal teacher to start your journey.
          </p>
          <div class="flex justify-center">
            <Button href="/funnel/signup" variant="white" class="text-lg px-10 group">
              Book Your Free Trial
              <span set:html={Icons.arrowRight} aria-hidden="true"></span>
            </Button>
          </div>
        </div>
      </div>
    </Section>

  </main>

  <Footer />
</Base>