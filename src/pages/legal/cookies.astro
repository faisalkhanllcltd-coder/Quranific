---
// src/pages/legal/cookie-policy.astro
import Base from '../../layouts/Base.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';

const lastUpdated = "March 25, 2026";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Cookie Policy - Quranific",
  "description": "Learn how Quranific uses cookies and tracking technologies to improve your experience and manage global advertising.",
  "dateModified": "2026-03-25"
};
---

<Base title="Cookie Policy | Quranific" description="How we use cookies, tracking pixels, and analytics to improve your experience and measure performance.">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  
  <Header />

  <main class="bg-[#fefdf9] min-h-screen selection:bg-[#d1fae5] selection:text-[#064e3b] font-sans pb-32">
    
    <div class="pt-16 md:pt-32 pb-12 lg:pt-40 lg:pb-16 px-4 sm:px-6 border-b border-emerald-100 bg-white">
      <div class="max-w-5xl mx-auto">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-emerald-50 border border-[#d1fae5] text-[#047857] text-xs font-bold uppercase tracking-widest rounded-full mb-6">
          Legal & Compliance
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-[#022c22] tracking-tight mb-6">
          Cookie Policy
        </h1>
        <p class="text-lg text-emerald-700/80 font-medium max-w-3xl">
          At Quranific, we believe in transparency regarding how we collect and use data. This policy explains our use of cookies and tracking technologies. <br/>
          <span class="text-sm mt-2 block opacity-70">Last Updated: {lastUpdated}</span>
        </p>
      </div>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-16 space-y-20">
      
      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          What Are Cookies?
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Definition</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">Cookies are small text files downloaded to your device (computer, tablet, or smartphone) when you visit our website. They act as a memory for the website, allowing us to recognize you when you return and ensuring the site functions properly securely.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Types of Cookies We Use
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Essential Cookies</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">These are strictly necessary for the website to operate. They allow you to log in to your student portal, access secure areas, and navigate the site. Because they are critical to site function, you cannot switch these off.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Performance & Analytics Cookies</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">These help us understand how visitors interact with our site (e.g., which pages are most popular and error occurrences). We use this aggregated data solely to improve our website’s performance and structure.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Functional Cookies</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">These allow the website to remember choices you make (such as your username, language preference, or region) to provide a more personalized, smoother experience.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Marketing & Tracking Cookies</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">These are used to deliver relevant advertisements to adult users on external platforms. They track browsing habits to help us measure the effectiveness of our marketing campaigns across global networks.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Third-Party Tracking Services
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Analytics Providers</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">We utilize Google Analytics to analyze website traffic, understand user behavior, and optimize our educational platform.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Global Advertising Networks</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">We use tracking pixels and tags from Google Ads, Meta (Facebook/Instagram), TikTok, Pinterest, and Microsoft Ads. These tools help us reach potential students and measure ad conversion rates.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Payment Gateways</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">Secure payment processors (such as Stripe, Wise, and PayPal) may place essential cookies to facilitate secure transactions and prevent fraud during checkout.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Managing Your Preferences
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Browser Settings</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">You have the right to accept or reject cookies. Most web browsers automatically accept cookies, but you can modify your browser settings to manage, delete, or decline them.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Impact of Disabling Cookies</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">Please note that disabling essential cookies may prevent you from logging into your account, scheduling classes, or using core features of the Quranific platform.</p>
          </li>
        </ul>
      </section>

      <section class="mt-16 pt-16 border-t border-emerald-100">
        <h2 class="text-3xl font-black text-[#022c22] mb-6 tracking-tight">Contact Our Data Team</h2>
        <p class="text-lg text-[#064e3b]/80 font-medium mb-6">If you have any questions regarding our use of cookies or tracking technologies, please contact us:</p>

        <div class="bg-emerald-50 border border-emerald-100 p-8 rounded-2xl">
          <div class="flex flex-col gap-4">
            <div class="flex items-center gap-4">
              <span class="w-10 h-10 rounded-full bg-[#047857] text-white flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </span>
              <a href="mailto:privacy@quranific.com" class="font-bold text-xl text-[#022c22] hover:text-[#047857] transition-colors">privacy@quranific.com</a>
            </div>
            <div class="flex items-center gap-4">
              <span class="w-10 h-10 rounded-full bg-[#047857] text-white flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"></path></svg>
              </span>
              <a href="https://wa.me/923112112122" target="_blank" rel="noopener" class="font-bold text-xl text-[#022c22] hover:text-[#047857] transition-colors">+92 311 2112122</a>
            </div>
          </div>
        </div>
      </section>

    </div>
  </main>

  <Footer />
</Base>