---
// src/components/global/MobileMenu.astro
// Pure HTML/Tailwind with Vanilla JS. Zero hydration cost.
import { MOBILE_NAVIGATION } from '../../constants/site';
---

<div class="lg:hidden">
  <button
    id="mobile-menu-toggle"
    type="button"
    aria-label="Open navigation menu"
    aria-expanded="false"
    aria-controls="mobile-menu-drawer"
    class="text-emerald-950 p-2 min-h-[44px] min-w-[44px] flex items-center justify-center focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-600 hover:bg-emerald-50 rounded-lg transition-colors"
  >
    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </button>

  <div
    id="mobile-menu-drawer"
    role="dialog"
    aria-modal="true"
    aria-label="Navigation menu"
    inert
    class="fixed inset-0 z-50 bg-[#fefdf9] transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col pt-6 px-4 sm:px-6 invisible"
  >
    <div class="flex items-center justify-between mb-12">
      <a href="/" class="font-serif text-2xl font-black text-emerald-950 tracking-tight focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-600 rounded">
        Quranific.
      </a>
      <button
        id="mobile-menu-close"
        type="button"
        aria-label="Close navigation menu"
        class="text-emerald-950 p-2 bg-emerald-50 rounded-full hover:bg-emerald-100 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-600 min-h-[44px] min-w-[44px] flex items-center justify-center"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <nav aria-label="Mobile navigation" class="flex flex-col gap-6 text-center mt-4">
      {MOBILE_NAVIGATION.map((item) => (
        <a
          href={item.href}
          class="text-3xl font-black text-emerald-950 hover:text-emerald-700 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-600 rounded py-1"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="mt-auto pb-12 flex flex-col gap-4">
      <a
        href="/portals"
        class="w-full text-center py-4 font-bold text-emerald-900 bg-emerald-50 rounded-xl border border-emerald-100 hover:bg-emerald-100 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-600 min-h-[44px] flex items-center justify-center"
      >
        Student Login
      </a>
      <a
        href="/funnel/signup"
        class="w-full text-center py-4 font-bold text-white bg-emerald-700 rounded-xl shadow-lg hover:bg-emerald-800 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-white min-h-[44px] flex items-center justify-center"
      >
        Book Your Free Class
      </a>
    </div>

  </div>
</div>

<script>
  let mobileMenuAbortController: AbortController | null = null;

  function initMobileMenu(): void {
    document.body.style.overflow = ''; // Always reset in case of interruption
    mobileMenuAbortController?.abort();
    mobileMenuAbortController = new AbortController();
    const { signal } = mobileMenuAbortController;

    const toggleBtn = document.getElementById('mobile-menu-toggle') as HTMLButtonElement | null;
    const closeBtn  = document.getElementById('mobile-menu-close')  as HTMLButtonElement | null;
    const drawer    = document.getElementById('mobile-menu-drawer') as HTMLElement | null;

    if (!toggleBtn || !closeBtn || !drawer) return;

    const FOCUSABLE = 'a[href]:not([tabindex="-1"]), button:not([disabled]):not([tabindex="-1"])';

    function getFocusables(): HTMLElement[] {
      return Array.from(drawer!.querySelectorAll<HTMLElement>(FOCUSABLE));
    }

    function openMenu(): void {
      drawer!.removeAttribute('inert');
      drawer!.classList.remove('invisible');
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          drawer!.classList.remove('translate-x-full');
        });
      });
      document.body.style.overflow = 'hidden';
      toggleBtn!.setAttribute('aria-expanded', 'true');
      closeBtn!.focus();
    }

    function closeMenu(): void {
      drawer!.classList.add('translate-x-full');
      document.body.style.overflow = '';
      toggleBtn!.setAttribute('aria-expanded', 'false');
      const animDuration = parseFloat(getComputedStyle(drawer!).transitionDuration || '0.3') * 1000;
      setTimeout(() => {
        drawer!.classList.add('invisible');
        drawer!.setAttribute('inert', '');
        toggleBtn!.focus();
      }, animDuration || 300);
    }

    drawer.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') return closeMenu();
      if (e.key !== 'Tab') return;

      const focusables = getFocusables();
      if (focusables.length === 0) return;

      const first = focusables[0];
      const last  = focusables[focusables.length - 1];

      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }, { signal });

    // Outside-click closure: fires only when the menu is open and the click
    // lands outside both the drawer panel and the hamburger toggle button.
    document.addEventListener('click', (e: MouseEvent) => {
      const isOpen = !drawer!.hasAttribute('inert');
      if (!isOpen) return;

      const target = e.target as Node | null;
      const clickedInsideDrawer  = drawer!.contains(target);
      const clickedToggleBtn     = toggleBtn!.contains(target);

      if (!clickedInsideDrawer && !clickedToggleBtn) {
        closeMenu();
      }
    }, { signal });

    toggleBtn.addEventListener('click', openMenu, { signal });
    closeBtn.addEventListener('click', closeMenu, { signal });

    document.addEventListener('astro:before-preparation', closeMenu, { signal });
  }

  document.addEventListener('astro:page-load', initMobileMenu);
</script>