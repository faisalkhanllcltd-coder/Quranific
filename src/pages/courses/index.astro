  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Attach event listeners
      document.querySelectorAll('#who-btns button').forEach(btn => {
        const val = btn.textContent.toLowerCase().includes('young') || btn.textContent.includes('4–8') ? 'child-young' : (btn.textContent.includes('9–14') ? 'child-older' : (btn.textContent.includes('Adult') ? 'adult' : 'special'));
        btn.addEventListener('click', function() { selectFinder('who', this, val); });
      });
      document.querySelectorAll('#level-btns button').forEach(btn => {
        const val = btn.textContent.includes('beginner') ? 'zero' : (btn.textContent.includes('read') ? 'reads' : 'hifz');
        btn.addEventListener('click', function() { selectFinder('level', this, val); });
      });
      document.querySelectorAll('.course-tab').forEach(btn => btn.addEventListener('click', function() { filterCourses(this.getAttribute('data-filter'), this); }));

    // --- 1. COURSE FINDER LOGIC ---
    const finderState = { who: null, level: null };
    const courseMap = {
      'child-young-zero': 'Quran Foundation — perfect for ages 4–8 starting from zero.',
      'child-young-reads': 'Tajweed Mastery — build on reading skills with full Tajweed rules.',
      'child-young-hifz': 'Hifz Programme — structured memorisation for children ready to begin.',
      'child-older-zero': 'Quran Foundation — no age is too late to start from the beginning.',
      'child-older-reads': 'Tajweed Mastery — our most enrolled programme, perfect for ages 9–14.',
      'child-older-hifz': 'Hifz Programme — systematic full Quran memorisation with revision cycles.',
      'adult-zero': 'Adult Tajweed Fix — 100% private, diagnostic-first, built around your actual gaps.',
      'adult-reads': 'Adult Tajweed Fix — correct your recitation in private, at your pace.',
      'adult-hifz': 'Adult Hifz Journey — memorise the Quran around a real adult schedule.',
      'special-zero': 'Learning Differences Programme — SEN-trained teacher, adapted from day one.',
      'special-reads': 'Learning Differences Programme — adapted Tajweed teaching for your child.',
      'special-hifz': "Learning Differences Programme — structured Hifz adapted for your child's needs."
    };

    function selectFinder(type, el, val) {
      // Update active button state
      const containerId = type === 'who' ? 'who-btns' : 'level-btns';
      const container = document.getElementById(containerId);
      
      container.querySelectorAll('button').forEach(b => {
        b.classList.remove('bg-white', 'text-[#022c22]', 'border-white');
        b.classList.add('bg-white/10', 'text-white/80', 'border-white/20');
      });
      
      el.classList.remove('bg-white/10', 'text-white/80', 'border-white/20');
      el.classList.add('bg-white', 'text-[#022c22]', 'border-white');
      
      finderState[type] = val;
      
      // If both selected, show result
      if (finderState.who && finderState.level) {
        const key = finderState.who + '-' + finderState.level;
        const rec = courseMap[key] || 'Quran Foundation — the best starting point when unsure.';
        const parts = rec.split(' — ');
        
        document.getElementById('fr-course').textContent = parts[0];
        document.getElementById('fr-desc').textContent = parts[1] || '';
        document.getElementById('finder-result').classList.remove('hidden');
      }
    };

    // --- 2. COURSE TAB FILTERING ---
    function filterCourses(category, btn) {
      // Update Tab Styles
      document.querySelectorAll('.course-tab').forEach(t => {
        t.classList.remove('bg-[#047857]', 'text-white', 'shadow-md');
        t.classList.add('text-[#064e3b]/60');
      });
      btn.classList.remove('text-[#064e3b]/60');
      btn.classList.add('bg-[#047857]', 'text-white', 'shadow-md');

      // Filter Cards
      const cards = document.querySelectorAll('.course-card');
      cards.forEach(card => {
        const cats = card.getAttribute('data-cat') || '';
        if (category === 'all' || cats.includes(category)) {
          card.style.display = 'flex';
        } else {
          card.style.display = 'none';
        }
      });
    };
      });
  </script>
