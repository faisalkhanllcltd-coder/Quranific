---
// src/components/sections/FinalCTA.astro
import { SITE } from '../../constants/site';

const CheckIcon = `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`;
---

<section
  class="py-12 md:py-24 lg:py-32 bg-[#047857] relative overflow-hidden text-center"
  aria-labelledby="final-cta-heading"
>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[400px] h-[400px] md:w-[800px] md:h-[800px] bg-[#10b981] rounded-full blur-[80px] md:blur-[120px] opacity-20 pointer-events-none -translate-y-1/2" aria-hidden="true"></div>
  
  <div class="max-w-4xl mx-auto px-4 sm:px-6 relative z-10">
    
    <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/10 border border-white/20 text-white text-xs font-bold uppercase tracking-widest rounded-full mb-8 backdrop-blur-sm">
      <span class="w-2 h-2 rounded-full bg-emerald-400" aria-hidden="true"></span>
      Guaranteed 1-on-1 Focus
    </div>

    <h2 id="final-cta-heading" class="text-4xl sm:text-5xl lg:text-6xl font-semibold text-white mb-6 tracking-tight leading-tight text-balance">
      Your child's first class 
      <span class="text-[#fde68a] font-serif italic">is completely free.</span>
    </h2>
    
    <p class="text-xl text-emerald-100/90 font-medium mb-12 max-w-xl mx-auto leading-relaxed text-balance">
      No credit card. No commitment. No risk.<br class="hidden sm:block"/>
      Just 30 minutes that might change everything.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
      <a href="/funnel/signup" class="w-full sm:w-auto inline-flex justify-center items-center gap-2 px-8 py-4 bg-white text-[#047857] hover:bg-[#ecfdf5] font-bold rounded-xl transition-all duration-300 shadow-xl shadow-emerald-900/30 text-lg">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
        Book Your Free Class
      </a>
      
      <a href={SITE.whatsappLink} target="_blank" rel="noopener noreferrer" class="group w-full sm:w-auto inline-flex justify-center items-center gap-2 px-8 py-4 bg-transparent border-2 border-emerald-200/50 text-white hover:bg-white/10 hover:border-white/80 font-bold rounded-xl transition-all duration-300 text-lg">
        <svg class="w-5 h-5 text-[#25D366] group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        Chat on WhatsApp
      </a>
    </div>

    <ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm font-semibold text-emerald-50/90" role="list">
      <li class="flex items-center gap-2"><Fragment set:html={CheckIcon} /> First class free</li>
      <li class="flex items-center gap-2"><Fragment set:html={CheckIcon} /> Full refund in month 1</li>
      <li class="flex items-center gap-2"><Fragment set:html={CheckIcon} /> Cancel anytime</li>
    </ul>

  </div>
</section>