---
// src/pages/careers.astro
import Base from '../layouts/Base.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';


// Elite Edge SEO: Upgraded to JobPosting Schema for Google Jobs native indexing
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Careers - Quranific",
    "description": "Join the team building something that matters. Fully remote, mission-driven careers at Quranific."
  },
  {
    "@context": "https://schema.org/",
    "@type": "JobPosting",
    "title": "Senior Full-Stack Engineer",
    "description": "<p>We are rebuilding our core platform on Astro 5 and Svelte 5. You will own the funnel experience, teacher-parent reporting pipeline, and our Cloudflare Workers architecture.</p>",
    "identifier": {
      "@type": "PropertyValue",
      "name": "Quranific",
      "value": "ENG-01"
    },
    "datePosted": "2024-03-01",
    "validThrough": "2024-12-31",
    "employmentType": "FULL_TIME",
    "hiringOrganization": {
      "@type": "Organization",
      "name": "Quranific",
      "sameAs": "https://quranific.com",
      "logo": "https://quranific.com/logo.png"
    },
    "jobLocationType": "TELECOMMUTE",
    "applicantLocationRequirements": {
      "@type": "Country",
      "name": "Worldwide"
    },
    "baseSalary": {
      "@type": "MonetaryAmount",
      "currency": "USD",
      "value": {
        "@type": "QuantitativeValue",
        "minValue": 90000,
        "maxValue": 120000,
        "unitText": "YEAR"
      }
    }
  }
];

// Reusable SVGs

---

<Base 
  title="Careers â€” Quranific | Join the Team Building Something That Matters" 
  description="At Quranific we are not just building a product. We are rebuilding the relationship between Muslim children and the Quran. Explore our remote-first roles."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" is:inline />

  <Header />

  <main class="bg-cream-50 selection:bg-emerald-100 selection:text-emerald-900 font-sans">
    
    <Section height={700} class="pt-16 md:pt-32 pb-10 md:pb-20 lg:pt-48 lg:pb-32 px-4 sm:px-6 relative overflow-hidden">
      <div class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-amber-500/10 rounded-full blur-[100px] pointer-events-none" aria-hidden="true"></div>
      <div class="absolute bottom-[-10%] left-[-5%] w-[500px] h-[500px] bg-emerald-700/10 rounded-full blur-[100px] pointer-events-none" aria-hidden="true"></div>

      <div class="max-w-7xl mx-auto grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-20 items-center relative z-10">
        
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-emerald-50 border border-emerald-100 text-emerald-700 text-xs font-bold uppercase tracking-widest rounded-full mb-8 shadow-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse" aria-hidden="true"></span>
            We are hiring Â· Remote-first
          </div>
          
          <h1 class="text-5xl lg:text-6xl font-bold text-emerald-950 leading-[1.05] tracking-tight mb-6">
            Join the team building<br/>
            <em class="font-serif italic text-emerald-700 font-medium">something that matters.</em>
          </h1>
          
          <p class="text-lg text-emerald-900/80 font-medium leading-relaxed mb-10 max-w-xl">
            At Quranific we are not just building a product. We are rebuilding the relationship between Muslim children and the Quran â€” one lesson, one family, one teacher at a time. If that mission pulls at you, read on.
          </p>

          <div class="flex flex-col sm:flex-row items-center gap-4 mb-12">
            <Button href="#open-roles" variant="primary" class="w-full sm:w-auto">See Open Roles â†“</Button>
            <Button href="#teacher-path" variant="ghost" class="w-full sm:w-auto">Apply as a Teacher</Button>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 pt-6 border-t border-emerald-100">
            <div>
              <div class="font-serif text-3xl font-bold text-emerald-700 mb-1">48</div>
              <div class="text-xs font-bold text-emerald-900/50 uppercase tracking-widest">Team members</div>
            </div>
            <div>
              <div class="font-serif text-3xl font-bold text-emerald-700 mb-1">22</div>
              <div class="text-xs font-bold text-emerald-900/50 uppercase tracking-widest">Countries</div>
            </div>
            <div>
              <div class="font-serif text-3xl font-bold text-emerald-700 mb-1">100%</div>
              <div class="text-xs font-bold text-emerald-900/50 uppercase tracking-widest">Remote-first</div>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-3xl shadow-xl shadow-emerald-900/10 border border-emerald-100 p-8 transform lg:-rotate-1 hover:rotate-0 transition-transform duration-700 animate-[flyY_6s_ease-in-out_infinite]">
          <div class="mb-6 pb-6 border-b border-emerald-50">
            <div class="text-xs font-bold uppercase tracking-widest text-emerald-900/50 mb-4">From the team</div>
            <p class="font-serif text-2xl italic text-emerald-950 leading-relaxed mb-6">"I joined Quranific because I saw parents crying in WhatsApp groups about failing their children's deen. I wanted to be part of fixing that."</p>
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-purple-600 to-purple-400 text-white flex items-center justify-center font-serif text-xl font-bold shadow-inner" aria-hidden="true">SA</div>
              <div>
                <div class="font-bold text-emerald-950 text-sm">Sara Ahmed</div>
                <div class="text-xs font-medium text-emerald-800/70">Head of Education Â· Joined 2022</div>
              </div>
            </div>
          </div>

          <div>
            <div class="text-xs font-bold uppercase tracking-widest text-emerald-900/50 mb-4">What we stand for</div>
            <div class="space-y-4">
              <div class="flex items-start gap-3"><div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center text-sm shrink-0" aria-hidden="true">ðŸŒ</div><p class="text-sm text-emerald-800/80 font-medium leading-relaxed pt-1.5"><strong class="text-emerald-950">Remote-first,</strong> always â€” no surprise return-to-office policies</p></div>
              <div class="flex items-start gap-3"><div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center text-sm shrink-0" aria-hidden="true">ðŸ§ </div><p class="text-sm text-emerald-800/80 font-medium leading-relaxed pt-1.5"><strong class="text-emerald-950">Mission over metrics</strong> â€” we optimise for families helped, not just revenue</p></div>
              <div class="flex items-start gap-3"><div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center text-sm shrink-0" aria-hidden="true">ðŸ¤</div><p class="text-sm text-emerald-800/80 font-medium leading-relaxed pt-1.5"><strong class="text-emerald-950">Honest culture</strong> â€” we share the hard news internally before the good news</p></div>
              <div class="flex items-start gap-3"><div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center text-sm shrink-0" aria-hidden="true">ðŸŒ™</div><p class="text-sm text-emerald-800/80 font-medium leading-relaxed pt-1.5"><strong class="text-emerald-950">Faith-aware</strong> â€” prayer times, Ramadan, and Eid leave respected instantly</p></div>
            </div>
          </div>
        </div>

      </div>
    </Section>

    <Section height={800} class="py-12 md:py-24 bg-white border-y border-emerald-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 max-w-3xl mx-auto">
          <span class="text-xs font-black tracking-widest uppercase text-emerald-700 block mb-3">Why Quranific</span>
          <h2 class="text-4xl font-bold text-emerald-950 mb-6 tracking-tight">Work that <em class="font-serif italic text-emerald-700 font-medium">means something.</em></h2>
          <p class="text-base text-emerald-900/80 font-medium leading-relaxed">
            We are a small, intentional team. Every person here chose Quranific because the mission resonated with something personal. Here is what makes working here different.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-cream-50 border border-emerald-100 rounded-3xl p-8 hover:-translate-y-1 hover:shadow-xl hover:border-emerald-200 transition-all duration-300 relative overflow-hidden group">
            <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-emerald-700 to-emerald-500 scale-x-0 group-hover:scale-x-100 origin-left transition-transform duration-500" aria-hidden="true"></div>
            <div class="w-14 h-14 rounded-2xl bg-emerald-50 border border-emerald-100 flex items-center justify-center text-2xl mb-6 group-hover:bg-emerald-700 group-hover:text-white transition-colors" aria-hidden="true">ðŸŒ™</div>
            <h3 class="text-lg font-bold text-emerald-950 mb-3">Real impact you can see</h3>
            <p class="text-sm text-emerald-800/80 font-medium leading-relaxed">Every week you will read progress reports from teachers describing a child who used to cry before Quran class â€” and now asks to start early. That is not abstract. That is the work you will be contributing to, directly.</p>
          </div>

          <div class="bg-cream-50 border border-emerald-100 rounded-3xl p-8 hover:-translate-y-1 hover:shadow-xl hover:border-emerald-200 transition-all duration-300 relative overflow-hidden group">
