---
// src/pages/blog/index.astro
import Base from '../../layouts/Base.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';
import Section from '../../components/ui/Section.astro';
import { getCollection } from 'astro:content';

// Safely fetch posts and sort by date. 
const allPosts = (await getCollection('blog')) || [];
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

const hasPosts = sortedPosts.length > 0;
const featuredPost = hasPosts ? sortedPosts[0] : null;
const regularPosts = hasPosts ? sortedPosts.slice(1) : [];

// Extracted SVG icons
const Icons = {
  pen: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>`,
  imagePlaceholder: `<svg class="w-12 h-12 text-emerald-500/30" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
  imagePlaceholderLarge: `<svg class="w-20 h-20 text-emerald-500/30" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "The Quranific Blog",
  "description": "Insights, guides, and inspiration for your Quranic journey.",
  "publisher": {
    "@type": "Organization",
    "name": "Quranific"
  }
};
---

<Base title="Blog | Quranific - Insights on Quran & Tajweed" description="Read the latest articles, guides, and insights from our expert Quran tutors.">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" is:inline />
  
  <Header />

  <main class="min-h-screen bg-gradient-to-b from-cream-50 to-white pt-16 md:pt-32 pb-12 md:pb-24 lg:pt-40 lg:pb-32 selection:bg-emerald-200 selection:text-emerald-950 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="max-w-3xl mb-16 animate-in fade-in slide-in-from-bottom-4 duration-700">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-emerald-950 mb-6 tracking-tighter text-balance">
          Insights for your<br/>Quranic journey.
        </h1>
        <p class="text-lg text-emerald-800/80 font-medium leading-relaxed">
          Expert advice on Tajweed, memorization strategies, and Islamic parenting from our global faculty of scholars.
        </p>
      </div>

      {!hasPosts ? (
        <div class="w-full bg-emerald-50/50 border-2 border-dashed border-emerald-200 rounded-3xl p-16 text-center animate-in fade-in duration-700 delay-150">
          <div class="w-20 h-20 bg-emerald-100 text-emerald-700 rounded-2xl flex items-center justify-center mx-auto mb-6" aria-hidden="true">
            <span set:html={Icons.pen}></span>
          </div>
          <h2 class="text-2xl font-bold text-emerald-950 mb-2">Publishing Soon</h2>
          <p class="text-emerald-800/80 font-medium max-w-md mx-auto">Our scholars are currently writing high-quality guides. Check back soon for our first publications.</p>
        </div>
      ) : (
        <>
          {featuredPost && (
            <a href={`/blog/${featuredPost.id}`} class="block group mb-16 animate-in fade-in slide-in-from-bottom-8 duration-700 delay-150">
              <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 bg-white rounded-[2rem] p-4 lg:p-6 border border-emerald-100 shadow-sm hover:shadow-xl transition-all duration-300">
                <div class="aspect-video lg:aspect-square w-full bg-emerald-50 rounded-[1.5rem] overflow-hidden relative border border-emerald-100/50">
                  {featuredPost.data.heroImage ? (
                    <img src={featuredPost.data.heroImage} alt={featuredPost.data.title} width="800" height="800" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="eager" />
                  ) : (
                    <div class="absolute inset-0 bg-gradient-to-br from-emerald-800 to-emerald-950 flex items-center justify-center group-hover:scale-105 transition-transform duration-700" aria-hidden="true">
                      <span set:html={Icons.imagePlaceholderLarge}></span>
                    </div>
                  )}
                </div>
                <div class="flex flex-col justify-center py-6 lg:pr-8">
                  <div class="flex items-center gap-3 mb-4">
                    <span class="px-3 py-1 bg-amber-50 border border-amber-200 text-amber-700 text-xs font-bold uppercase tracking-wider rounded-md">Guide</span>
                    <span class="text-sm font-bold text-emerald-700/70">
                      {new Date(featuredPost.data.pubDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                    </span>
                  </div>
                  <h2 class="text-3xl lg:text-4xl font-black text-emerald-950 mb-4 group-hover:text-emerald-700 transition-colors tracking-tight leading-tight">
                    {featuredPost.data.title}
                  </h2>
                  <p class="text-emerald-800/80 text-lg font-medium leading-relaxed mb-8">
                    {featuredPost.data.description}
                  </p>
                  <div class="flex items-center gap-3 mt-auto">
                    <div class="w-10 h-10 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-800 font-bold border-2 border-white shadow-sm">
                      {(featuredPost.data.author || 'Q').charAt(0)}
                    </div>
                    <span class="font-bold text-emerald-950 text-sm">{featuredPost.data.author || 'Quranific Editorial'}</span>
                  </div>
                </div>
              </div>
            </a>
          )}

          <Section height={800}>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
              {regularPosts.map((post) => (
                <a href={`/blog/${post.id}`} class="group flex flex-col bg-white rounded-3xl border border-emerald-100 shadow-sm hover:shadow-xl transition-all duration-300 p-4">
                  <div class="aspect-video w-full bg-emerald-50 border border-emerald-100/50 rounded-2xl mb-6 overflow-hidden relative shrink-0">
                    {post.data.heroImage ? (
                      <img src={post.data.heroImage} alt={post.data.title} width="800" height="450" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                    ) : (
                      <div class="absolute inset-0 bg-emerald-900 flex items-center justify-center group-hover:scale-105 transition-transform duration-500" aria-hidden="true">
                        <span set:html={Icons.imagePlaceholder}></span>
                      </div>
                    )}
                  </div>
                  <div class="flex-1 flex flex-col px-2">
                    <div class="text-xs font-bold text-emerald-700/70 mb-3 uppercase tracking-wider">
                      {new Date(post.data.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                    </div>
                    <h3 class="text-xl font-bold text-emerald-950 mb-3 group-hover:text-emerald-700 transition-colors leading-snug">
                      {post.data.title}
                    </h3>
                    <p class="text-emerald-800/80 text-sm font-medium leading-relaxed mb-6 line-clamp-2">
                      {post.data.description}
                    </p>
                    <div class="mt-auto font-bold text-emerald-950 text-sm flex items-center gap-2">
                      Read Article <span class="group-hover:translate-x-1 transition-transform text-emerald-600" aria-hidden="true">→</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </Section>
        </>
      )}

    </div>
  </main>

  <Footer />
</Base>