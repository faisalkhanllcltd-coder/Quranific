---
// src/pages/how-it-works.astro
import Base from '../layouts/Base.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';

// SECURITY & MAINTENANCE FIX: Import canonical SITE data for WhatsApp links
import { SITE } from '../constants/site';

// Elite Edge SEO: HowTo Schema for Google Rich Snippets
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "How It Works - Quranific",
    "description": "Discover exactly how our online Quran classes work. From booking a free trial to your child's first live session and weekly progress reports."
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to Start Online Quran Classes with Quranific",
    "description": "A simple four-step process to start personalized 1-on-1 online Quran classes for your child.",
    "step": [
      {
        "@type": "HowToStep",
        "name": "Fill in a 2-minute form",
        "text": "Provide your child's name, age, level, and preferred time slots. No credit card required."
      },
      {
        "@type": "HowToStep",
        "name": "We hand-pick your child's teacher",
        "text": "Within 3 to 6 hours, we manually match your child with a certified teacher and send you their full profile."
      },
      {
        "@type": "HowToStep",
        "name": "Your child attends their first live session",
        "text": "Join a secure, private 1-on-1 video session from any device. The session lasts 30 minutes."
      },
      {
        "@type": "HowToStep",
        "name": "You receive a full progress report",
        "text": "Within 30 minutes of the session ending, receive a detailed progress report in your email."
      }
    ]
  }
];

// Reusable SVGs
const Check = `<svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`;

---

<Base 
  title="How It Works — Quranific | Simple, honest, no surprises." 
  description="Discover exactly how our online Quran classes work. From booking a free trial to your child's first live session and weekly progress reports."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" is:inline />

  <Header />

  <main id="main-content" class="bg-cream-50 selection:bg-emerald-100 selection:text-emerald-900 font-sans overflow-hidden">
    
    <Section height={600} class="pt-16 md:pt-32 pb-10 md:pb-20 lg:pt-48 lg:pb-32 px-4 sm:px-6 relative">
      <div class="absolute top-[-10%] right-[-5%] w-[500px] h-[500px] bg-amber-500/10 rounded-full blur-[100px] pointer-events-none"></div>
      <div class="absolute bottom-[-10%] left-[-5%] w-[400px] h-[400px] bg-emerald-700/10 rounded-full blur-[100px] pointer-events-none"></div>

      <div class="max-w-7xl mx-auto grid lg:grid-cols-[1fr_1fr] gap-12 lg:gap-20 items-center relative z-10">
        
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-emerald-50 border border-emerald-100 text-emerald-700 text-xs font-bold uppercase tracking-widest rounded-full mb-6 shadow-sm">
            <span class="w-2 h-2 rounded-full bg-emerald-700 animate-pulse" aria-hidden="true"></span>
            Signup to first lesson in 24 hours
          </div>
          
          <h1 class="text-5xl lg:text-[4rem] font-bold text-emerald-950 leading-[1.05] tracking-tight mb-6">
            Simple, honest,<br/>
            <em class="font-serif italic text-emerald-700 font-medium">no surprises.</em>
          </h1>
          
          <p class="text-lg text-emerald-900/80 font-medium leading-relaxed mb-10 max-w-lg">
            We have designed every step of the Quranific experience to feel easy, transparent, and warm — from your first click to your child's first confident recitation.
          </p>

          <div class="flex flex-col sm:flex-row items-center gap-4 mb-10">
            <Button href="/funnel/signup" variant="primary" class="w-full sm:w-auto">
              Book Your Free Class →
            </Button>
            <Button href={`https://wa.me/${SITE.whatsappNumber.replace(/\D/g, '')}`} target="_blank" variant="ghost" class="w-full sm:w-auto">
              Have a question?
            </Button>
          </div>

          <div class="flex items-center gap-4 pt-6 border-t border-emerald-100">
            <div class="flex -space-x-3">
              <div class="w-10 h-10 rounded-full border-2 border-cream-50 bg-gradient-to-br from-emerald-700 to-emerald-500 flex items-center justify-center text-white text-[10px] font-bold">SA</div>
              <div class="w-10 h-10 rounded-full border-2 border-cream-50 bg-gradient-to-br from-purple-600 to-purple-400 flex items-center justify-center text-white text-[10px] font-bold">KH</div>
              <div class="w-10 h-10 rounded-full border-2 border-cream-50 bg-gradient-to-br from-amber-500 to-amber-400 flex items-center justify-center text-white text-[10px] font-bold">NM</div>
              <div class="w-10 h-10 rounded-full border-2 border-cream-50 bg-gradient-to-br from-cyan-600 to-cyan-400 flex items-center justify-center text-white text-[10px] font-bold">AR</div>
            </div>
            <p class="text-[13px] text-emerald-900/70 font-medium"><strong class="text-emerald-950 font-bold">3,200+ families</strong> have already started this journey</p>
          </div>
        </div>

        <div class="bg-white rounded-3xl shadow-xl shadow-emerald-900/10 border border-emerald-100 p-8 transform lg:-rotate-1 hover:rotate-0 transition-transform duration-700 animate-[flyY_6s_ease-in-out_infinite]">
          <div class="flex items-center justify-between mb-8 pb-6 border-b border-emerald-50">
            <div>
              <h2 class="text-lg font-bold text-emerald-950">Your journey to first lesson</h2>
              <p class="text-xs font-medium text-emerald-800/80 mt-1">Average time: under 24 hours</p>
            </div>
            <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-green-50 border border-green-200 text-green-600 text-[10px] font-bold uppercase tracking-wider rounded-full">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full animate-pulse" aria-hidden="true"></span> In progress
            </div>
          </div>

          <div class="space-y-6 relative">
            <div class="absolute left-[17px] top-[20px] bottom-[30px] w-0.5 bg-gradient-to-b from-emerald-700 via-amber-500 to-slate-200" aria-hidden="true"></div>
            
            <div class="flex gap-5 relative z-10">
              <div class="w-9 h-9 rounded-full bg-emerald-700 text-white flex items-center justify-center font-bold text-sm shrink-0" set:html={Check}></div>
              <div>
                <h3 class="font-bold text-emerald-950 text-sm">You book the free class</h3>
                <p class="text-[11px] text-emerald-900/70 font-medium mb-1.5">2-minute form. No credit card. No commitment.</p>
                <span class="inline-block px-2 py-0.5 bg-emerald-50 text-emerald-700 text-[10px] font-bold rounded-md">✓ Complete · 2 mins</span>
              </div>
            </div>
            <div class="flex gap-5 relative z-10">
              <div class="w-9 h-9 rounded-full bg-emerald-700 text-white flex items-center justify-center font-bold text-sm shrink-0" set:html={Check}></div>
              <div>
                <h3 class="font-bold text-emerald-950 text-sm">We match your child to a teacher</h3>
                <p class="text-[11px] text-emerald-900/70 font-medium mb-1.5">Hand-selected based on age, level and personality notes.</p>
                <span class="inline-block px-2 py-0.5 bg-emerald-50 text-emerald-700 text-[10px] font-bold rounded-md">✓ Complete · 3 hours</span>
              </div>
            </div>
            <div class="flex gap-5 relative z-10">
              <div class="w-9 h-9 rounded-full bg-amber-500 text-white flex items-center justify-center font-bold text-sm shrink-0 ring-4 ring-amber-500/20 animate-pulse">→</div>
              <div>
                <h3 class="font-bold text-emerald-950 text-sm">You receive the teacher's profile</h3>
                <p class="text-[11px] text-emerald-900/70 font-medium mb-1.5">Certifications, bio, and confirmed session time in your inbox.</p>
                <span class="inline-block px-2 py-0.5 bg-amber-50 border border-amber-200 text-amber-600 text-[10px] font-bold rounded-md">⏳ Happening now</span>
              </div>
            </div>
            <div class="flex gap-5 relative z-10 opacity-50">
              <div class="w-9 h-9 rounded-full bg-white border-2 border-emerald-100 text-emerald-900/70 flex items-center justify-center font-bold text-sm shrink-0">4</div>
              <div>
                <h3 class="font-bold text-emerald-950 text-sm">First free session — live</h3>
                <p class="text-[11px] text-emerald-900/70 font-medium mb-1.5">Your child meets their teacher. You watch progress in real time.</p>
                <span class="inline-block px-2 py-0.5 bg-gray-100 text-gray-500 text-[10px] font-bold rounded-md">⏱ Tomorrow, 4:30 PM</span>
              </div>
            </div>
          </div>
          
          <div class="mt-8 pt-5 border-t border-emerald-50 text-[11px] text-emerald-900/70 font-medium">
            <strong class="text-emerald-950 font-bold block mb-0.5">Zero risk, always</strong>
            First class free. Full refund if unsatisfied in month one.
          </div>
        </div>

      </div>
    </Section>

    <Section height={200} class="bg-white border-y border-emerald-100">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-emerald-100">
          <div class="p-8 text-center hover:bg-emerald-50 transition-colors duration-300">
            <div class="font-serif text-4xl font-bold text-emerald-700 mb-2">2 min</div>
            <div class="text-[13px] font-semibold text-emerald-800/80 uppercase tracking-wide">To book your free class</div>
          </div>
          <div class="p-8 text-center hover:bg-emerald-50 transition-colors duration-300">
            <div class="font-serif text-4xl font-bold text-emerald-700 mb-2">24 hrs</div>
            <div class="text-[13px] font-semibold text-emerald-800/80 uppercase tracking-wide">From signup to first lesson</div>
          </div>
          <div class="p-8 text-center hover:bg-emerald-50 transition-colors duration-300">
            <div class="font-serif text-4xl font-bold text-emerald-700 mb-2">30 min</div>
            <div class="text-[13px] font-semibold text-emerald-800/80 uppercase tracking-wide">Per session — built for children</div>
          </div>
          <div class="p-8 text-center hover:bg-emerald-50 transition-colors duration-300">
            <div class="font-serif text-4xl font-bold text-emerald-700 mb-2">1-on-1</div>
            <div class="text-[13px] font-semibold text-emerald-800/80 uppercase tracking-wide">Always — no group classes</div>
          </div>
        </div>
      </div>
    </Section>

    <Section height={900} class="py-12 md:py-24 lg:py-32 bg-cream-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-20 max-w-3xl mx-auto">
          <span class="text-xs font-black tracking-widest uppercase text-emerald-700 block mb-3">The Four Steps</span>
          <h2 class="text-4xl lg:text-5xl font-bold text-emerald-950 mb-6 tracking-tight">Every step, <em class="font-serif italic text-emerald-700 font-medium">explained honestly.</em></h2>
          <p class="text-lg text-emerald-900/80 font-medium">No hidden steps. No surprise fees. Here is exactly what happens from your first click.</p>
        </div>

        <div class="space-y-24 lg:space-y-32">
          
          <div class="grid lg:grid-cols-[1fr_1fr] gap-12 lg:gap-20 items-center">
            <div class="order-1 lg:order-1">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-14 h-14 rounded-full bg-emerald-700 text-white flex items-center justify-center font-serif text-2xl font-bold shadow-[0_0_0_8px_rgba(4,120,87,0.1)]">1</div>
                <div class="text-[11px] font-black uppercase tracking-[0.15em] text-emerald-700">Step One</div>
              </div>
              <h3 class="text-3xl font-bold text-emerald-950 mb-6 leading-tight">You fill in a <em class="font-serif italic text-emerald-700 font-medium">2-minute form.</em></h3>
              <p class="text-[16px] text-emerald-800/80 font-medium leading-relaxed mb-6">
                We ask for your child's name, age, current level, and preferred time slots. <strong class="text-emerald-950">No credit card. No long questionnaire. No account to create.</strong> Just what we need to make the right match. Confirmation arrives in your inbox instantly.
              </p>
              <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-emerald-50 border border-emerald-100 text-emerald-700 text-xs font-bold rounded-full mb-8">⏱ Takes 2 minutes</div>
              <div class="space-y-3">
                <div class="flex items-start gap-3"><div class="w-6 h-6 rounded-md bg-emerald-50 text-emerald-700 flex items-center justify-center shrink-0 text-xs font-bold" set:html={Check}></div><span class="text-[15px] font-medium text-emerald-900/80">No payment details needed at this stage</span></div>
                <div class="flex items-start gap-3"><div class="w-6 h-6 rounded-md bg-emerald-50 text-emerald-700 flex items-center justify-center shrink-0 text-xs font-bold" set:html={Check}></div><span class="text-[15px] font-medium text-emerald-900/80">Add notes on your child's personality or special needs</span></div>
                <div class="flex items-start gap-3"><div class="w-6 h-6 rounded-md bg-emerald-50 text-emerald-700 flex items-center justify-center shrink-0 text-xs font-bold" set:html={Check}></div><span class="text-[15px] font-medium text-emerald-900/80">Choose 3 preferred time slots — we confirm the best fit</span></div>
              </div>
            </div>
            <div class="order-2 lg:order-2">
              <div class="bg-white border border-emerald-100 rounded-3xl p-8 shadow-xl shadow-emerald-900/5">
                <div class="space-y-4 mb-6">
                  <div>
                    <div class="text-[11px] font-bold uppercase tracking-wider text-emerald-900/70 mb-1.5">Child's name</div>
                    <input type="text" value="Yusuf" class="w-full bg-cream-50 border border-emerald-100 rounded-lg px-4 py-2.5 text-sm font-bold text-emerald-950 outline-none" readonly>
                  </div>
                  <div class="grid grid-cols-2 gap-4">
                    <div>
                      <div class="text-[11px] font-bold uppercase tracking-wider text-emerald-900/70 mb-1.5">Age</div>
                      <div class="w-full bg-cream-50 border border-emerald-100 rounded-lg px-4 py-2.5 text-sm font-medium text-emerald-950">9 years old</div>
                    </div>
                    <div>
                      <div class="text-[11px] font-bold uppercase tracking-wider text-emerald-900/70 mb-1.5">Level</div>
                      <div class="w-full bg-cream-50 border border-emerald-100 rounded-lg px-4 py-2.5 text-sm font-medium text-emerald-950">Beginner</div>
                    </div>
                  </div>
                </div>
                <div class="mb-6">
                  <div class="text-[11px] font-bold uppercase tracking-wider text-emerald-900/70 mb-2">Pick 3 preferred time slots</div>
                  <div class="grid grid-cols-3 gap-2">
                    <div class="slot-btn bg-emerald-700 border-emerald-700 text-white text-xs font-bold text-center py-2.5 rounded-lg border cursor-pointer select-none">Mon 4pm</div>
                    <div class="slot-btn bg-cream-50 border-emerald-100 text-emerald-900/80 text-xs font-bold text-center py-2.5 rounded-lg border cursor-pointer select-none hover:bg-emerald-50 hover:border-emerald-700 hover:text-emerald-700 transition-[color,background-color,border-color,box-shadow,opacity,transform]">Mon 6pm</div>
                    <div class="slot-btn bg-emerald-700 border-emerald-700 text-white text-xs font-bold text-center py-2.5 rounded-lg border cursor-pointer select-none">Wed 4pm</div>
                    <div class="slot-btn bg-cream-50 border-emerald-100 text-emerald-900/80 text-xs font-bold text-center py-2.5 rounded-lg border cursor-pointer select-none hover:bg-emerald-50 hover:border-emerald-700 hover:text-emerald-700 transition-[color,background-color,border-color,box-shadow,opacity,transform]">Thu 5pm</div>
                    <div class="bg-cream-50 border-emerald-100 text-emerald-900/70 text-xs font-bold text-center py-2.5 rounded-lg border opacity-50 cursor-not-allowed">Fri 4pm</div>
                    <div class="slot-btn bg-emerald-700 border-emerald-700 text-white text-xs font-bold text-center py-2.5 rounded-lg border cursor-pointer select-none">Sat 10am</div>
                  </div>
                </div>
                <Button variant="primary" class="w-full" onclick="event.currentTarget.textContent='Booked! ✓'">Book Your Free Class →</Button>
                <div class="text-center text-xs font-medium text-emerald-900/70 mt-3">No credit card · No commitment · Cancel anytime</div>
              </div>
            </div>
          </div>

          <div class="grid lg:grid-cols-[1fr_1fr] gap-12 lg:gap-20 items-center">
            <div class="order-1 lg:order-2">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-14 h-14 rounded-full bg-emerald-700 text-white flex items-center justify-center font-serif text-2xl font-bold shadow-[0_0_0_8px_rgba(4,120,87,0.1)]">2</div>
                <div class="text-[11px] font-black uppercase tracking-[0.15em] text-emerald-700">Step Two</div>
              </div>
              <h3 class="text-3xl font-bold text-emerald-950 mb-6 leading-tight">We hand-pick <em class="font-serif italic text-emerald-700 font-medium">your child's teacher.</em></h3>
              <p class="text-[16px] text-emerald-800/80 font-medium leading-relaxed mb-6">
                This is not an algorithm. A real person on our team reviews your child's profile and selects a teacher based on age-fit, teaching style, and your notes. <strong class="text-emerald-950">Within 3–6 hours you receive the teacher's full profile</strong> — certification, experience, and a confirmed session time.
              </p>
              <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-emerald-50 border border-emerald-100 text-emerald-700 text-xs font-bold rounded-full mb-8">⏱ Within 3–6 hours</div>
              <div class="space-y-3">
                <div class="flex items-start gap-3"><div class="w-6 h-6 rounded-md bg-emerald-50 text-emerald-700 flex items-center justify-center shrink-0 text-xs font-bold" set:html={Check}></div><span class="text-[15px] font-medium text-emerald-900/80">Selected by a human, not a filter</span></div>
                <div class="flex items-start gap-3"><div class="w-6 h-6 rounded-md bg-emerald-50 text-emerald-700 flex items-center justify-center shrink-0 text-xs font-bold" set:html={Check}></div><span class="text-[15px] font-medium text-emerald-900/80">Full ijazah credentials shared before the session</span></div>
                <div class="flex items-start gap-3"><div class="w-6 h-6 rounded-md bg-emerald-50 text-emerald-700 flex items-center justify-center shrink-0 text-xs font-bold" set:html={Check}></div><span class="text-[15px] font-medium text-emerald-900/80">Don't like the match? We find a new one the same day</span></div>
              </div>
            </div>
            <div class="order-2 lg:order-1">
              <div class="bg-white border border-emerald-100 rounded-3xl p-8 shadow-xl shadow-emerald-900/5">
                <div class="flex items-center gap-4 mb-6">
                  <div class="w-12 h-12 rounded-xl bg-amber-50 border border-amber-200 flex items-center justify-center text-xl shrink-0" aria-hidden="true">🤝</div>
                  <div>
                    <h4 class="font-bold text-emerald-950 text-sm">Your teacher match is ready</h4>
                    <p class="text-xs text-emerald-900/70 font-medium">Based on Yusuf's age, level and schedule</p>
                  </div>
                </div>
                <div class="bg-emerald-50/50 border border-emerald-100 rounded-2xl p-5 mb-5">
                  <div class="flex items-center gap-4 mb-4">
                    <div class="w-14 h-14 rounded-full bg-gradient-to-br from-emerald-700 to-emerald-500 text-white flex items-center justify-center font-serif text-2xl font-bold shrink-0">ف</div>
                    <div>
                      <div class="font-bold text-emerald-950 text-[15px] mb-0.5">Ustadha Fatima K.</div>
                      <div class="text-xs text-emerald-800/80 font-medium">Hafiza · Ijazah certified · 6 yrs experience</div>
                    </div>
                  </div>
                  <div class="flex flex-wrap gap-2 mb-4">
                    <span class="px-2.5 py-1 bg-white border border-emerald-100 text-emerald-900/80 text-[10px] font-bold rounded-full">Ages 5–12</span>
                    <span class="px-2.5 py-1 bg-white border border-emerald-100 text-emerald-900/80 text-[10px] font-bold rounded-full">Beginners specialist</span>
                    <span class="px-2.5 py-1 bg-white border border-emerald-100 text-emerald-900/80 text-[10px] font-bold rounded-full">Patience-first</span>
                  </div>
                  <div class="pt-4 border-t border-emerald-100 flex justify-between items-center">
                    <span class="text-xs font-medium text-emerald-900/70">Compatibility score for Yusuf</span>
                    <span class="text-sm font-bold text-emerald-700">97% match ✓</span>
                  </div>
                </div>
                <div class="bg-emerald-700 rounded-xl p-4 flex items-start gap-3">
                  <div class="text-white" aria-hidden="true">✅</div>
                  <div>
                    <strong class="text-white text-sm block mb-0.5">First session confirmed</strong>
                    <span class="text-emerald-50/90 text-xs font-medium">Wednesday, 4:30 PM · 30 mins · Free trial</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="grid lg:grid-cols-[1fr_1fr] gap-12 lg:gap-20 items-center">
            <div class="order-1 lg:order-1">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-14 h-14 rounded-full bg-emerald-700 text-white flex items-center justify-center font-serif text-2xl font-bold shadow-[0_0_0_8px_rgba(4,120,87,0.1)]">3</div>
                <div class="text-[11px] font-black uppercase tracking-[0.15em] text-emerald-700">Step Three</div>
              </div>
              <h3 class="text-3xl font-bold text-emerald-950 mb-6 leading-tight">Your child attends <em class="font-serif italic text-emerald-700 font-medium">their first live session.</em></h3>
              <p class="text-[16px] text-emerald-800/80 font-medium leading-relaxed mb-6">
                You receive a secure private link before the session. Your child joins from any device — no app download required. <strong class="text-emerald-950">The session is 1-on-1: your child and their teacher, nobody else.</strong> You're welcome to sit in the room. Sessions run 30 minutes — built for children's attention spans.
              </p>
              <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-emerald-50 border border-emerald-100 text-emerald-700 text-xs font-bold rounded-full mb-8">⏱ 30 minutes · 1-on-1</div>
              <div class="space-y-3">
                <div class="flex items-start gap-3"><div class="w-6 h-6 rounded-md bg-emerald-50 text-emerald-700 flex items-center justify-center shrink-0 text-xs font-bold" set:html={Check}></div><span class="text-[15px] font-medium text-emerald-900/80">Works on any device — no app download required</span></div>
                <div class="flex items-start gap-3"><div class="w-6 h-6 rounded-md bg-emerald-50 text-emerald-700 flex items-center justify-center shrink-0 text-xs font-bold" set:html={Check}></div><span class="text-[15px] font-medium text-emerald-900/80">Sit in without notice — teacher always welcomes it</span></div>
                <div class="flex items-start gap-3"><div class="w-6 h-6 rounded-md bg-emerald-50 text-emerald-700 flex items-center justify-center shrink-0 text-xs font-bold" set:html={Check}></div><span class="text-[15px] font-medium text-emerald-900/80">Progress report sent within 30 minutes of session ending</span></div>
              </div>
            </div>
            <div class="order-2 lg:order-2">
              <div class="bg-white border border-emerald-100 rounded-3xl p-8 shadow-xl shadow-emerald-900/5">
