    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/amiri": "^5.2.8",
    "@fontsource/merriweather": "^5.2.11",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^6.0.8",
    "jose": "^6.2.1",
    "lucide-svelte": "^1.0.1",
    "resend": "^4.8.0",
    "svelte": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@cloudflare/workers-types": "^4.20241112.0",
