      if (waTyping && !(waTyping as HTMLElement).dataset.bound) {
        (waTyping as HTMLElement).dataset.bound = 'true';
        setTimeout(() => {
          const replyMsg = document.getElementById('wa-reply');
          if (waTyping && replyMsg) {
            waTyping.style.display = 'flex';
            setTimeout(() => {
              waTyping.style.display = 'none';
              replyMsg.style.display = 'block';
            }, 2000);
          }
        }, 3500);
