          document.querySelectorAll<HTMLButtonElement>('.topic-btn').forEach(b => {
            b.classList.remove('bg-emerald-50', 'border-emerald-700', 'border-2');
            b.classList.add('bg-cream-50', 'border-emerald-100');
            b.setAttribute('aria-pressed', 'false');        // E-3 FIX
            const icon = b.querySelector('.topic-icon');
            if (icon) {
              icon.classList.remove('border-emerald-100');
              icon.classList.add('border-emerald-50');
            }
          });

          // Activate clicked button
          this.classList.remove('bg-cream-50', 'border-emerald-100');
          this.classList.add('bg-emerald-50', 'border-2', 'border-emerald-700');
          this.setAttribute('aria-pressed', 'true');         // E-3 FIX
          const thisIcon = this.querySelector('.topic-icon');
          if (thisIcon) {
            thisIcon.classList.replace('border-emerald-50', 'border-emerald-100');
          }

          const topic = this.getAttribute('data-topic');
          if (topic && topicCopy[topic]) {
            const copy = topicCopy[topic];

            const titleEl = document.getElementById('form-dynamic-title');
            if (titleEl) titleEl.textContent = copy.title;

            const subEl = document.getElementById('form-dynamic-sub');
            if (subEl) subEl.textContent = copy.sub;

            const msgEl = document.getElementById('fc-message') as HTMLTextAreaElement;
            if (msgEl) msgEl.placeholder = copy.msg;

            const childSection = document.getElementById('dynamic-child-field');
            if (childSection) {
              childSection.style.display = (topic === 'enrol' || topic === 'existing') ? 'block' : 'none';
            }
          }
        });
      });

      // --- 3. URGENCY TOGGLE (E-2 FIX) ---
      // Now a <button role="checkbox"> — aria-checked is toggled for screen readers
      const urgencyToggle = document.getElementById('urgency-toggle') as HTMLButtonElement | null;
      if (urgencyToggle && !(urgencyToggle as HTMLElement).dataset.bound) {
        (urgencyToggle as HTMLElement).dataset.bound = 'true';

        urgencyToggle.addEventListener('click', () => {
          const isNowUrgent = urgencyToggle.getAttribute('aria-checked') !== 'true';
          urgencyToggle.setAttribute('aria-checked', isNowUrgent ? 'true' : 'false'); // E-2 FIX

          const check = document.getElementById('urgency-check');
          if (isNowUrgent) {
            urgencyToggle.classList.add('bg-amber-50', 'border-amber-200');
            urgencyToggle.classList.remove('border-emerald-200');
            if (check) {
              check.classList.replace('bg-cream-50', 'bg-amber-500');
              check.classList.replace('border-emerald-200', 'border-amber-500');
              check.classList.replace('text-transparent', 'text-white');
            }
          } else {
            urgencyToggle.classList.remove('bg-amber-50', 'border-amber-200');
            urgencyToggle.classList.add('border-emerald-200');
            if (check) {
              check.classList.replace('bg-amber-500', 'bg-cream-50');
              check.classList.replace('border-amber-500', 'border-emerald-200');
              check.classList.replace('text-white', 'text-transparent');
            }
          }
        });
      }

      // --- 4. SMART FORM SUBMIT (E-1 FIX) ---
      // Form now has action="/api/contact". The handler reads the Turnstile token
      // and sends the full payload as JSON — matching the updated contact API contract.
      const smartForm = document.getElementById('smart-form') as HTMLFormElement | null;
      if (smartForm && !(smartForm as HTMLElement).dataset.bound) {
        (smartForm as HTMLElement).dataset.bound = 'true';

        smartForm.addEventListener('submit', async (e) => {
          e.preventDefault();

          const submitBtn = document.getElementById('form-submit-btn') as HTMLButtonElement;
          const originalBtnText = submitBtn.innerText;
          submitBtn.innerText = 'Sending…';
          submitBtn.disabled = true;

          try {
            // Split name into first/last for the API schema
            const nameInput = (document.getElementById('fc-name') as HTMLInputElement).value.trim();
            const nameParts = nameInput.split(' ');
            const firstName = nameParts[0] || '';
            const lastName  = nameParts.length > 1 ? nameParts.slice(1).join(' ') : 'N/A';

            const email    = (document.getElementById('fc-email')    as HTMLInputElement).value.trim();
            const whatsapp = (document.getElementById('fc-whatsapp') as HTMLInputElement).value.trim();

            const levelSelect = document.getElementById('fc-level') as unknown as HTMLSelectElement;
            const level = levelSelect && levelSelect.offsetParent !== null ? levelSelect.value : '';

            const rawMessage = (document.getElementById('fc-message') as HTMLTextAreaElement).value.trim();
            const isUrgent   = urgencyToggle?.getAttribute('aria-checked') === 'true';

            // Build a comprehensive message string
            let fullMessage = rawMessage;
            if (whatsapp)  fullMessage = `Provided WhatsApp: ${whatsapp}\n\n${fullMessage}`;
            if (level)     fullMessage = `Child Level Context: ${level}\n\n${fullMessage}`;
            if (isUrgent)  fullMessage = `🚨 URGENT PRIORITY 🚨\n\n${fullMessage}`;

            // Read the Turnstile token from the widget
            const turnstileInput = smartForm.querySelector<HTMLInputElement>('[name="cf-turnstile-response"]');
            const turnstileToken = turnstileInput?.value ?? '';

            if (!turnstileToken) {
              submitBtn.innerText = originalBtnText;
              submitBtn.disabled = false;
              alert('Please complete the security check before submitting.');
              return;
            }

            const response = await fetch('/api/contact', {
              method:  'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                firstName,
                lastName,
                email,
                message: fullMessage,
                'cf-turnstile-response': turnstileToken,
              }),
            });

            if (!response.ok) {
              const errData = await response.json().catch((): { error?: string } => ({}));
              throw new Error((errData as { error?: string }).error || 'Submission failed');
            }

            // F-1 FIX: Generate a real client-side reference ID using crypto.randomUUID()
            // with a date-based fallback for older browsers.
            const refId = typeof crypto !== 'undefined' && crypto.randomUUID
              ? 'QRF-' + crypto.randomUUID().toUpperCase().slice(0, 8)
              : 'QRF-' + new Date().getFullYear() + '-' + Math.floor(1000 + Math.random() * 9000);

            // Swap to success state
            smartForm.style.display = 'none';
            const titleEl = document.getElementById('form-dynamic-title');
            if (titleEl) titleEl.style.display = 'none';
            const subEl = document.getElementById('form-dynamic-sub');
            if (subEl) subEl.style.display = 'none';

            const successEmail = document.getElementById('success-email-display');
            if (successEmail) successEmail.textContent = email;

            const successRef = document.getElementById('success-ref-display');
            if (successRef) successRef.textContent = `Ref: ${refId}`;   // F-1 FIX

            const successBlock = document.getElementById('form-success');
            if (successBlock) successBlock.classList.remove('hidden');

          } catch (error: unknown) {
            console.error(error);
            submitBtn.innerText = originalBtnText;
            submitBtn.disabled = false;
            const msg = error instanceof Error ? error.message : 'Network error.';
            alert(`We encountered an error: ${msg}\n\nPlease try again or reach out via WhatsApp.`);
          }
        });
      }

      // --- 5. UTC TODAY HIGHLIGHTER ---
      const days = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
      const today = days[new Date().getUTCDay()];

      document.querySelectorAll('#utc-table > div').forEach(row => {
        if (row.getAttribute('data-day') === today) {
          const badge = row.querySelector('.today-badge');
          if (badge) badge.classList.remove('hidden');
          row.classList.remove('bg-white', 'bg-cream-50');
          row.classList.add('bg-green-50');
        }
      });
    });
  </script>

</Base>