---
// src/pages/legal/privacy.astro
import Base from '../../layouts/Base.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';

const lastUpdated = "March 25, 2026";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Privacy Policy - Quranific",
  "description": "Read our comprehensive privacy policy. Learn how Quranific protects your data, ensures children's safety online, and complies with global privacy laws.",
  "dateModified": "2026-03-25"
};
---

<Base title="Privacy Policy | Quranific" description="How we collect, use, and protect your personal data and ensure the safety of our young learners.">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" is:inline />
  
  <Header />

  <main class="bg-[#fefdf9] min-h-screen selection:bg-[#d1fae5] selection:text-[#064e3b] font-sans pb-32">
    
    <div class="pt-16 md:pt-32 pb-12 lg:pt-40 lg:pb-16 px-4 sm:px-6 border-b border-emerald-100 bg-white">
      <div class="max-w-5xl mx-auto">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-emerald-50 border border-[#d1fae5] text-[#047857] text-xs font-bold uppercase tracking-widest rounded-full mb-6">
          Legal & Compliance
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-[#022c22] tracking-tight mb-6">
          Privacy Policy
        </h1>
        <p class="text-lg text-emerald-700/80 font-medium max-w-3xl">
          At Quranific, we respect your privacy and are committed to protecting your personal data in accordance with global standards, including GDPR, CCPA, and COPPA. <br/>
          <span class="text-sm mt-2 block opacity-70">Last Updated: {lastUpdated}</span>
        </p>
      </div>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-16 space-y-20">
      
      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Information We Collect
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Personal Information</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">We collect your name, email address, phone number (including WhatsApp), and country/time zone during registration to securely schedule classes and manage your account.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Payment Information</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">We do not store your credit card or sensitive banking details on our servers. All financial transactions are processed securely by PCI-compliant third-party gateways (e.g., Stripe, PayPal, Wise).</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Educational Data</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">We record progress reports, class schedules, homework status, and teacher feedback to monitor and improve the student's learning journey.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Usage & Device Data</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">We collect information on how you access our website, including IP address, browser type, operating system, and page interactions to optimize platform performance.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          How We Use Your Data
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Service Delivery & Communication</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">Your data is used to schedule classes, connect you with appropriate teachers, manage your portal, and send class reminders, progress reports, and technical updates.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Platform Improvement & Security</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">We analyze website performance to resolve technical issues. Data is also used to detect and prevent fraudulent activity and unauthorized account access.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Marketing & Advertising</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">We may use adult users' data to provide tailored information about our services. You may opt out at any time. We strictly do not use children's data for marketing purposes.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Children's Privacy (COPPA)
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Verifiable Parental Consent</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">For students under the age of 13 (or 16 in certain jurisdictions), we require verifiable parental consent. Consent is typically verified through the financial transaction required to begin paid classes.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Strict Data Limits</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">We only collect information reasonably necessary for the child to participate in classes, such as first name, age, learning level, and live video/audio strictly during the lesson.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Parental Rights</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">Parents have the absolute right to review, delete, or refuse further collection of their child's data by contacting our privacy team.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Global Advertising & Third Parties
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Advertising Trackers</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">To reach new students globally, we utilize advertising platforms including Google Ads, Meta, TikTok, Pinterest, and Microsoft Ads. These may collect usage data (like IP addresses) to measure campaign effectiveness for adult users.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Service Providers</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">We share data strictly with operational partners bound by confidentiality, including video conferencing tools (Zoom, Google Meet) and secure email/messaging platforms.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Data Protection & Security
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Encryption & Access</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">We use industry-standard SSL encryption for data transmission. Access to personal and educational information is strictly restricted to authorized personnel and your assigned teacher.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">No Selling of Data</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">We do not sell, rent, or trade your personal data to data brokers or third parties for their independent commercial use under any circumstances.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-[#022c22] mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Your Global Data Rights
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Access, Rectification, & Erasure</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">You hold the right to request a copy of your data, correct outdated information, or request the deletion of your personal data (Right to be Forgotten), subject to our legal record-keeping obligations.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-[#047857] mb-2">Opting Out & International Transfers</strong>
            <p class="text-[#064e3b]/80 font-medium leading-relaxed">You may opt out of marketing communications at any time. By using our services, you consent to the secure transfer of your data across international borders to facilitate our global operations.</p>
          </li>
        </ul>
      </section>

      <section class="mt-16 pt-16 border-t border-emerald-100">
        <h2 class="text-3xl font-black text-[#022c22] mb-6 tracking-tight">Contact Our Privacy Team</h2>
        <p class="text-lg text-[#064e3b]/80 font-medium mb-6">If you have questions about this Privacy Policy, wish to exercise your data rights, or have concerns regarding your child's data, please contact us:</p>

        <div class="bg-emerald-50 border border-emerald-100 p-8 rounded-2xl">
          <div class="flex flex-col gap-4">
            <div class="flex items-center gap-4">
              <span class="w-10 h-10 rounded-full bg-[#047857] text-white flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </span>
              <a href="mailto:privacy@quranific.com" class="font-bold text-xl text-[#022c22] hover:text-[#047857] transition-colors">privacy@quranific.com</a>
            </div>
            <div class="flex items-center gap-4">
              <span class="w-10 h-10 rounded-full bg-[#047857] text-white flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"></path></svg>
              </span>
              <a href="https://wa.me/923112112122" target="_blank" rel="noopener" class="font-bold text-xl text-[#022c22] hover:text-[#047857] transition-colors">+92 311 2112122</a>
            </div>
          </div>
        </div>
      </section>

    </div>
  </main>

  <Footer />
</Base>