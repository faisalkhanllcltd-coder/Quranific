---
// src/pages/legal/terms.astro
import Base from '../../layouts/Base.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';

const lastUpdated = "March 25, 2026";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Terms of Service & Safeguarding Policy - Quranific",
  "description": "Read the Quranific Terms of Service. This legally binding agreement covers our code of conduct, safeguarding policies, intellectual property, and dispute resolution.",
  "dateModified": "2026-03-25"
};
---

<Base title="Terms of Service | Quranific" description="The foundational rules, safeguarding policies, and professional boundaries that govern our global learning community.">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" is:inline />
  
  <Header />

  <main class="bg-cream-50 min-h-screen selection:bg-emerald-100 selection:text-emerald-900 font-sans pb-32">
    
    <div class="pt-16 md:pt-32 pb-12 lg:pt-40 lg:pb-16 px-4 sm:px-6 border-b border-emerald-100 bg-white">
      <div class="quranific-container">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-emerald-50 border border-emerald-100 text-emerald-700 text-xs font-bold uppercase tracking-widest rounded-full mb-6">
          Legal & Compliance
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-emerald-950 tracking-tight mb-6">
          Terms of Service & Safeguarding
        </h1>
        <p class="text-lg text-emerald-700/80 font-medium max-w-3xl">
          Welcome to Quranific. These Terms of Service constitute a legally binding agreement between you and Quranific LTD. By accessing our services, you expressly agree to be bound by these Terms.<br/>
          <span class="text-sm mt-2 block opacity-70">Last Updated: {lastUpdated}</span>
        </p>
      </div>
    </div>

    <div class="quranific-container pt-16 space-y-20">
      
      <section>
        <h2 class="text-3xl md:text-4xl font-black text-emerald-950 mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Eligibility & Account Registration
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Age of Majority</strong>
            <p class="text-emerald-900/80 font-medium leading-relaxed">By registering for an account independently, you represent and warrant that you are at least 18 years of age and possess the legal capacity to enter into binding contracts.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Minors & Guardianship</strong>
            <p class="text-emerald-900/80 font-medium leading-relaxed">If the student is a minor, a parent or legal guardian must create the account and agree to these Terms on their behalf. The guardian assumes full responsibility for the minor's conduct during lessons.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Account Security</strong>
            <p class="text-emerald-900/80 font-medium leading-relaxed">You are strictly responsible for maintaining the confidentiality of your credentials. You must immediately notify Quranific of any unauthorized use of your account.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-emerald-950 mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Safeguarding & Professional Boundaries
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Zero Tolerance Policy</strong>
            <p class="text-emerald-900/80 font-medium leading-relaxed">Because we serve minors, we enforce a strict zero tolerance policy regarding the breach of professional boundaries. All communication must remain exclusively within official channels.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Rules for Students & Parents</strong>
            <p class="text-emerald-900/80 font-medium leading-relaxed">Under no circumstances may you request or accept personal phone numbers (including WhatsApp), emails, addresses, or social media profiles from instructors. You may not attempt to hire them privately outside the platform.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Rules for Teachers</strong>
            <p class="text-emerald-900/80 font-medium leading-relaxed">Teachers are strictly prohibited from requesting students' or parents' personal contact information, physical addresses, or financial details. Teachers may not contact students outside official channels.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Reporting Violations</strong>
            <p class="text-emerald-900/80 font-medium leading-relaxed">If anyone attempts to bypass these rules, you must decline the request, screenshot the communication, and immediately report the incident to our privacy and administrative team.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-emerald-950 mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Acceptable Use & Classroom Etiquette
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Conduct & Character</strong>
            <p class="text-emerald-900/80 font-medium leading-relaxed">Harassment, foul language, or discriminatory remarks directed at any student, teacher, or staff member will result in immediate termination of your account without a refund.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Modesty & Dress Code</strong>
            <p class="text-emerald-900/80 font-medium leading-relaxed">Both students and teachers are required to observe modest, appropriate Islamic attire during all video sessions.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Parental Supervision</strong>
            <p class="text-emerald-900/80 font-medium leading-relaxed">We strongly advise that parents or guardians remain present or in close proximity to supervise minors during online lessons to ensure a focused and productive learning environment.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-emerald-950 mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Intellectual Property & Recording
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Prohibition of Recording</strong>
            <p class="text-emerald-900/80 font-medium leading-relaxed">To protect the privacy and modesty of our teachers and students, the recording of live lessons (audio, video, or screen capture) is strictly prohibited without explicit written authorization from Administration.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Ownership of Materials</strong>
            <p class="text-emerald-900/80 font-medium leading-relaxed">The curriculum, teaching methodologies, and digital content provided are the exclusive intellectual property of Quranific LTD. We grant you a limited, non-commercial license to use these materials.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-emerald-950 mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Liability, Disclaimers & Termination
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Educational Outcomes</strong>
            <p class="text-emerald-900/80 font-medium leading-relaxed">Quranic memorization relies heavily on personal dedication and practice. Therefore, Quranific makes no guarantees regarding specific educational or spiritual outcomes.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Technical Disruptions</strong>
            <p class="text-emerald-900/80 font-medium leading-relaxed">We are not liable for missed classes or data loss resulting from third-party software failures (e.g., Zoom outages) or internet provider disruptions on the user's end.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Termination Rights</strong>
            <p class="text-emerald-900/80 font-medium leading-relaxed">Quranific reserves the right to suspend or terminate access immediately, without refund, for violating safeguarding boundaries, classroom etiquette, or failing to remit tuition payments.</p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-3xl md:text-4xl font-black text-emerald-950 mb-8 pb-4 border-b-2 border-emerald-100 tracking-tight">
          Governing Law & Disputes
        </h2>
        <ul class="space-y-6 pl-4 md:pl-8 border-l-2 border-emerald-50">
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Jurisdiction</strong>
            <!-- TODO(owner): confirm -->
            <p class="text-emerald-900/80 font-medium leading-relaxed">These Terms shall be governed by and construed in accordance with the laws of the United Kingdom, without regard to its conflict of law principles.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Mediation First</strong>
            <p class="text-emerald-900/80 font-medium leading-relaxed">In the event of a dispute, both parties agree to first attempt to resolve the issue amicably through good-faith mediation with our support team.</p>
          </li>
          <li class="pl-4">
            <strong class="block text-xl text-emerald-700 mb-2">Statute of Limitations</strong>
            <!-- TODO(owner): confirm -->
            <p class="text-emerald-900/80 font-medium leading-relaxed">Any legal claim or cause of action arising out of your use of Quranific must be filed within one (1) year after such claim arose, or it shall be forever barred.</p>
          </li>
        </ul>
      </section>

      <section class="mt-16 pt-16 border-t border-emerald-100">
        <h2 class="text-3xl font-black text-emerald-950 mb-6 tracking-tight">Contact Administration</h2>
        <p class="text-lg text-emerald-900/80 font-medium mb-6">If you have any questions, concerns, or legal inquiries regarding these Terms of Service, please contact us:</p>

        <div class="bg-emerald-50 border border-emerald-100 p-8 rounded-2xl">
          <div class="flex flex-col gap-4">
            <div class="flex items-center gap-4">
              <span class="w-10 h-10 rounded-full bg-emerald-700 text-white flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </span>
              <a href="mailto:privacy@quranific.com" class="font-bold text-xl text-emerald-950 hover:text-emerald-700 transition-colors">privacy@quranific.com</a>
            </div>
            <div class="flex items-center gap-4">
              <span class="w-10 h-10 rounded-full bg-emerald-700 text-white flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"></path></svg>
              </span>
              <a href="https://wa.me/923112112122" target="_blank" rel="noopener" class="font-bold text-xl text-emerald-950 hover:text-emerald-700 transition-colors">+92 311 2112122</a>
            </div>
          </div>
        </div>
      </section>

    </div>
  </main>

  <Footer />
</Base>