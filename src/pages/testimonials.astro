---
// src/pages/testimonials.astro
import Base from '../layouts/Base.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';

// --- EXPANDED TESTIMONIAL DATA ---
const TESTIMONIALS = [
  {
    name: "Usama Meer",
    role: "Verified Parent & Student",
    location: "Saudi Arabia",
    text: "Two of my daughters are studying Quran with Quranific and we have great experience with them. Their customer support is extraordinary. They always work with you and resolve any issues. I myself am also learning Tajweed and translation through one of their awesome teachers. I recommended Quranific to many of my friends... It is kind of a service of our community now. Two thumbs up.",
    rating: 5
  },
  {
    name: "Amna",
    role: "Verified Adult Learner",
    location: "Germany",
    text: "Studying at Quranific has been a profound experience. With the guidance of my dedicated teacher, I have enhanced my Quran recitation and memorized significant portions. Additionally, I have learned about Islamic Studies, fiqah, and Salah. Memorizing various duas and prayers has improved my linguistic skills and spiritual practice. Overall, Quranific has greatly contributed to my personal and spiritual growth.",
    rating: 5
  },
  {
    name: "Saleem",
    role: "Verified Parent",
    location: "Pakistan",
    text: "Our son has been making steady progress with his teacher. He has learnt to pray too alhamdulillah. The teacher also knows when to be firm with our son and when he needs to be gentle, really glad he understands our son's needs and helping him through the Qaida.",
    rating: 5
  },
  {
    name: "Omar & Fatima",
    role: "Verified Parents",
    location: "United Kingdom",
    text: "We struggled to find a reliable local teacher who could accommodate our work schedules. Quranific's flexibility is a lifesaver. Our kids log in at 6 PM sharp, and their Ustadha is always there waiting with a smile. The progress in their Makharij (pronunciation) is remarkable.",
    rating: 5
  },
  {
    name: "Dr. Ahmed R.",
    role: "Verified Adult Learner",
    location: "United States",
    text: "As a busy physician, my schedule is chaotic. My teacher at Quranific has been incredibly accommodating. I am finally memorizing Surah Al-Baqarah, something I thought I'd never have time for. The 1-on-1 focus means we don't waste a single minute of the session.",
    rating: 5
  },
  {
    name: "Zainab Ali",
    role: "Verified Parent",
    location: "Canada",
    text: "My 7-year-old daughter was previously very shy and intimidated by Quran classes. Her female tutor at Quranific completely changed that. She uses interactive screen sharing and so much positive reinforcement. Now, my daughter reminds ME that it's time for her Quran class!",
    rating: 5
  }
];

// Reusable SVGs mapped for DOM injection
const Icons = {
  starSmall: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>`,
  starMedium: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>`,
  play: `<svg class="w-10 h-10 lg:w-12 lg:h-12 text-white ml-2" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z" /></svg>`,
  check: `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>`,
  arrowRight: `<svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>`
};

// Elite Edge SEO: Upgraded with Review array natively generated from testimonial data
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Quranific",
  "url": "https://quranific.com",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "542"
  },
  "review": TESTIMONIALS.map(t => ({
    "@type": "Review",
    "author": {
      "@type": "Person",
      "name": t.name
    },
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": t.rating,
      "bestRating": "5"
    },
    "reviewBody": t.text
  }))
};
---

<Base 
  title="Testimonials | Success Stories from Quranific Students" 
  description="Read real stories and reviews from parents and students worldwide who have transformed their Quran reading and Tajweed with Quranific."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" is:inline />
  
  <Header />

  <main class="min-h-screen bg-cream-50 selection:bg-emerald-200 selection:text-emerald-950 overflow-hidden">
    
    <section class="pt-16 md:pt-32 pb-16 lg:pt-40 lg:pb-24 px-4 sm:px-6 relative">
      <div class="absolute top-0 right-1/4 w-[600px] h-[600px] bg-amber-400/5 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>
      
      <div class="max-w-4xl mx-auto text-center relative z-10 animate-in fade-in slide-in-from-bottom-8 duration-1000">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-50 text-emerald-800 text-xs font-bold tracking-widest uppercase rounded-full mb-8 border border-emerald-100 shadow-sm">
          <span class="text-amber-500" set:html={Icons.starSmall} aria-hidden="true"></span>
          Trusted Worldwide
        </span>
        
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-emerald-950 mb-6 tracking-tighter leading-[1.1] text-balance">
          Don't just take <br/> our word for it.
        </h1>
        
        <p class="text-lg lg:text-xl text-emerald-700/80 font-medium max-w-2xl mx-auto leading-relaxed text-balance mb-12">
          Discover how families across 100+ countries are building lifelong, meaningful connections with the Holy Quran through our dedicated tutors.
        </p>

        <div class="flex flex-wrap justify-center gap-8 lg:gap-16">
          <div class="text-center">
            <div class="text-4xl font-black text-emerald-800 mb-1">4.9/5</div>
            <div class="flex text-amber-400 justify-center mb-1 text-sm" aria-hidden="true">★★★★★</div>
            <div class="text-xs font-bold text-emerald-600/70 uppercase tracking-wider">Average Rating</div>
          </div>
          <div class="w-px h-16 bg-emerald-100 hidden sm:block" aria-hidden="true"></div>
          <div class="text-center flex flex-col justify-center">
            <div class="text-4xl font-black text-emerald-800 mb-1">50k+</div>
            <div class="text-xs font-bold text-emerald-600/70 uppercase tracking-wider mt-2">Active Students</div>
          </div>
        </div>
      </div>
    </section>

    <Section height={500} class="pb-10 md:pb-20 lg:pb-32 px-4 sm:px-6 relative z-10">
      <div class="max-w-5xl mx-auto">
        <div class="relative w-full aspect-video bg-emerald-950 rounded-[2rem] lg:rounded-[3rem] shadow-2xl border-4 border-white/60 overflow-hidden group cursor-pointer">
          <div class="absolute inset-0 bg-gradient-to-br from-emerald-900 via-emerald-800 to-emerald-950 opacity-90 transition-transform duration-1000 group-hover:scale-105" aria-hidden="true"></div>
          <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0MCIgaGVpZ2h0PSI0MCI+PHBhdGggZD0iTTAgMGg0MHY0MEgweiIgZmlsbD0ibm9uZSIvPPHBhdGggZD0iTTAgMTBoNDBNMTAgMHY0ME0wIDIwaDQwTTIwIDB2NDBNMCAzMGg0ME0zMCAwdjQwIiBzdHJva2U9InJnYmEoMjU1LDI1NSwyNTUsMC4wNSkiIHN0cm9rZS13aWR0aD0iMSIvPjwvc3ZnPg==')] opacity-40" aria-hidden="true"></div>
          
          <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-64 h-64 bg-emerald-700/50 rounded-t-full blur-2xl" aria-hidden="true"></div>
          
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <div class="w-20 h-20 lg:w-24 lg:h-24 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center border border-white/30 group-hover:bg-white/30 group-hover:scale-110 transition-all duration-300 shadow-2xl">
              <span set:html={Icons.play}></span>
            </div>
            <p class="text-white font-bold mt-6 tracking-widest uppercase text-sm drop-shadow-md">Watch The Parent Experience</p>
          </div>

          <div class="absolute top-6 left-6 lg:top-8 lg:left-8 flex gap-3">
            <span class="bg-amber-400 text-emerald-950 text-xs font-black uppercase tracking-wider px-3 py-1.5 rounded-md shadow-sm">Featured Story</span>
          </div>
          <div class="absolute bottom-6 left-6 lg:bottom-8 lg:left-8">
            <h3 class="text-white font-bold text-xl lg:text-2xl drop-shadow-md">"It completely transformed his Tajweed."</h3>
            <p class="text-emerald-100/80 text-sm font-medium mt-1">Sarah & Ibrahim • London, UK</p>
          </div>
        </div>
        <div class="absolute -inset-10 bg-emerald-500/20 blur-[100px] rounded-[4rem] -z-10 pointer-events-none" aria-hidden="true"></div>
      </div>
    </Section>

    <Section height={1200} class="py-12 lg:py-24 px-4 sm:px-6 bg-emerald-50/50 border-t border-emerald-100/50">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-4xl font-black text-emerald-950 mb-4 tracking-tight">Real Words from Real Families</h2>
          <p class="text-lg text-emerald-700/80 font-medium">Explore why families worldwide trust us for quality Quran education.</p>
        </div>

        <div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6">
          {TESTIMONIALS.map((testimonial) => (
            <div class="break-inside-avoid bg-white p-8 rounded-3xl border border-emerald-100 shadow-sm hover:shadow-md transition-shadow relative group">
              
              <div class="absolute top-6 right-8 text-8xl font-serif text-emerald-50 leading-none select-none pointer-events-none group-hover:-translate-y-2 transition-transform duration-500" aria-hidden="true">
                "
              </div>
              
              <div class="relative z-10">
                <div class="flex mb-6 text-sm" aria-label={`Rating: ${testimonial.rating} out of 5 stars`}>
                  {[...Array(5)].map((_, i) => (
                    <span 
                      class={i < testimonial.rating ? 'text-amber-400' : 'text-gray-300'} 
                      set:html={Icons.starMedium} 
                    ></span>
                  ))}
                </div>
                
                <p class="text-emerald-900/80 text-base font-medium leading-relaxed mb-8">
                  "{testimonial.text}"
                </p>
                
                <div class="flex items-center gap-4 pt-6 border-t border-emerald-50">
                  <div class="w-12 h-12 bg-emerald-100 text-emerald-700 rounded-full flex items-center justify-center font-black text-lg shrink-0" aria-hidden="true">
                    {testimonial.name[0]}
                  </div>
                  <div>
                    <p class="font-bold text-emerald-950 text-base">{testimonial.name}</p>
                    <div class="flex items-center gap-2 mt-0.5">
                      <span class="text-emerald-500" set:html={Icons.check}></span>
                      <p class="text-xs font-bold text-emerald-700/80 uppercase tracking-wider">{testimonial.role} • {testimonial.location}</p>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          ))}
        </div>
      </div>
    </Section>

    <Section height={400} class="py-12 md:py-24 px-4 sm:px-6 relative z-10">
      <div class="max-w-4xl mx-auto bg-gradient-to-br from-emerald-800 to-emerald-950 rounded-3xl p-10 lg:p-16 text-center shadow-xl border border-emerald-800 relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-64 h-64 bg-amber-400/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none transition-transform duration-700 group-hover:scale-110" aria-hidden="true"></div>
        
        <div class="relative z-10">
          <h2 class="text-3xl lg:text-4xl font-black text-white mb-4 tracking-tight">Ready to write your own success story?</h2>
          <p class="text-emerald-100/90 mb-10 text-lg max-w-xl mx-auto font-medium">
            Join the global community of students who have completely transformed their connection to the Book of Allah.
          </p>
          <div class="flex flex-col sm:flex-row justify-center gap-4">
            <Button href="/funnel/signup" variant="white" class="text-lg px-10 group">
              Start Your Free Trial
              <span set:html={Icons.arrowRight}></span>
            </Button>
          </div>
        </div>
      </div>
    </Section>

  </main>

  <Footer />
</Base>