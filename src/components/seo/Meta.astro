---
// src/components/seo/Meta.astro
import { SITE } from '../../constants/site';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'profile';
}

const { 
  title = SITE.title, 
  description = SITE.description, 
  image = SITE.defaultImage,
  type = 'website'
} = Astro.props;

// CRITICAL FIX: Safe URL resolution fallback to prevent Edge crashes
const siteDomain = Astro.site || new URL(SITE.url);

// Edge SEO: Generate a pristine Canonical URL (strips trailing slashes to prevent duplicate content indexing)
const canonicalURL = new URL(Astro.url.pathname, siteDomain);
const canonicalString = canonicalURL.href.replace(/\/$/, '');

// Resolve the OpenGraph image against the site root safely
const ogImage = new URL(image, siteDomain);
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalString} />

<meta name="theme-color" content={SITE.themeColor} />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />

<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalString} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage.toString()} />
<meta property="og:site_name" content={SITE.name} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalString} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImage.toString()} />

<link rel="dns-prefetch" href={SITE.url} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />