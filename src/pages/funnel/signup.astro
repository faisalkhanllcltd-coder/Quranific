---
// src/pages/funnel/signup.astro
import Funnel from '../../layouts/Funnel.astro';
import SignupForm from '../../components/funnel/SignupForm.svelte';
import StepIndicator from '../../components/funnel/StepIndicator.svelte';
---
<Funnel title="Sign Up - Step 1 | Quranific">
  <div class="w-full flex flex-col items-center justify-center animate-in fade-in slide-in-from-bottom-4 duration-700">
    
    <div class="w-full mb-4">
      <StepIndicator currentStep={1} client:load />
    </div>
    
    <div class="text-center mb-6">
      <h1 class="text-2xl lg:text-3xl font-black text-emerald-950 tracking-tight mb-1">
        Start Your Journey
      </h1>
      <p class="text-sm lg:text-base text-emerald-700/80 font-medium">
        Step 1: Let's get to know you
      </p>
    </div>
    
    <div class="w-full">
      <SignupForm client:load />
    </div>
    
  </div>
</Funnel>