---
// src/components/sections/ContactForm.astro
// Standalone, edge-optimized contact form with built-in async submission states.
import { ENV } from '../../lib/env';
---

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>

<div class="relative w-full max-w-2xl mx-auto">
  <div id="form-message" class="hidden rounded-xl p-4 mb-6 text-sm font-medium"></div>

  <form id="standalone-contact-form" class="bg-white border border-emerald-100 rounded-3xl p-6 sm:p-8 shadow-xl shadow-emerald-900/5 flex flex-col gap-6 relative overflow-hidden" action="/api/contact" method="POST">
    
    <div id="form-success-overlay" class="absolute inset-0 bg-white/95 backdrop-blur-md z-20 hidden flex-col items-center justify-center text-center px-8 opacity-0 transition-opacity duration-500">
      <div class="w-16 h-16 bg-emerald-50 text-emerald-600 rounded-full flex items-center justify-center text-2xl mb-4 shadow-sm" aria-hidden="true">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
      </div>
      <h3 class="text-2xl font-bold text-emerald-950 mb-2">Message Sent</h3>
      <p class="text-sm font-medium text-emerald-800/80">Alhamdulillah, we've received your message. Our team will email you within 24 hours.</p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      <div class="flex flex-col gap-2">
        <label for="firstName" class="text-xs font-bold uppercase tracking-wider text-emerald-950/80">First Name <span class="text-amber-500">*</span></label>
        <input type="text" id="firstName" name="firstName" autocomplete="given-name" required class="w-full bg-[#fefdf9] border border-emerald-100 rounded-xl px-4 py-3 text-base sm:text-sm font-medium text-emerald-950 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 focus:border-emerald-400 transition-all duration-300 placeholder:text-emerald-900/30" placeholder="Yusuf" />
      </div>
      <div class="flex flex-col gap-2">
        <label for="lastName" class="text-xs font-bold uppercase tracking-wider text-emerald-950/80">Last Name <span class="text-amber-500">*</span></label>
        <input type="text" id="lastName" name="lastName" autocomplete="family-name" required class="w-full bg-[#fefdf9] border border-emerald-100 rounded-xl px-4 py-3 text-base sm:text-sm font-medium text-emerald-950 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 focus:border-emerald-400 transition-all duration-300 placeholder:text-emerald-900/30" placeholder="Ali" />
      </div>
    </div>
    
    <div class="flex flex-col gap-2">
      <label for="email" class="text-xs font-bold uppercase tracking-wider text-emerald-950/80">Email Address <span class="text-amber-500">*</span></label>
      <input type="email" id="email" name="email" autocomplete="email" required class="w-full bg-[#fefdf9] border border-emerald-100 rounded-xl px-4 py-3 text-base sm:text-sm font-medium text-emerald-950 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 focus:border-emerald-400 transition-all duration-300 placeholder:text-emerald-900/30" placeholder="you@example.com" />
    </div>
    
    <div class="flex flex-col gap-2">
      <label for="message" class="text-xs font-bold uppercase tracking-wider text-emerald-950/80">How can we help? <span class="text-amber-500">*</span></label>
      <textarea id="message" name="message" rows="4" required class="w-full bg-[#fefdf9] border border-emerald-100 rounded-xl px-4 py-3 text-base sm:text-sm font-medium text-emerald-950 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 focus:border-emerald-400 transition-all duration-300 resize-y min-h-[120px] placeholder:text-emerald-900/30" placeholder="Tell us what you need assistance with..."></textarea>
    </div>

    <div class="cf-turnstile mt-4" data-sitekey={ENV.TURNSTILE_SITE_KEY}></div>
    
    <button type="submit" id="submit-btn" class="relative w-full bg-emerald-700 text-white font-bold py-3.5 rounded-xl hover:bg-emerald-800 transition-all duration-300 shadow-md mt-2 overflow-hidden flex items-center justify-center group disabled:opacity-70 disabled:cursor-not-allowed">
      <span id="btn-text" class="transition-opacity duration-300">Send Message →</span>
      
      <svg id="btn-spinner" class="hidden absolute w-5 h-5 text-white animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    </button>
  </form>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('standalone-contact-form') as HTMLFormElement;
    if (!form || (form as any).dataset.bound) return;
    (form as any).dataset.bound = 'true';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const btn = document.getElementById('submit-btn') as HTMLButtonElement;
      const btnText = document.getElementById('btn-text');
      const btnSpinner = document.getElementById('btn-spinner');
      const overlay = document.getElementById('form-success-overlay');
      const messageBox = document.getElementById('form-message');

      if (!btn || !btnText || !btnSpinner || !overlay || !messageBox) return;

      const formData = new FormData(form);
      const token = formData.get('cf-turnstile-response');

      if (!token) {
        messageBox.textContent = 'Please complete the security check.';
        messageBox.className = 'rounded-xl p-4 mb-6 text-sm font-medium bg-red-50 text-red-600 border border-red-200 block';
        return;
      }

      btn.disabled = true;
      btnText.classList.add('opacity-0');
      messageBox.className = 'hidden';
      setTimeout(() => btnSpinner.classList.remove('hidden'), 150);

      try {
        const data = Object.fromEntries(formData.entries());

        const response = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        if (!response.ok) {
            const errData = await response.json().catch((): { error?: string } => ({}));
            throw new Error((errData as any).error || 'Server rejected submission');
        }
        
        btnSpinner.classList.add('hidden');
        btnText.classList.remove('opacity-0');
        
        overlay.classList.remove('hidden');
        setTimeout(() => overlay.classList.remove('opacity-0'), 50);
        
        form.reset();

      } catch (error: any) {
        console.error('Form submission failed:', error);
        btn.disabled = false;
        btnSpinner.classList.add('hidden');
        btnText.classList.remove('opacity-0');
        
        messageBox.textContent = error.message || "We encountered a network error. Please try again.";
        messageBox.className = 'rounded-xl p-4 mb-6 text-sm font-medium bg-red-50 text-red-600 border border-red-200 block';
      }
    });
  });
</script>