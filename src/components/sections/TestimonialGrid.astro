---
// src/components/sections/TestimonialGrid.astro
const CheckIcon = `<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`;
---

<section class="py-16 md:py-24 lg:py-32 bg-[#022c22]" id="testimonials" aria-labelledby="testimonials-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-12 md:mb-16 max-w-3xl mx-auto">
      <span class="text-xs font-black tracking-widest uppercase text-emerald-400 block mb-3">Real Families. Real Results.</span>
      <h2 id="testimonials-heading" class="text-4xl lg:text-5xl font-semibold text-white mb-5 tracking-tight text-balance">
        Don't take our word for it.
      </h2>
      <p class="text-lg text-emerald-100/80 font-medium text-balance">
        These are unedited reviews from parents across our community.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 sm:gap-8 mb-16 lg:mb-20">
      
      <blockquote class="bg-white/5 border border-white/10 rounded-3xl p-6 sm:p-8 flex flex-col hover:bg-white/10 transition-colors duration-300 ease-out">
        <div class="text-amber-400 text-lg tracking-widest mb-6 drop-shadow-sm" aria-hidden="true">★★★★★</div>
        <p class="font-serif text-lg sm:text-xl italic text-white/95 mb-8 flex-1 leading-relaxed text-balance">"My daughter used to cry before her old Quran class. After two months with Quranific, she reminds ME it's time for her lesson. I didn't think that was possible."</p>
        <footer class="flex items-center gap-4 pt-6 border-t border-white/10">
          <div class="w-12 h-12 rounded-full bg-amber-50 text-amber-700 flex items-center justify-center font-bold text-lg shrink-0" aria-hidden="true">SA</div>
          <div>
            <cite class="font-bold text-white text-sm not-italic">Sarah A.</cite>
            <div class="text-xs text-emerald-100/60 font-medium">Manchester, UK · Daughter, age 8</div>
          </div>
        </footer>
        <div class="mt-4 text-[11px] font-bold text-emerald-400 flex items-center gap-1.5 uppercase tracking-wider"><Fragment set:html={CheckIcon} /> Verified · Enrolled 14 months</div>
      </blockquote>

      <blockquote class="bg-white/5 border border-white/10 rounded-3xl p-6 sm:p-8 flex flex-col hover:bg-white/10 transition-colors duration-300 ease-out">
        <div class="text-amber-400 text-lg tracking-widest mb-6 drop-shadow-sm" aria-hidden="true">★★★★★</div>
        <p class="font-serif text-lg sm:text-xl italic text-white/95 mb-8 flex-1 leading-relaxed text-balance">"As a father working long hours, the guilt was real. Quranific didn't just teach my sons tajweed — they gave me back the peace of knowing I didn't drop the ball on their deen."</p>
        <footer class="flex items-center gap-4 pt-6 border-t border-white/10">
          <div class="w-12 h-12 rounded-full bg-emerald-50 text-emerald-700 flex items-center justify-center font-bold text-lg shrink-0" aria-hidden="true">KH</div>
          <div>
            <cite class="font-bold text-white text-sm not-italic">Khalid H.</cite>
            <div class="text-xs text-emerald-100/60 font-medium">Houston, USA · Two sons, 9 & 12</div>
          </div>
        </footer>
        <div class="mt-4 text-[11px] font-bold text-emerald-400 flex items-center gap-1.5 uppercase tracking-wider"><Fragment set:html={CheckIcon} /> Verified · Enrolled 8 months</div>
      </blockquote>

      <blockquote class="bg-white/5 border border-white/10 rounded-3xl p-6 sm:p-8 flex flex-col hover:bg-white/10 transition-colors duration-300 ease-out">
        <div class="text-amber-400 text-lg tracking-widest mb-6 drop-shadow-sm" aria-hidden="true">★★★★★</div>
        <p class="font-serif text-lg sm:text-xl italic text-white/95 mb-8 flex-1 leading-relaxed text-balance">"The make-up class policy alone is worth it. We travel a lot for work and previous academies just let sessions disappear. Quranific has never let us miss a lesson."</p>
        <footer class="flex items-center gap-4 pt-6 border-t border-white/10">
          <div class="w-12 h-12 rounded-full bg-purple-50 text-purple-700 flex items-center justify-center font-bold text-lg shrink-0" aria-hidden="true">NM</div>
          <div>
            <cite class="font-bold text-white text-sm not-italic">Nadia M.</cite>
            <div class="text-xs text-emerald-100/60 font-medium">Dubai, UAE · Son, age 7</div>
          </div>
        </footer>
        <div class="mt-4 text-[11px] font-bold text-emerald-400 flex items-center gap-1.5 uppercase tracking-wider"><Fragment set:html={CheckIcon} /> Verified · Enrolled 11 months</div>
      </blockquote>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
      <div class="bg-emerald-950/40 border border-emerald-800/50 rounded-3xl p-6 sm:p-8 text-center backdrop-blur-sm">
        <div class="font-serif text-4xl lg:text-5xl font-semibold text-white mb-2">3,200<span class="text-amber-400 text-3xl" aria-hidden="true">+</span></div>
        <div class="text-xs sm:text-sm font-medium text-emerald-100/60 uppercase tracking-widest">Families enrolled</div>
      </div>
      <div class="bg-emerald-950/40 border border-emerald-800/50 rounded-3xl p-6 sm:p-8 text-center backdrop-blur-sm">
        <div class="font-serif text-4xl lg:text-5xl font-semibold text-white mb-2">22</div>
        <div class="text-xs sm:text-sm font-medium text-emerald-100/60 uppercase tracking-widest">Countries served</div>
      </div>
      <div class="bg-emerald-950/40 border border-emerald-800/50 rounded-3xl p-6 sm:p-8 text-center backdrop-blur-sm">
        <div class="font-serif text-4xl lg:text-5xl font-semibold text-white mb-2">94<span class="text-amber-400 text-3xl" aria-hidden="true">%</span></div>
        <div class="text-xs sm:text-sm font-medium text-emerald-100/60 uppercase tracking-widest">Retention (Mo 1)</div>
      </div>
      <div class="bg-emerald-950/40 border border-emerald-800/50 rounded-3xl p-6 sm:p-8 text-center backdrop-blur-sm">
        <div class="font-serif text-4xl lg:text-5xl font-semibold text-white mb-2">4.9<span class="text-amber-400 text-3xl" aria-hidden="true">★</span></div>
        <div class="text-xs sm:text-sm font-medium text-emerald-100/60 uppercase tracking-widest">Average rating</div>
      </div>
    </div>

  </div>
</section>