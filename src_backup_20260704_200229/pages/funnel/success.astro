---
// src/pages/funnel/success.astro
import Funnel from '../../layouts/Funnel.astro';
import StepIndicator from '../../components/funnel/StepIndicator.svelte';
import { generateWhatsAppLink } from '../../lib/helpers';

// Central helper to generate the secure, encoded link
const waLink = generateWhatsAppLink("As-salamu alaykum! I just completed my registration on Quranific and I'm ready to schedule my free trial.");
---
<Funnel title="Registration Successful | Quranific">
  <div class="w-full flex flex-col items-center justify-center text-center animate-in duration-700 fade-in slide-in-from-bottom-4">
    
    <div class="w-full mb-8">
      <StepIndicator currentStep={3} client:visible />
    </div>
    
    <div class="relative mb-6">
      <div class="absolute w-full h-full bg-emerald-500/20 rounded-full blur-2xl animate-pulse"></div>
      <div class="absolute w-full h-full bg-emerald-300/30 rounded-full blur-xl"></div>
      
      <div class="relative z-10 w-16 h-16 bg-white border-2 border-emerald-500 rounded-full flex items-center justify-center shadow-lg mx-auto">
        <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
    </div>
    
    <div class="text-center mb-6">
      <h1 class="text-2xl lg:text-3xl font-black text-emerald-950 tracking-tight mb-2">
        You're All Set!
      </h1>
      <p class="text-sm text-emerald-700/80 font-medium max-w-sm mx-auto">
        Alhamdulillah, we’ve received your details and are matching you with the perfect teacher.
      </p>
    </div>

    <div class="w-full max-w-sm mx-auto bg-emerald-50/50 border border-emerald-100/80 rounded-2xl p-5 mb-6 text-left shadow-sm">
      <h3 class="font-bold text-emerald-950 text-sm mb-3 flex items-center gap-2">
        <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        What Happens Now:
      </h3>
      <ul class="space-y-3">
        <li class="flex items-start gap-2.5">
          <div class="w-5 h-5 rounded-full bg-emerald-100 flex items-center justify-center shrink-0 mt-0.5"><span class="text-emerald-700 text-[10px] font-bold">1</span></div>
          <p class="text-xs text-emerald-800 font-medium leading-relaxed">We review your goals to find your ideal tutor.</p>
        </li>
        <li class="flex items-start gap-2.5">
          <div class="w-5 h-5 rounded-full bg-emerald-100 flex items-center justify-center shrink-0 mt-0.5"><span class="text-emerald-700 text-[10px] font-bold">2</span></div>
          <p class="text-xs text-emerald-800 font-medium leading-relaxed">We schedule your free trial class at your convenience.</p>
        </li>
      </ul>
    </div>
    
    <div class="w-full max-w-sm mx-auto">
      <a href={waLink} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center w-full gap-3 bg-gradient-to-br from-white via-emerald-50 to-emerald-100 text-emerald-950 font-bold py-3.5 px-6 rounded-2xl border-2 border-emerald-500 hover:scale-[1.02] transition-[color,background-color,border-color,box-shadow,opacity,transform] duration-300 shadow-md active:scale-95 text-base group">
        
        <svg class="w-5 h-5 group-hover:scale-110 transition-transform text-emerald-600" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        Message us to start now
      </a>
      
      <p class="text-[10px] text-center text-emerald-600/60 mt-3 font-medium">
        (Typically fastest response)
      </p>
    </div>
    
  </div>
</Funnel>