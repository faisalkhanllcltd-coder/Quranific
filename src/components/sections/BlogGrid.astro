---
// src/components/sections/BlogGrid.astro
// SEO Article Grid.
---

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
  {[1, 2, 3].map(item => (
    <article class="bg-white border border-emerald-100 rounded-3xl overflow-hidden hover:shadow-xl hover:border-emerald-200 hover:-translate-y-1 transition-[color,background-color,border-color,box-shadow,opacity,transform] group flex flex-col">
      <div class="w-full h-48 bg-emerald-50 relative overflow-hidden">
        <div class="absolute inset-0 bg-emerald-900/5 group-hover:bg-transparent transition-colors"></div>
        <div class="absolute inset-0 flex items-center justify-center text-emerald-200">
          <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        </div>
      </div>
      <div class=a"p-6 lg:p-8 flex flex-col flex-1">
        <div class="flex items-center gap-3 mb-4">
          <span class="px-3 py-1 bg-amber-50 text-amber-700 text-[10px] font-black tracking-widest uppercase rounded-full">Guide</span>
          <span class="text-xs font-bold text-emerald-800/40">Mar 15, 2026</span>
        </div>
        <h3 class="text-xl font-bold text-emerald-950 mb-3 leading-snug group-hover:text-emerald-700 transition-colors">
          How to help your child memorize the Quran effectively
        </h3>
        <p class="text-sm text-emerald-700/70 font-medium leading-relaxed mb-6 flex-1">
          Discover proven pedagogical techniques to make Hifz an enjoyable and rewarding journey for younger students without causing burnout.
        </p>
        <a href="#" class="inline-flex items-center gap-2 text-sm font-bold text-emerald-800 hover:text-amber-600 transition-colors mt-auto">
          Read Article <span class="text-lg leading-none">→</span>
        </a>
      </div>
    </article>
  ))}
</div>